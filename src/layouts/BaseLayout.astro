---
import "../styles/global.css";
import { SITE, GA4_MEASUREMENT_ID } from "../consts";
import GlassNav from "../components/GlassNav.astro";
import Footer from "../components/Footer.astro";
import EntryOverlay from "../components/EntryOverlay.astro";

interface Props {
  /** Page title; omit on the home page to use the full default title. */
  title?: string;
  description?: string;
  /** OG/Twitter image (root-relative). Defaults to the site card. */
  image?: string;
  /** og:type — "website" (default) or "article" for project detail pages. */
  ogType?: "website" | "article";
  /** Set true to keep a page out of search indexes (e.g. /dev, 404). Emits "noindex, nofollow". */
  noindex?: boolean;
  /**
   * Explicit robots directive — overrides `noindex`. Use for tiered pages that
   * should stay out of the index but keep passing link equity, e.g.
   * "noindex, follow" on secondary programmatic location pages.
   */
  robots?: string;
  /** Render without nav + footer chrome. */
  bare?: boolean;
  /** schema.org JSON-LD object(s) emitted into <head>. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Preload an above-the-fold LCP image (e.g. the hero). */
  preloadImage?: string;
  /** Homepage-only Live Set entry animation overlay. */
  entryAnimation?: boolean;
}

const {
  title,
  description,
  image,
  ogType = "website",
  noindex = false,
  robots,
  bare = false,
  jsonLd,
  preloadImage,
  entryAnimation = false,
} = Astro.props;

const jsonLdItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

const pageTitle = title ? SITE.titleTemplate.replace("%s", title) : SITE.defaultTitle;
const pageDescription = description ?? SITE.description;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const ogImage = new URL(image ?? SITE.ogImage, SITE.url).href;
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />

    <script is:inline define:vars={{ entryAnimation }}>
      try {
        const root = document.documentElement;
        root.classList.add("js");

        if (entryAnimation) {
          const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
          let entryPlayed = false;
          try {
            entryPlayed = sessionStorage.getItem("rc_entry_played") === "1";
          } catch (e) {
            entryPlayed = false;
          }
          if (!reduceMotion && !entryPlayed) root.classList.add("entry-pending");
        }

        const savedTheme = localStorage.getItem("rc_theme");
        const theme =
          savedTheme === "light" || savedTheme === "dark"
            ? savedTheme
            : matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
        root.dataset.theme = theme;
      } catch (e) {
        document.documentElement.classList.add("js");
        document.documentElement.dataset.theme = "light";
      }
    </script>

    <meta name="theme-color" content={SITE.themeColor} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#191612" media="(prefers-color-scheme: dark)" />
    <meta name="generator" content={Astro.generator} />

    {/* Google Search Console site ownership verification. */}
    <meta name="google-site-verification" content="fyZS5UavT94a55wy-FnpHgdni_klAkPjiKyfS0WFtfw" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    {(robots ?? (noindex ? "noindex, nofollow" : undefined)) && (
      <meta name="robots" content={robots ?? "noindex, nofollow"} />
    )}

    {/* Blog RSS feed discovery */}
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.name} — Günlük`}
      href={new URL("/rss.xml", SITE.url).href}
    />

    {/* Local SEO geo hints (Sakarya / TR-54). No invented coordinates. */}
    <meta name="geo.region" content="TR-54" />
    <meta name="geo.placename" content="Sakarya" />

    <!-- Icons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    {/* Preload only the LCP image so it gets the connection first; fonts rely
        on font-display:swap (CLS is 0, so the swap costs no layout shift). */}
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
    <link rel="preload" as="font" type="font/woff2" href="/fonts/fraunces-latin-standard-normal.woff2" crossorigin />
    {/* Space Grotesk (UI/buttons/eyebrows) — preload both subsets so above-the-fold
        labels (incl. Turkish İ/ş in latin-ext) don't swap in late on first load. */}
    <link rel="preload" as="font" type="font/woff2" href="/fonts/space-grotesk-latin-wght-normal.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/space-grotesk-latin-ext-wght-normal.woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />

    {jsonLdItems.map((obj) => <script type="application/ld+json" set:html={JSON.stringify(obj)} />)}

    {/* Google Analytics 4: queue immediately, load the external script after the page settles. */}
    <script is:inline define:vars={{ GA4_MEASUREMENT_ID }}>
      const params = new URLSearchParams(window.location.search);
      let storedAnalyticsDisabled = false;
      try {
        if (params.get("rc_analytics") === "off") {
          localStorage.setItem("rc_analytics_disabled", "1");
        }
        if (params.get("rc_analytics") === "on") {
          localStorage.removeItem("rc_analytics_disabled");
        }
        storedAnalyticsDisabled = localStorage.getItem("rc_analytics_disabled") === "1";
      } catch (e) {
        storedAnalyticsDisabled = false;
      }

      const analyticsDisabled =
        window.location.hostname === "localhost" ||
        window.location.hostname === "127.0.0.1" ||
        window.location.pathname.startsWith("/admin") ||
        storedAnalyticsDisabled;

      window[`ga-disable-${GA4_MEASUREMENT_ID}`] = analyticsDisabled;
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      window.rcTrack = (eventName, eventParams = {}, callback) => {
        const done = () => {
          if (typeof callback === "function") callback();
        };
        if (analyticsDisabled || typeof gtag !== "function") {
          done();
          return;
        }

        let settled = false;
        const finish = () => {
          if (settled) return;
          settled = true;
          done();
        };

        gtag("event", eventName, {
          ...eventParams,
          event_callback: finish,
          event_timeout: 1200,
        });
        window.setTimeout(finish, 1300);
      };

      if (!analyticsDisabled) {
        gtag('js', new Date());
        gtag('config', GA4_MEASUREMENT_ID);
      }

      const loadAnalytics = () => {
        if (analyticsDisabled) return;
        if (document.querySelector('script[data-ga4]')) return;
        cleanupAnalyticsTriggers();
        const s = document.createElement('script');
        s.async = true;
        s.src = `https://www.googletagmanager.com/gtag/js?id=${GA4_MEASUREMENT_ID}`;
        s.dataset.ga4 = 'true';
        document.head.appendChild(s);
      };

      const analyticsEvents = ["pointerdown", "keydown", "scroll", "touchstart"];
      const analyticsOpts = { once: true, passive: true };
      const cleanupAnalyticsTriggers = () => {
        analyticsEvents.forEach((event) => window.removeEventListener(event, loadAnalytics, analyticsOpts));
      };

      analyticsEvents.forEach((event) => window.addEventListener(event, loadAnalytics, analyticsOpts));
      window.addEventListener("load", () => window.setTimeout(loadAnalytics, 30000), { once: true });

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const link = target.closest("a[href]");
        if (!(link instanceof HTMLAnchorElement)) return;

        const href = link.getAttribute("href") || "";
        const text = (link.textContent || "").trim().replace(/\s+/g, " ");
        const ctaLocation = link.dataset.ctaLocation;
        if (ctaLocation) {
          window.rcTrack("cta_click", {
            event_category: "engagement",
            cta_text: text,
            location: ctaLocation,
            link_url: href,
          });
        }

        if (href.startsWith("/projeler/")) {
          window.rcTrack("project_view", {
            event_category: "portfolio",
            project_slug: href.replace(/^\/projeler\//, "").replace(/\/$/, ""),
            link_text: text,
          });
        }

        if (href.startsWith("tel:")) {
          window.rcTrack("contact_phone_click", {
            event_category: "contact",
            event_label: "phone",
            link_url: href,
          });
        } else if (href.startsWith("mailto:")) {
          window.rcTrack("contact_email_click", {
            event_category: "contact",
            event_label: "email",
            link_url: href,
          });
        } else if (href.includes("wa.me/") || href.includes("api.whatsapp.com/")) {
          window.rcTrack("contact_whatsapp_click", {
            event_category: "contact",
            event_label: "whatsapp_link",
            link_url: href,
          });
        }
      });
    </script>
  </head>

  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-[var(--radius-sm)] focus:bg-ink focus:px-4 focus:py-2 focus:font-utility focus:text-paper"
    >
      İçeriğe geç
    </a>
    {!bare && entryAnimation && <EntryOverlay />}
    {!bare && <GlassNav />}
    <main id="main">
      <slot />
    </main>
    {!bare && <Footer />}

    <script>
      const initReveal = () => {
        // Scroll-reveal: reveal [data-reveal] elements as they enter the viewport.
        const revealEls = document.querySelectorAll<HTMLElement>("[data-reveal]:not(.is-revealed)");
        if (!revealEls.length) return;

        const animateOdometer = (root: HTMLElement) => {
          if (root.dataset.odometerStarted === "true") return;
          root.dataset.odometerStarted = "true";

          const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
          root.querySelectorAll<HTMLElement>(".stats__n").forEach((el) => {
            const value = (el.textContent ?? "").trim();
            const match = value.match(/^(\d+)(.*)$/);
            if (!match) return;

            const target = Number(match[1]);
            const suffix = match[2] ?? "";
            if (!Number.isFinite(target)) return;
            if (reduceMotion) {
              el.textContent = value;
              return;
            }

            const duration = 900;
            const start = performance.now();
            const tick = (now: number) => {
              const progress = Math.min((now - start) / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              el.textContent = `${Math.round(target * eased)}${suffix}`;
              if (progress < 1) requestAnimationFrame(tick);
              else el.textContent = value;
            };
            el.textContent = `0${suffix}`;
            requestAnimationFrame(tick);
          });
        };

        const reveal = (el: HTMLElement) => {
          el.classList.add("is-revealed");
          if (el.dataset.reveal === "odometer") animateOdometer(el);
        };

        if (!("IntersectionObserver" in window)) {
          revealEls.forEach(reveal);
          return;
        }

        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                reveal(entry.target as HTMLElement);
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.08 },
        );
        revealEls.forEach((el) => io.observe(el));
      };

      initReveal();
    </script>
  </body>
</html>
