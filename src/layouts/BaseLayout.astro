---
import "../styles/global.css";
import { SITE } from "../consts";
import GlassNav from "../components/GlassNav.astro";
import Footer from "../components/Footer.astro";
import Clapperboard from "../components/Clapperboard.astro";
import Preloader from "../components/Preloader.astro";
import WhatsAppFab from "../components/WhatsAppFab.astro";

interface Props {
  /** Page title; omit on the home page to use the full default title. */
  title?: string;
  description?: string;
  /** OG/Twitter image (root-relative). Defaults to the site card. */
  image?: string;
  /** og:type — "website" (default) or "article" for project detail pages. */
  ogType?: "website" | "article";
  /** Set true to keep a page out of search indexes (e.g. /dev, 404). */
  noindex?: boolean;
  /** Render without nav + footer chrome. */
  bare?: boolean;
  /** schema.org JSON-LD object(s) emitted into <head>. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Preload an above-the-fold LCP image (e.g. the hero). */
  preloadImage?: string;
}

const {
  title,
  description,
  image,
  ogType = "website",
  noindex = false,
  bare = false,
  jsonLd,
  preloadImage,
} = Astro.props;

const jsonLdItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

const pageTitle = title ? SITE.titleTemplate.replace("%s", title) : SITE.defaultTitle;
const pageDescription = description ?? SITE.description;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const ogImage = new URL(image ?? SITE.ogImage, SITE.url).href;
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />

    {/* Show the preloader once per session, never for reduced-motion. Runs
        synchronously before first paint so it never flashes on later pages. */}
    {!bare && (
      <script is:inline>
        try {
          if (
            !sessionStorage.getItem("rc_preloaded") &&
            !matchMedia("(prefers-reduced-motion: reduce)").matches
          ) {
            document.documentElement.classList.add("rc-preload");
            sessionStorage.setItem("rc_preloaded", "1");
          }
        } catch (e) {}
      </script>
      <style is:global>
        #preloader { display: none; }
        html.rc-preload #preloader { display: grid; }
      </style>
    )}
    <meta name="theme-color" content={SITE.themeColor} />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Local SEO geo hints (Sakarya / TR-54). No invented coordinates. */}
    <meta name="geo.region" content="TR-54" />
    <meta name="geo.placename" content="Sakarya" />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    {/* Preload only the LCP image so it gets the connection first; fonts rely
        on font-display:swap (CLS is 0, so the swap costs no layout shift). */}
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />

    {jsonLdItems.map((obj) => <script type="application/ld+json" set:html={JSON.stringify(obj)} />)}
  </head>

  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-[var(--radius-sm)] focus:bg-ink focus:px-4 focus:py-2 focus:font-utility focus:text-paper"
    >
      İçeriğe geç
    </a>
    {!bare && <Preloader />}
    {!bare && <Clapperboard />}
    {!bare && <GlassNav />}
    <main id="main">
      <slot />
    </main>
    {!bare && <Footer />}
    {!bare && <WhatsAppFab />}

    <script>
      // Scroll-reveal: reveal [data-reveal] elements as they enter the viewport.
      const revealEls = document.querySelectorAll<HTMLElement>("[data-reveal]");
      if (revealEls.length) {
        if (!("IntersectionObserver" in window)) {
          revealEls.forEach((el) => el.classList.add("is-revealed"));
        } else {
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-revealed");
                  io.unobserve(entry.target);
                }
              }
            },
            { rootMargin: "0px 0px -8% 0px", threshold: 0.08 },
          );
          revealEls.forEach((el) => io.observe(el));
        }
      }
    </script>
  </body>
</html>
