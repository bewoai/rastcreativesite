---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Eyebrow from "../components/Eyebrow.astro";
import Button from "../components/Button.astro";
---

<BaseLayout title="Sayfa bulunamadı" noindex>
  <Section>
    <div class="nf">
      <Eyebrow>Hata · 404</Eyebrow>
      <h1 class="nf__title">Bu kare bulunamadı.</h1>
      <p class="nf__text">
        Aradığınız sayfa taşınmış ya da hiç var olmamış olabilir. Buradan devam
        edebilirsiniz:
      </p>
      <div class="nf__cta">
        <Button href="/">Ana sayfa</Button>
        <Button href="/projeler" variant="secondary" arrow>Projelerimizi İzleyin</Button>
      </div>

      <nav class="nf__nav" aria-label="Hızlı gezinme">
        <a href="/hizmetler" class="nf__link">Hizmetlerimiz</a>
        <span class="nf__sep" aria-hidden="true">·</span>
        <a href="/hakkimizda" class="nf__link">Hakkımızda</a>
        <span class="nf__sep" aria-hidden="true">·</span>
        <a href="/iletisim" class="nf__link">İletişim</a>
      </nav>
    </div>
  </Section>
</BaseLayout>

<style>
  .nf {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    align-items: center;
    text-align: center;
    min-height: 52vh;
    justify-content: center;
    max-width: var(--container-max);
    margin-inline: auto;
  }
  .nf__title {
    margin: 0;
    max-width: 16ch;
  }
  .nf__text {
    margin: 0;
    max-width: 48ch;
    color: var(--ink-soft);
    font-size: 1.1rem;
  }
  .nf__cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
    margin-top: 0.5rem;
  }
  .nf__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    margin-top: 1.5rem;
    font-family: var(--font-utility);
    font-size: 0.95rem;
  }
  .nf__link {
    color: var(--ink-soft);
    transition: color var(--dur-fast) var(--ease-out);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .nf__link:hover {
    color: var(--amber-text);
  }
  .nf__link:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 2px;
  }
  .nf__sep {
    color: var(--line);
  }
</style>
