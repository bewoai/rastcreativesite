---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Eyebrow from "../components/Eyebrow.astro";
import Button from "../components/Button.astro";
---

<BaseLayout title="Sayfa bulunamadı" noindex>
  <Section>
    <div class="nf">
      <Eyebrow>Hata · 404</Eyebrow>
      <h1 class="nf__title">Bu kare bulunamadı.</h1>
      <p class="nf__text">
        Aradığınız sayfa taşınmış ya da hiç var olmamış olabilir. Buradan devam
        edebilirsiniz:
      </p>
      <div class="nf__cta">
        <Button href="/">Ana sayfa</Button>
        <Button href="/projeler" variant="secondary" arrow>Projeleri izle</Button>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .nf {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    align-items: flex-start;
    min-height: 48vh;
    justify-content: center;
  }
  .nf__title {
    margin: 0;
    max-width: 16ch;
  }
  .nf__text {
    margin: 0;
    max-width: 48ch;
    color: var(--ink-soft);
    font-size: 1.1rem;
  }
  .nf__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 0.5rem;
  }
</style>
