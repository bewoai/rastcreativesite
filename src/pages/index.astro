---
import { getCollection, render } from "astro:content";
import { Picture, getImage } from "astro:assets";
import whyPhoto from "../assets/photos/hero-cinema.jpg";
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Eyebrow from "../components/Eyebrow.astro";
import Button from "../components/Button.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import AccordionItem from "../components/AccordionItem.astro";
import LogoWall from "../components/LogoWall.astro";
import VideoHero from "../components/VideoHero.astro";
import HeroShowreel3D from "../components/HeroShowreel3D.astro";
import AreaIndex from "../components/AreaIndex.astro";
import BlogCard from "../components/BlogCard.astro";
import heroDesktopImg from "../assets/photos/hero-set-desktop.webp";
import heroMobileImg from "../assets/photos/hero-set-mobile.webp";
import { COPY, PRIMARY_CTA } from "../consts";
import { localBusiness, organization, webSite, faqPage, toPlainText } from "../lib/schema";
import { groupByBrand } from "../lib/brands";
import { SEO_SERVICES } from "../data/seo-services";
import { AREA_INDEX_LOCATION_SLUGS, SEO_LOCATIONS } from "../data/locations";

const byOrder = (a: { data: { order: number } }, b: { data: { order: number } }) =>
  a.data.order - b.data.order;

const projects = (await getCollection("projects")).filter((p) => !p.data.draft);
const dailyProjectCount = 3;
const dailyProjects = [...projects].sort(byOrder);
const services = (await getCollection("services")).sort(byOrder);
const faqEntries = (await getCollection("faq")).sort(byOrder);
const faqRendered = await Promise.all(
  faqEntries.map(async (e) => ({ data: e.data, Content: (await render(e)).Content })),
);

// Latest blog posts for the homepage "Son yazılar" section.
const blogPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
const fmtBlogDate = (d: Date) =>
  d.toLocaleDateString("tr-TR", { day: "numeric", month: "long", year: "numeric" });

// Quick credibility numbers — derived from real content so they stay accurate.
const brandCount = groupByBrand(projects).length;
const stats = [
  {
    n: `${brandCount}+`,
    l: "Marka",
    d: "Sanayi, medikal, perakende ve hizmet sektörlerinde farklı markalarla üretim süreci yürüttük.",
  },
  {
    n: `${projects.length}`,
    l: "İçerik",
    d: "Tanıtım filmi, sosyal medya videosu, ürün videosu ve reklam formatlarında içerikler ürettik.",
  },
  {
    n: "4K",
    l: "Sinema Standardı",
    d: "Profesyonel kamera, ışık, ses ve renk düzenleme süreciyle yayına hazır çıktılar teslim ederiz.",
  },
  {
    n: "Sakarya",
    l: "Merkezli Stüdyo",
    d: "Sakarya, Kocaeli, Gebze ve çevresinde yerinde çekim süreçleri planlıyoruz.",
  },
];

// "Nasıl çalışırız" — process clarity the 35+ audience wants (roadmap §2.5).
const steps = [
  {
    n: "01",
    t: "Ücretsiz ön görüşme",
    d: "Projenizi dinler; formatı, kapsamı ve takvimi birlikte netleştiririz.",
  },
  {
    n: "02",
    t: "Çekim & prodüksiyon",
    d: "Sinema standardı ekipmanla sahadayız; ön hazırlıktan sete tek ekip disiplini.",
  },
  {
    n: "03",
    t: "Kurgu & teslim",
    d: "Post-prodüksiyon, renk ve son rötuş; genellikle 2–4 hafta içinde teslim.",
  },
];

// "Neden Rast" — concrete trust signals for the 35+ audience (roadmap §2.5).
const whyRast = [
  {
    k: "Yerinde çekim",
    t: "Sahaya yakın prodüksiyon",
    d: "Sakarya ve çevresinde keşif, planlama, prodüksiyon ve kurgu sürecini tek ekip olarak yürütürüz.",
  },
  {
    k: "Tek elden",
    t: "Dağılmayan üretim akışı",
    d: "Fikir, senaryo, çekim, kurgu, renk ve teslim süreci aynı masada ilerler; projenin muhatabı değişmez.",
  },
  {
    k: "Format uyumu",
    t: "Web, reklam ve sosyal medya",
    d: "Ana videonun yanında Reels, Shorts, YouTube ve reklam kullanımına uygun versiyonları baştan planlarız.",
  },
];

const prioritySeoServices = SEO_SERVICES.filter((s) =>
  ["video-cekimi", "drone-cekimi", "tanitim-filmi", "reklam-filmi", "sosyal-medya-icerigi"].includes(s.slug),
);
const prioritySeoLocations = SEO_LOCATIONS.filter((l) =>
  AREA_INDEX_LOCATION_SLUGS.includes(l.slug),
);

// Home-page structured data: enriched LocalBusiness + FAQPage (rich results).
const pageJsonLd = [
  organization,
  webSite,
  localBusiness,
  faqPage(
    faqEntries.map((e) => ({
      question: e.data.question,
      answer: toPlainText(e.body ?? ""),
    })),
  ),
];

const heroDesktop = await getImage({
  src: heroDesktopImg,
  width: 1920,
  format: "webp",
  quality: 72,
});
const heroMobile = await getImage({
  src: heroMobileImg,
  width: 900,
  format: "webp",
  quality: 72,
});
---

<BaseLayout jsonLd={pageJsonLd}>
  {/* 1 — Hero (cinematic film-set header; art-directed poster) */}
  <VideoHero poster={heroDesktop.src} posterMobile={heroMobile.src} flush class="hero">
    <div class="hero__layout">
      <div class="hero__text">
        <Eyebrow tone="paper">Sakarya · Sinematik Video Prodüksiyon</Eyebrow>
        <h1 class="hero__title">{COPY.heroTitle}</h1>
        <p class="hero__subtitle">{COPY.heroSubtitle}</p>
        <p class="hero__trust">{COPY.heroTrust}</p>
        <div class="hero__cta">
          <Button href={PRIMARY_CTA.href} size="lg" arrow data-cta-location="hero">
            {PRIMARY_CTA.label}
          </Button>
          <Button href="/projeler" variant="secondary" size="lg" class="hero__ghost" data-cta-location="hero">
            {COPY.heroSecondaryCta}
          </Button>
        </div>
      </div>
    </div>
  </VideoHero>

  <HeroShowreel3D />

  {/* 2 — Seçili işler */}
  <Section id="secili-isler">
    <div class="head-row">
      <SectionHeading eyebrow="Sahne 02 · Seçili İşler">Son işlerimizden seçmeler</SectionHeading>
      <Button href="/projeler" variant="secondary" arrow class="head-row__cta">Tümünü gör</Button>
    </div>
    <div class="grid-cards" data-daily-projects data-daily-count={dailyProjectCount}>
      {
        dailyProjects.map((p, index) => (
          <div class="daily-project" data-daily-project data-project-index={index}>
            <ProjectCard
              href={p.data.externalUrl ?? `/projeler/${p.id}`}
              title={p.data.title}
              category={p.data.category}
              poster={p.data.poster}
              posterAlt={p.data.posterAlt}
              client={p.data.client}
              year={p.data.year}
              timecode={p.data.duration}
              vertical={p.data.vertical}
              preview={p.data.preview}
              summary={p.data.summary}
            />
          </div>
        ))
      }
    </div>
  </Section>

  {/* 3 — Referans logoları */}
  <Section space="tight">
    <div class="refs">
      <Eyebrow tone="soft">Çalıştığımız markalardan bazıları</Eyebrow>
      <LogoWall />
    </div>
  </Section>

  {/* 3.5 — İstatistik barı */}
  <Section space="tight">
    <ul class="stats" data-reveal aria-label="Rakamlarla Rast Creative">
      {
        stats.map((s) => (
          <li class="stats__item">
            <span class="stats__n">{s.n}</span>
            <span class="stats__l">{s.l}</span>
            <span class="stats__d">{s.d}</span>
          </li>
        ))
      }
    </ul>
  </Section>

  {/* 4 — Hizmetler özeti */}
  <Section id="hizmetler-ozet">
    <SectionHeading eyebrow="Sahne 03 · Hizmetler">
      Uçtan uca üç ana hizmet
      <Fragment slot="intro">
        <p>Fikirden teslime; strateji, prodüksiyon ve post-prodüksiyonu tek elden yürütürüz.</p>
      </Fragment>
    </SectionHeading>
    <div class="grid-services">
      {
        services.map((s, i) => (
          <ServiceCard
            href={`/hizmetler#${s.id}`}
            index={i + 1}
            title={s.data.title}
            summary={s.data.summary}
            features={s.data.features.slice(0, 3)}
          />
        ))
      }
    </div>
  </Section>

  {/* 4.25 — Bölgesel SEO hub */}
  <Section space="tight">
    <AreaIndex
      eyebrow="Sakarya ve çevresi"
      title="Sakarya ve Serdivan'da prodüksiyon hizmetleri"
      text="Sakarya merkezli markalar için video çekimi, drone, tanıtım filmi, reklam filmi ve sosyal medya içeriklerini bölgeye göre planlıyoruz. Çekim yapılacak ilçeyi seçerek ilgili hizmet detaylarına geçebilirsiniz."
      services={prioritySeoServices}
      locations={prioritySeoLocations}
    />
  </Section>

  <Section width="narrow" space="tight">
    <div class="seo-copy" data-reveal>
      <h2>Sakarya'da video çekimi nasıl planlanır?</h2>
      <p>
        Rast Creative Studio, Sakarya ve Serdivan merkezli işletmeler için video çekimi
        sürecini hedef, mecra ve teslim formatına göre planlar. Tanıtım filmi,
        sosyal medya videosu, ürün çekimi, etkinlik kaydı veya kurumsal prodüksiyon
        ihtiyacında önce mesajı netleştirir; ardından sahne akışı, kamera, ışık,
        ses, kurgu ve renk düzenleme adımlarını tek üretim planında toplarız.
      </p>
      <p>
        Çekim günü sadece güzel görüntü almak için değil, markanın kullanabileceği
        içerik havuzunu büyütmek için tasarlanır. Aynı prodüksiyondan web sitesi,
        Instagram Reels, YouTube, reklam kampanyası ve satış sunumu için farklı
        sürelerde yatay ve dikey videolar hazırlanabilir.
      </p>
      <p>
        Sakarya tanıtım filmi projelerinde Serdivan, Adapazarı, Arifiye ve çevre
        ilçelerde keşif, çekim izni, sahne akışı ve teslim takvimini baştan
        netleştiririz. Ürün çekimi ve kurgu aşamasında ise videonun yalnızca iyi
        görünmesine değil, satış ekibi, web sitesi ve sosyal medya içerik planı
        içinde gerçekten kullanılabilir olmasına odaklanırız.
      </p>
    </div>
  </Section>

  {/* 4.5 — Ara CTA */}
  <Section space="tight">
    <div class="services-cta" data-reveal>
      <p class="services-cta__text">Projeniz için doğru kareyi birlikte yakalayalım.</p>
      <Button href={PRIMARY_CTA.href} arrow data-cta-location="services_mid_page">{PRIMARY_CTA.label}</Button>
    </div>
  </Section>

  {/* 5 — Neden Rast */}
  <Section id="neden-rast" tone="ink">
    <SectionHeading eyebrow="Sahne 04 · Neden Rast" eyebrowTone="paper">Somut güven sinyalleri</SectionHeading>
    <Picture
      src={whyPhoto}
      formats={["avif", "webp"]}
      alt="Sakarya'da video prodüksiyon setinde çekim ekibi, monitör ve sinema ışığı"
      widths={[600, 900, 1200, 1600]}
      sizes="(min-width: 1100px) 1040px, 92vw"
      loading="lazy"
      class="why__photo"
    />
    <ul class="why">
      {
        whyRast.map((w) => (
          <li class="why__item">
            <span class="why__k">{w.k}</span>
            <h3 class="why__t">{w.t}</h3>
            <p class="why__d">{w.d}</p>
          </li>
        ))
      }
    </ul>
  </Section>

  {/* 5.5 — Süreç */}
  <Section id="surec">
    <SectionHeading eyebrow="Sahne 05 · Süreç">
      Üç adımda, baştan sona
      <Fragment slot="intro">
        <p>Net bir akış: ön görüşmeden teslime kadar her aşamada yanınızdayız.</p>
      </Fragment>
    </SectionHeading>
    <ol class="steps" data-reveal>
      {
        steps.map((s) => (
          <li class="steps__item">
            <span class="steps__n">{s.n}</span>
            <h3 class="steps__t">{s.t}</h3>
            <p class="steps__d">{s.d}</p>
          </li>
        ))
      }
    </ol>
  </Section>

  {/* 6 — SSS */}
  <Section id="sss" width="narrow">
    <SectionHeading eyebrow="Sahne 06 · SSS">Sık sorulan sorular</SectionHeading>
    <div class="faq">
      {
        faqRendered.map((f, i) => {
          const Answer = f.Content;
          return (
            <AccordionItem question={f.data.question} open={i === 0}>
              <Answer />
            </AccordionItem>
          );
        })
      }
    </div>
  </Section>

  {/* 6.5 — Son yazılar (blog) */}
  {
    blogPosts.length > 0 && (
      <Section id="blog" space="tight">
        <div class="head-row">
          <SectionHeading eyebrow="Sahne 07 · Günlük">Son yazılar</SectionHeading>
          <Button href="/blog" variant="secondary" arrow class="head-row__cta">
            Tüm yazılar
          </Button>
        </div>
        <div class="grid-cards">
          {blogPosts.map((p) => (
            <BlogCard
              href={`/blog/${p.id}`}
              title={p.data.title}
              description={p.data.description}
              date={fmtBlogDate(p.data.pubDate)}
              datetime={p.data.pubDate.toISOString()}
              cover={p.data.cover}
              coverAlt={p.data.coverAlt}
            />
          ))}
        </div>
      </Section>
    )
  }

  {/* 7 — Son CTA bandı */}
  <Section tone="ink" space="tight">
    <div class="cta-band">
      <Eyebrow tone="paper">Hazır mısınız?</Eyebrow>
      <h2 class="cta-band__title">Markanızın sinematik yüzünü birlikte çekelim.</h2>
      <Button href={PRIMARY_CTA.href} size="lg" arrow data-cta-location="final_band">{PRIMARY_CTA.label}</Button>
    </div>
  </Section>
</BaseLayout>

<style>
  /* 1 — Hero (showreel background); content sits light over the video scrim */
  .hero__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3rem);
  }
  .hero__text {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    max-width: 42rem;
    position: relative;
    z-index: 2;
  }
  .hero__title {
    margin: 0;
    max-width: 18ch;
    color: var(--on-ink);
    letter-spacing: 0;
  }
  .hero__subtitle {
    margin: 0;
    max-width: 58ch;
    font-size: 1.2rem;
    color: color-mix(in srgb, var(--on-ink) 82%, transparent);
    line-height: 1.5;
  }
  .hero__trust {
    margin: -0.25rem 0 0;
    max-width: max-content;
    padding: 0.45rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--on-ink) 22%, transparent);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--ink) 46%, transparent);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    color: color-mix(in srgb, var(--on-ink) 82%, transparent);
    font-family: var(--font-utility);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 0.5rem;
  }
  @media (max-width: 520px) {
    .hero__text {
      gap: 0.9rem;
      max-width: 100%;
    }
    .hero__title {
      max-width: 13ch;
      font-size: clamp(2.35rem, 11vw, 3rem);
      line-height: 1.04;
    }
    .hero__subtitle {
      max-width: 30ch;
      font-size: 1rem;
      line-height: 1.45;
    }
    .hero__trust {
      max-width: 20rem;
      padding: 0;
      border: 0;
      background: transparent;
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
      font-size: 0.74rem;
      line-height: 1.35;
    }
    .hero__cta {
      width: min(100%, 20rem);
      flex-direction: column;
      gap: 0.55rem;
      margin-top: 0.25rem;
    }
    .hero__cta :global(.btn) {
      width: 100%;
      min-height: 50px;
      padding-inline: 1rem;
      white-space: normal;
      text-align: center;
    }
  }
  @media (max-width: 380px) {
    .hero__title {
      max-width: 12.5ch;
      font-size: 2.38rem;
    }
    .hero__subtitle {
      font-size: 0.96rem;
    }
  }
  /* Secondary CTA → light outline so it reads on the dark footage. */
  :global(.hero__ghost) {
    color: var(--on-ink) !important;
    border-color: color-mix(in srgb, var(--on-ink) 50%, transparent) !important;
  }
  :global(.hero__ghost:hover) {
    border-color: var(--on-ink) !important;
    background: color-mix(in srgb, var(--on-ink) 14%, transparent) !important;
  }
  @media (min-width: 920px) {
    .hero__layout {
      grid-template-columns: minmax(0, 1fr);
      max-width: 48rem;
    }
  }
  @media (max-width: 919.98px) {
    .hero__layout {
      justify-items: start;
    }
  }

  /* 2 — section head row with side CTA */
  .head-row {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .head-row__cta {
    flex: none;
  }
  .grid-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .daily-project {
    min-width: 0;
  }
  .daily-project:nth-child(n + 4) {
    display: none;
  }
  .daily-project.is-active {
    display: block;
  }
  .daily-project.is-inactive {
    display: none;
  }
  @media (min-width: 640px) {
    .grid-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .grid-cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* 3 — references */
  .refs {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    align-items: center;
    text-align: center;
  }

  /* 4 — services grid */
  .grid-services {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  @media (min-width: 768px) {
    .grid-services {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* 4.5 — services cta */
  .services-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding: 2rem clamp(1.25rem, 4vw, 2.5rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background: color-mix(in srgb, var(--amber) 4%, var(--paper));
    text-align: center;
  }

  .services-cta__text {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 3vw, 1.4rem);
    font-weight: 500;
    line-height: var(--leading-flat);
    color: var(--ink);
  }

  .seo-copy {
    display: grid;
    gap: 1rem;
    color: var(--ink-soft);
    line-height: var(--leading-body);
  }
  .seo-copy h2 {
    margin: 0;
    color: var(--ink);
  }
  .seo-copy p {
    margin: 0;
    max-width: 68ch;
  }
  @media (min-width: 640px) {
    .services-cta {
      flex-direction: row;
      text-align: left;
      gap: 2rem;
    }
  }

  /* 5 — why rast */
  .why__photo {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 7;
    object-fit: cover;
    border-radius: var(--radius-card);
    margin: 2.5rem 0 0;
    border: 1px solid color-mix(in srgb, #ffffff 12%, transparent);
  }
  :global(picture):has(.why__photo) {
    display: block;
  }
  .why {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .why__item {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-top: 1.4rem;
    border-top: 2px solid color-mix(in srgb, var(--amber) 70%, transparent);
  }
  .why__k {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 500;
    color: var(--on-ink);
    line-height: 1;
  }
  .why__t {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--on-ink);
  }
  .why__d {
    margin: 0;
    color: color-mix(in srgb, var(--on-ink) 72%, transparent);
    line-height: var(--leading-body);
  }
  @media (min-width: 768px) {
    .why {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
    }
  }

  /* 3.5 — stats bar */
  .stats {
    list-style: none;
    margin: 0;
    padding: 1.4rem clamp(1rem, 4vw, 2rem);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem 1.1rem;
    border-block: 1px solid var(--line);
  }
  .stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    text-align: center;
  }
  .stats__n {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    line-height: 1;
    color: var(--amber-text);
  }
  .stats__l {
    font-family: var(--font-utility);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .stats__d {
    max-width: 24ch;
    margin-top: 0.35rem;
    color: var(--ink-soft);
    font-size: 0.86rem;
    line-height: 1.45;
  }
  @media (min-width: 720px) {
    .stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* 5.5 — process steps */
  .steps {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.8rem;
    counter-reset: step;
  }
  .steps__item {
    position: relative;
    padding-top: 1.3rem;
    border-top: 2px solid color-mix(in srgb, var(--amber) 65%, transparent);
  }
  .steps__n {
    font-family: var(--font-utility);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--amber-text);
  }
  .steps__t {
    margin: 0.5rem 0 0.5rem;
    font-size: 1.25rem;
    font-weight: 600;
  }
  .steps__d {
    margin: 0;
    color: var(--ink-soft);
    line-height: var(--leading-body);
    max-width: 42ch;
  }
  @media (min-width: 768px) {
    .steps {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  /* 6 — faq */
  .faq {
    margin-top: 2.5rem;
    border-top: 1px solid var(--line);
  }

  /* 7 — final CTA band */
  .cta-band {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
  }
  .cta-band__title {
    margin: 0;
    max-width: 18ch;
    color: var(--on-ink);
  }
</style>

<script>
  const dailyProjectRoot = document.querySelector<HTMLElement>("[data-daily-projects]");
  if (dailyProjectRoot) {
    const cards = Array.from(dailyProjectRoot.querySelectorAll<HTMLElement>("[data-daily-project]"));
    const count = Math.min(Number(dailyProjectRoot.dataset.dailyCount ?? 3), cards.length);

    const istanbulDateKey = () => {
      const parts = new Intl.DateTimeFormat("en-CA", {
        timeZone: "Europe/Istanbul",
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
      }).formatToParts(new Date());
      const get = (type: string) => parts.find((part) => part.type === type)?.value ?? "";
      return `${get("year")}-${get("month")}-${get("day")}`;
    };

    const seedFromString = (value: string) => {
      let seed = 2166136261;
      for (let i = 0; i < value.length; i += 1) {
        seed ^= value.charCodeAt(i);
        seed = Math.imul(seed, 16777619);
      }
      return seed >>> 0;
    };

    const nextRandom = (seed: number) => {
      let state = seed || 1;
      return () => {
        state = Math.imul(state ^ (state >>> 15), 1 | state);
        state ^= state + Math.imul(state ^ (state >>> 7), 61 | state);
        return ((state ^ (state >>> 14)) >>> 0) / 4294967296;
      };
    };

    let currentDateKey = "";
    const applyDailyProjects = () => {
      const dateKey = istanbulDateKey();
      if (dateKey === currentDateKey) return;
      currentDateKey = dateKey;

      const random = nextRandom(seedFromString(dateKey));
      const indexes = cards.map((_, index) => index);
      for (let i = indexes.length - 1; i > 0; i -= 1) {
        const j = Math.floor(random() * (i + 1));
        [indexes[i], indexes[j]] = [indexes[j], indexes[i]];
      }

      const selected = new Set(indexes.slice(0, count));
      cards.forEach((card, index) => {
        const order = indexes.indexOf(index);
        const active = selected.has(index);
        card.classList.toggle("is-active", active);
        card.classList.toggle("is-inactive", !active);
        if (active) card.style.order = String(order);
      });
    };

    applyDailyProjects();
    window.setInterval(applyDailyProjects, 60_000);
  }
</script>
