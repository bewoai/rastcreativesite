---
import { getCollection, render } from "astro:content";
import { Picture } from "astro:assets";
import whyPhoto from "../assets/photos/hero-cinema.jpg";
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Eyebrow from "../components/Eyebrow.astro";
import Button from "../components/Button.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import AccordionItem from "../components/AccordionItem.astro";
import LogoWall from "../components/LogoWall.astro";
import VideoHero from "../components/VideoHero.astro";
import LiquidHeroAnimation from "../components/LiquidHeroAnimation.astro";
import HeroShowreel3D from "../components/HeroShowreel3D.astro";
import AreaIndex from "../components/AreaIndex.astro";
import BlogCard from "../components/BlogCard.astro";
import { COPY, PRIMARY_CTA, CONTACT } from "../consts";
import { localBusiness, organization, webSite, faqPage, toPlainText } from "../lib/schema";
import { groupByBrand } from "../lib/brands";
import { SEO_SERVICES } from "../data/seo-services";
import { AREA_INDEX_LOCATION_SLUGS, SEO_LOCATIONS } from "../data/locations";

const byOrder = (a: { data: { order: number } }, b: { data: { order: number } }) =>
  a.data.order - b.data.order;

const projects = (await getCollection("projects")).filter((p) => !p.data.draft);
const dailyProjectCount = 3;
const dailyProjects = [...projects].sort(byOrder);
const services = (await getCollection("services")).sort(byOrder);
const faqEntries = (await getCollection("faq")).sort(byOrder);
const faqRendered = await Promise.all(
  faqEntries.map(async (e) => ({ data: e.data, Content: (await render(e)).Content })),
);

// Latest blog posts for the homepage "Son yazılar" section.
const blogPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
const fmtBlogDate = (d: Date) =>
  d.toLocaleDateString("tr-TR", { day: "numeric", month: "long", year: "numeric" });

// Quick credibility numbers — derived from real content so they stay accurate.
const brandCount = groupByBrand(projects).length;
// Hero trust line — built from the same real counts as the stats bar below so
// the two never disagree (no hand-maintained numbers going stale).
const heroTrust = `${brandCount}+ marka · ${projects.length}+ içerik · Sakarya merkezli prodüksiyon ekibi`;
const stats = [
  {
    n: `${brandCount}+`,
    l: "Marka",
    d: "Sanayi, medikal, perakende ve hizmet sektörlerinde farklı markalarla üretim süreci yürüttük.",
  },
  {
    n: `${projects.length}`,
    l: "İçerik",
    d: "Tanıtım filmi, sosyal medya videosu, ürün videosu ve reklam formatlarında içerikler ürettik.",
  },
  {
    n: "4K",
    l: "Sinema Standardı",
    d: "Profesyonel kamera, ışık, ses ve renk düzenleme süreciyle yayına hazır çıktılar teslim ederiz.",
  },
  {
    n: "Sakarya",
    l: "Merkezli Stüdyo",
    d: "Sakarya, Kocaeli, Gebze ve çevresinde yerinde çekim süreçleri planlıyoruz.",
  },
];

// "Nasıl çalışırız" — process clarity the 35+ audience wants (roadmap §2.5).
const steps = [
  {
    n: "01",
    t: "Ücretsiz ön görüşme",
    d: "Projenizi dinler; formatı, kapsamı ve takvimi birlikte netleştiririz.",
  },
  {
    n: "02",
    t: "Çekim & prodüksiyon",
    d: "Sinema standardı ekipmanla sahadayız; ön hazırlıktan sete tek ekip disiplini.",
  },
  {
    n: "03",
    t: "Kurgu & teslim",
    d: "Post-prodüksiyon, renk ve son rötuş; genellikle 2–4 hafta içinde teslim.",
  },
];

// "Neden Rast" — concrete trust signals for the 35+ audience (roadmap §2.5).
const whyRast = [
  {
    k: "Yerinde çekim",
    t: "Sahaya yakın prodüksiyon",
    d: "Sakarya ve çevresinde keşif, planlama, prodüksiyon ve kurgu sürecini tek ekip olarak yürütürüz.",
  },
  {
    k: "Tek elden",
    t: "Dağılmayan üretim akışı",
    d: "Fikir, senaryo, çekim, kurgu, renk ve teslim süreci aynı masada ilerler; projenin muhatabı değişmez.",
  },
  {
    k: "Format uyumu",
    t: "Web, reklam ve sosyal medya",
    d: "Ana videonun yanında Reels, Shorts, YouTube ve reklam kullanımına uygun versiyonları baştan planlarız.",
  },
];

const prioritySeoServices = SEO_SERVICES.filter((s) =>
  ["video-cekimi", "drone-cekimi", "tanitim-filmi", "reklam-filmi", "sosyal-medya-icerigi"].includes(s.slug),
);
const prioritySeoLocations = SEO_LOCATIONS.filter((l) =>
  AREA_INDEX_LOCATION_SLUGS.includes(l.slug),
);

// Home-page structured data: enriched LocalBusiness + FAQPage (rich results).
const pageJsonLd = [
  organization,
  webSite,
  localBusiness,
  faqPage(
    faqEntries.map((e) => ({
      question: e.data.question,
      answer: toPlainText(e.body ?? ""),
    })),
  ),
];
---

<BaseLayout jsonLd={pageJsonLd} entryAnimation>
  {/* 1 — Hero (sinematik merkezi tablo; Monopo Saigon esinli) */}
  <VideoHero flush fadeBottom class="hero" height="min(100svh, 900px)">
    <LiquidHeroAnimation />
    <div class="hero__layout">
      <span class="hero__intro-glow" aria-hidden="true"></span>
      <p class="hero__introline" aria-hidden="true">Doğru kare, doğru hikaye.</p>
      <div class="hero__center">
        <p class="hero__eyebrow">SAKARYA · SİNEMATİK VİDEO PRODÜKSİYON</p>
        <h1 class="hero__title">Sakarya Video Çekimi<br class="hero__title-br" /> ve Prodüksiyon</h1>
        <p class="hero__tagline">
          Markanız için reklam filmi, tanıtım filmi ve sosyal medya videoları üretiyoruz.
          Sakarya merkezli prodüksiyon ekibimizle fikrinizi sinematik bir hikâyeye dönüştürüyoruz.
        </p>
        <div class="hero__cta">
          <Button href={PRIMARY_CTA.href} size="lg" arrow data-cta-location="hero">
            {PRIMARY_CTA.label}
          </Button>
          <Button href="/projeler" variant="secondary" size="lg" class="hero__ghost" data-cta-location="hero">
            Projelerimizi İzleyin
          </Button>
        </div>
        <p class="hero__meta">{heroTrust}</p>
      </div>
    </div>
    <div class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-line"></span>
      Keşfet
    </div>
  </VideoHero>

  <HeroShowreel3D />

  {/* 1.5 — Kurumsal kimlik / "ne yapar" — yanıt-öncelikli, AI motorları ve yeni ziyaretçiler için */}
  <Section width="narrow" space="tight">
    <div class="entity" data-reveal>
      <Eyebrow>Rast Creative Studio ne yapar?</Eyebrow>
      <p class="entity__lead">
        Rast Creative Studio, <strong>Serdivan/Sakarya merkezli bir video prodüksiyon ve
        kreatif içerik ajansıdır.</strong> Markalar için reklam filmi, tanıtım filmi, sosyal
        medya videosu, ürün ve drone çekimi üretir; çekim, kurgu ve renk düzenlemeyi tek
        elden yürütür.
      </p>
      <p class="entity__text">
        Serdivan'daki stüdyosundan Sakarya, Adapazarı, Erenler, Arifiye ve çevre ilçelerin
        yanı sıra Kocaeli, Gebze ve Düzce hattında yerinde çekim yapar. Fikirden teslime
        kadar süreç, projeyi planlayan kurucu ortakların kontrolünde ilerler.
      </p>
      <dl class="entity__facts">
        <div><dt>Merkez</dt><dd>Serdivan, Sakarya</dd></div>
        <div><dt>Hizmet bölgesi</dt><dd>Sakarya ve çevresi · Kocaeli · Gebze · Düzce</dd></div>
        <div>
          <dt>Ana hizmetler</dt>
          <dd>Reklam ve tanıtım filmi, sosyal medya videosu, ürün & drone çekimi, kurgu</dd>
        </div>
        <div>
          <dt>İletişim</dt>
          <dd>
            <a href={`tel:${CONTACT.phoneIntl}`}>{CONTACT.phone}</a> ·
            <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
          </dd>
        </div>
      </dl>
    </div>
  </Section>

  <style>
    .entity__lead {
      margin: 1rem 0 0;
      font-size: 1.15rem;
      line-height: var(--leading-body);
      color: var(--ink);
      max-width: 60ch;
    }
    .entity__text {
      margin: 0.9rem 0 0;
      color: var(--ink-soft);
      line-height: var(--leading-body);
      max-width: 62ch;
    }
    .entity__facts {
      margin: 1.6rem 0 0;
      border-top: 1px solid var(--line);
    }
    .entity__facts > div {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.15rem;
      padding: 0.85rem 0;
      border-bottom: 1px solid var(--line);
    }
    .entity__facts dt {
      font-family: var(--font-utility);
      font-size: 0.8rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--ink-soft);
    }
    .entity__facts dd {
      margin: 0;
      color: var(--ink);
    }
    .entity__facts a:hover {
      color: var(--amber-text);
    }
    @media (min-width: 640px) {
      .entity__facts > div {
        grid-template-columns: 12rem 1fr;
        gap: 1rem;
        align-items: baseline;
      }
    }
  </style>

  {/* 2 — Seçili işler */}
  <Section id="secili-isler">
    <div class="head-row">
      <SectionHeading eyebrow="Sahne 02 · Seçili İşler">Son işlerimizden seçmeler</SectionHeading>
      <Button href="/projeler" variant="secondary" arrow class="head-row__cta">Tümünü gör</Button>
    </div>
    <div class="grid-cards" data-reveal="frame-advance" data-daily-projects data-daily-count={dailyProjectCount}>
      {
        dailyProjects.map((p, index) => (
          <div class="daily-project" data-daily-project data-project-index={index}>
            <ProjectCard
              href={p.data.externalUrl ?? `/projeler/${p.id}`}
              title={p.data.title}
              category={p.data.category}
              poster={p.data.poster}
              posterAlt={p.data.posterAlt}
              client={p.data.client}
              year={p.data.year}
              timecode={p.data.duration}
              vertical={p.data.vertical}
              preview={p.data.preview}
              summary={p.data.summary}
              class="card--balanced"
            />
          </div>
        ))
      }
    </div>
  </Section>

  {/* 3 — Referans logoları */}
  <Section space="tight">
    <div class="refs">
      <Eyebrow tone="soft">Çalıştığımız markalardan bazıları</Eyebrow>
      <LogoWall />
    </div>
  </Section>

  {/* 3.5 — İstatistik barı */}
  <Section space="tight">
    <ul class="stats" data-reveal="odometer" aria-label="Rakamlarla Rast Creative">
      {
        stats.map((s) => (
          <li class="stats__item">
            <span class="stats__n">{s.n}</span>
            <span class="stats__l">{s.l}</span>
            <span class="stats__d">{s.d}</span>
          </li>
        ))
      }
    </ul>
  </Section>

  {/* 4 — Hizmetler özeti */}
  <Section id="hizmetler-ozet">
    <SectionHeading eyebrow="Sahne 03 · Hizmetler">
      Uçtan uca üç ana hizmet
      <Fragment slot="intro">
        <p>Fikirden teslime; strateji, prodüksiyon ve post-prodüksiyonu tek elden yürütürüz.</p>
      </Fragment>
    </SectionHeading>
    <div class="grid-services" data-reveal="frame-advance">
      {
        services.map((s, i) => (
          <ServiceCard
            href={`/hizmetler#${s.id}`}
            index={i + 1}
            title={s.data.title}
            summary={s.data.summary}
            features={s.data.features.slice(0, 3)}
          />
        ))
      }
    </div>
  </Section>

  {/* 4.25 — Bölgesel SEO hub */}
  <Section space="tight">
    <AreaIndex
      eyebrow="Sakarya ve çevresi"
      title="Sakarya ve Serdivan'da prodüksiyon hizmetleri"
      text="Sakarya merkezli markalar için video çekimi, drone, tanıtım filmi, reklam filmi ve sosyal medya içeriklerini bölgeye göre planlıyoruz. Çekim yapılacak ilçeyi seçerek ilgili hizmet detaylarına geçebilirsiniz."
      services={prioritySeoServices}
      locations={prioritySeoLocations}
    />
  </Section>

  <Section width="narrow" space="tight">
    <div class="seo-copy" data-reveal="focus-pull">
      <h2>Sakarya'da video çekimi nasıl planlanır?</h2>
      <p>
        Rast Creative Studio, Sakarya ve Serdivan merkezli işletmeler için video çekimi
        sürecini hedef, mecra ve teslim formatına göre planlar. Tanıtım filmi,
        sosyal medya videosu, ürün çekimi, etkinlik kaydı veya kurumsal prodüksiyon
        ihtiyacında önce mesajı netleştirir; ardından sahne akışı, kamera, ışık,
        ses, kurgu ve renk düzenleme adımlarını tek üretim planında toplarız.
      </p>
      <p>
        Çekim günü sadece güzel görüntü almak için değil, markanın kullanabileceği
        içerik havuzunu büyütmek için tasarlanır. Aynı prodüksiyondan web sitesi,
        Instagram Reels, YouTube, reklam kampanyası ve satış sunumu için farklı
        sürelerde yatay ve dikey videolar hazırlanabilir.
      </p>
      <p>
        Sakarya tanıtım filmi projelerinde Serdivan, Adapazarı, Arifiye ve çevre
        ilçelerde keşif, çekim izni, sahne akışı ve teslim takvimini baştan
        netleştiririz. Ürün çekimi ve kurgu aşamasında ise videonun yalnızca iyi
        görünmesine değil, satış ekibi, web sitesi ve sosyal medya içerik planı
        içinde gerçekten kullanılabilir olmasına odaklanırız.
      </p>
    </div>
  </Section>

  {/* 4.5 — Ara CTA */}
  <Section space="tight">
    <div class="services-cta" data-reveal>
      <p class="services-cta__text">Projeniz için doğru kareyi birlikte yakalayalım.</p>
      <Button href={PRIMARY_CTA.href} arrow data-cta-location="services_mid_page">{PRIMARY_CTA.label}</Button>
    </div>
  </Section>

  {/* 5 — Neden Rast */}
  <Section id="neden-rast" tone="ink">
    <SectionHeading eyebrow="Sahne 04 · Neden Rast" eyebrowTone="paper">Somut güven sinyalleri</SectionHeading>
    <Picture
      src={whyPhoto}
      formats={["avif", "webp"]}
      alt="Sakarya'da video prodüksiyon setinde çekim ekibi, monitör ve sinema ışığı"
      widths={[600, 900, 1200, 1600]}
      sizes="(min-width: 1100px) 1040px, 92vw"
      loading="lazy"
      class="why__photo"
      data-reveal="exposure-fade"
    />
    <ul class="why">
      {
        whyRast.map((w) => (
          <li class="why__item">
            <span class="why__k">{w.k}</span>
            <h3 class="why__t">{w.t}</h3>
            <p class="why__d">{w.d}</p>
          </li>
        ))
      }
    </ul>
  </Section>

  {/* 5.5 — Süreç */}
  <Section id="surec">
    <SectionHeading eyebrow="Sahne 05 · Süreç">
      Üç adımda, baştan sona
      <Fragment slot="intro">
        <p>Net bir akış: ön görüşmeden teslime kadar her aşamada yanınızdayız.</p>
      </Fragment>
    </SectionHeading>
    <ol class="steps" data-reveal="frame-advance">
      {
        steps.map((s) => (
          <li class="steps__item">
            <span class="steps__n">{s.n}</span>
            <h3 class="steps__t">{s.t}</h3>
            <p class="steps__d">{s.d}</p>
          </li>
        ))
      }
    </ol>
  </Section>

  {/* 6 — SSS */}
  <Section id="sss" width="narrow">
    <SectionHeading eyebrow="Sahne 06 · SSS">Sık sorulan sorular</SectionHeading>
    <div class="faq">
      {
        faqRendered.map((f, i) => {
          const Answer = f.Content;
          return (
            <AccordionItem question={f.data.question} open={i === 0}>
              <Answer />
            </AccordionItem>
          );
        })
      }
    </div>
  </Section>

  {/* 6.5 — Son yazılar (blog) */}
  {
    blogPosts.length > 0 && (
      <Section id="blog" space="tight">
        <div class="head-row">
          <SectionHeading eyebrow="Sahne 07 · Günlük">Son yazılar</SectionHeading>
          <Button href="/blog" variant="secondary" arrow class="head-row__cta">
            Tüm yazılar
          </Button>
        </div>
        <div class="grid-cards" data-reveal="frame-advance">
          {blogPosts.map((p) => (
            <BlogCard
              href={`/blog/${p.id}`}
              title={p.data.title}
              description={p.data.description}
              date={fmtBlogDate(p.data.pubDate)}
              datetime={p.data.pubDate.toISOString()}
              cover={p.data.cover}
              coverAlt={p.data.coverAlt}
            />
          ))}
        </div>
      </Section>
    )
  }

  {/* 7 — Son CTA bandı */}
  <Section tone="ink" space="tight">
    <div class="cta-band">
      <Eyebrow tone="paper">Hazır mısınız?</Eyebrow>
      <h2 class="cta-band__title">Markanızın sinematik yüzünü birlikte çekelim.</h2>
      <Button href={PRIMARY_CTA.href} size="lg" arrow data-cta-location="final_band">{PRIMARY_CTA.label}</Button>
    </div>
  </Section>
</BaseLayout>

<style>
  /* 1 — Hero (sinematik merkezi tablo; Monopo Saigon esinli) */
  :global(.hero) {
    background: #050403 !important;
  }
  :global(.hero .vhero__scrim) {
    display: block !important;
    background:
      radial-gradient(70% 54% at 50% 48%, rgba(0, 0, 0, 0.08), rgba(0, 0, 0, 0.50) 70%),
      linear-gradient(180deg, rgba(0, 0, 0, 0.18), rgba(0, 0, 0, 0.78)) !important;
  }
  .hero__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    place-items: center;
    min-height: inherit;
  }
  /* ---- Intro statement (first phase) ---- */
  .hero__intro-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate3d(-50%, -50%, 0) scale(0.7);
    width: min(44rem, 95vw);
    aspect-ratio: 1;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(226, 83, 3, 0.45) 0%, rgba(255, 176, 92, 0.14) 38%, transparent 70%);
    filter: blur(50px);
    opacity: 0;
    z-index: 3;
    pointer-events: none;
    animation: hero-intro-glow 2.55s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero__introline {
    position: absolute;
    inset-inline: 50% auto;
    top: 50%;
    width: min(88vw, 48rem);
    margin: 0;
    color: var(--on-ink);
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 7.5vw, 5.2rem);
    font-weight: 480;
    line-height: 1.05;
    letter-spacing: -0.025em;
    text-align: center;
    text-wrap: balance;
    opacity: 0;
    filter: blur(8px);
    transform: translate3d(-50%, -50%, 0) scale(0.94);
    animation: hero-intro-statement 2.55s cubic-bezier(0.16, 1, 0.3, 1) both;
    pointer-events: none;
    z-index: 5;
    text-shadow: 0 0 40px rgba(255, 176, 92, 0.15);
  }
  /* ---- Centered hero block (second phase) ---- */
  .hero__center {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.8rem;
    width: 100%;
    max-width: 58rem;
    padding-inline: var(--container-pad);
    position: relative;
    z-index: 2;
    opacity: 0;
    filter: blur(12px);
    transform: translate3d(0, 24px, 0);
    animation: hero-reveal 1.5s var(--ease-out) 1.65s both;
  }
  .hero__eyebrow {
    margin: 0;
    color: color-mix(in srgb, var(--on-ink) 50%, transparent);
    font-family: var(--font-utility);
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }
  /* Monumental display matching the site's default serif style (Fraunces weight 480). */
  .hero__title {
    margin: 0;
    color: var(--on-ink);
    font-family: var(--font-display);
    font-weight: 480;
    font-size: clamp(2.5rem, 8vw, 6.2rem);
    line-height: 1.02;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }
  .hero__title-br {
    display: block;
  }
  .hero__tagline {
    margin: 0;
    max-width: 54rem;
    color: color-mix(in srgb, var(--on-ink) 68%, transparent);
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    font-weight: 400;
    line-height: 1.65;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
    margin-top: 0.2rem;
  }
  /* Tiny trust meta-line beneath CTAs. */
  .hero__meta {
    margin: 0;
    margin-top: -0.4rem;
    color: color-mix(in srgb, var(--on-ink) 54%, transparent);
    font-family: var(--font-utility);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  @keyframes hero-intro-glow {
    0% {
      opacity: 0;
      transform: translate3d(-50%, -50%, 0) scale(0.7);
      filter: blur(60px);
    }
    30%,
    58% {
      opacity: 0.95;
      transform: translate3d(-50%, -50%, 0) scale(1.15);
      filter: blur(40px);
    }
    100% {
      opacity: 0;
      transform: translate3d(-50%, -50%, 0) scale(1.55);
      filter: blur(70px);
    }
  }
  @keyframes hero-intro-statement {
    0% {
      opacity: 0;
      filter: blur(12px);
      transform: translate3d(-50%, -50%, 0) scale(0.94);
    }
