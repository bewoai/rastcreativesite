---
import { getCollection, render } from "astro:content";
import { Picture } from "astro:assets";
import heroPhoto from "../assets/photos/camera-closeup.jpg";
import whyPhoto from "../assets/photos/hero-cinema.jpg";
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Eyebrow from "../components/Eyebrow.astro";
import Button from "../components/Button.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import AccordionItem from "../components/AccordionItem.astro";
import LogoWall from "../components/LogoWall.astro";
import { COPY, PRIMARY_CTA } from "../consts";
import { localBusiness, faqPage, toPlainText } from "../lib/schema";
import { groupByBrand } from "../lib/brands";

const byOrder = (a: { data: { order: number } }, b: { data: { order: number } }) =>
  a.data.order - b.data.order;

const projects = (await getCollection("projects")).filter((p) => !p.data.draft);
const featured = projects.filter((p) => p.data.featured).sort(byOrder).slice(0, 4);
const services = (await getCollection("services")).sort(byOrder);
const faqEntries = (await getCollection("faq")).sort(byOrder);
const faqRendered = await Promise.all(
  faqEntries.map(async (e) => ({ data: e.data, Content: (await render(e)).Content })),
);

// Quick credibility numbers — derived from real content so they stay accurate.
const brandCount = groupByBrand(projects).length;
const stats = [
  { n: `${brandCount}+`, l: "Marka" },
  { n: `${projects.length}`, l: "İçerik" },
  { n: "4K", l: "Sinema Standardı" },
  { n: "Sakarya", l: "Merkezli Stüdyo" },
];

// "Nasıl çalışırız" — process clarity the 35+ audience wants (roadmap §2.5).
const steps = [
  {
    n: "01",
    t: "Ücretsiz ön görüşme",
    d: "Projenizi dinler; formatı, kapsamı ve takvimi birlikte netleştiririz.",
  },
  {
    n: "02",
    t: "Çekim & prodüksiyon",
    d: "Sinema standardı ekipmanla sahadayız; ön hazırlıktan sete tek ekip disiplini.",
  },
  {
    n: "03",
    t: "Kurgu & teslim",
    d: "Post-prodüksiyon, renk ve son rötuş; genellikle 2–4 hafta içinde teslim.",
  },
];

// "Neden Rast" — concrete trust signals for the 35+ audience (roadmap §2.5).
const whyRast = [
  {
    k: "Yerinde",
    t: "Sakarya'da yerinde hizmet",
    d: "Ön görüşmeden çekime kadar sahadayız; uzaktan koordinasyon derdi olmadan, yüz yüze çalışırız.",
  },
  {
    k: "Ekipman",
    t: "Sinema standardı ekipman",
    d: "Profesyonel sinema kamera ve optik parkıyla, reklamdan medikale her projede sinematik kalite.",
  },
  {
    k: "2–4 hafta",
    t: "Net teslim süresi",
    d: "Projeler kapsamına göre genellikle 2–4 hafta içinde teslim edilir; takvimi baştan netleştiririz.",
  },
];

// Home-page structured data: enriched LocalBusiness + FAQPage (rich results).
const pageJsonLd = [
  localBusiness,
  faqPage(
    faqEntries.map((e) => ({
      question: e.data.question,
      answer: toPlainText(e.body ?? ""),
    })),
  ),
];
---

<BaseLayout jsonLd={pageJsonLd}>
  {/* 1 — Hero */}
  <section class="hero">
    <div class="hero__inner">
      <div class="hero__text">
        <Eyebrow>Sakarya · Sinematik Video Prodüksiyon</Eyebrow>
        <h1 class="hero__title">{COPY.heroTitle}</h1>
        <p class="hero__subtitle">{COPY.heroSubtitle}</p>
        <div class="hero__cta">
          <Button href={PRIMARY_CTA.href} size="lg" arrow>{PRIMARY_CTA.label}</Button>
          <Button href="/projeler" variant="secondary" size="lg">
            {COPY.heroSecondaryCta}
          </Button>
        </div>
      </div>
      <div class="hero__visual">
        <Picture
          src={heroPhoto}
          formats={["avif", "webp"]}
          alt="Sakarya'da sinematik video prodüksiyon: profesyonel sinema kamerası ve timecode'lu monitör"
          widths={[420, 640, 900]}
          sizes="(min-width: 860px) 45vw, 92vw"
          loading="eager"
          fetchpriority="high"
          class="hero__img"
        />
      </div>
    </div>
  </section>

  {/* 2 — Seçili işler */}
  <Section id="secili-isler">
    <div class="head-row">
      <SectionHeading eyebrow="Sahne 02 · Seçili İşler">Son işlerimizden seçmeler</SectionHeading>
      <Button href="/projeler" variant="secondary" arrow class="head-row__cta">Tümünü gör</Button>
    </div>
    <div class="grid-cards">
      {
        featured.map((p) => (
          <ProjectCard
            href={`/projeler/${p.id}`}
            title={p.data.title}
            category={p.data.category}
            poster={p.data.poster}
            posterAlt={p.data.posterAlt}
            client={p.data.client}
            year={p.data.year}
            timecode={p.data.duration}
            vertical={p.data.vertical}
          />
        ))
      }
    </div>
  </Section>

  {/* 3 — Referans logoları */}
  <Section space="tight">
    <div class="refs">
      <Eyebrow tone="soft">Çalıştığımız markalardan bazıları</Eyebrow>
      <LogoWall />
    </div>
  </Section>

  {/* 3.5 — İstatistik barı */}
  <Section space="tight">
    <ul class="stats">
      {
        stats.map((s) => (
          <li class="stats__item">
            <span class="stats__n">{s.n}</span>
            <span class="stats__l">{s.l}</span>
          </li>
        ))
      }
    </ul>
  </Section>

  {/* 4 — Hizmetler özeti */}
  <Section id="hizmetler-ozet">
    <SectionHeading eyebrow="Sahne 03 · Hizmetler">
      Uçtan uca üç ana hizmet
      <Fragment slot="intro">
        <p>Fikirden teslime; strateji, prodüksiyon ve post-prodüksiyonu tek elden yürütürüz.</p>
      </Fragment>
    </SectionHeading>
    <div class="grid-services">
      {
        services.map((s, i) => (
          <ServiceCard
            href={`/hizmetler#${s.id}`}
            index={i + 1}
            title={s.data.title}
            summary={s.data.summary}
            features={s.data.features.slice(0, 3)}
          />
        ))
      }
    </div>
  </Section>

  {/* 5 — Neden Rast */}
  <Section id="neden-rast" tone="ink">
    <SectionHeading eyebrow="Sahne 04 · Neden Rast" eyebrowTone="paper">Somut güven sinyalleri</SectionHeading>
    <Picture
      src={whyPhoto}
      formats={["avif", "webp"]}
      alt="Sakarya'da video prodüksiyon setinde çekim ekibi, monitör ve sinema ışığı"
      widths={[600, 900, 1200, 1600]}
      sizes="(min-width: 1100px) 1040px, 92vw"
      loading="lazy"
      class="why__photo"
    />
    <ul class="why">
      {
        whyRast.map((w) => (
          <li class="why__item">
            <span class="why__k">{w.k}</span>
            <h3 class="why__t">{w.t}</h3>
            <p class="why__d">{w.d}</p>
          </li>
        ))
      }
    </ul>
  </Section>

  {/* 5.5 — Süreç */}
  <Section id="surec">
    <SectionHeading eyebrow="Sahne 05 · Süreç">
      Üç adımda, baştan sona
      <Fragment slot="intro">
        <p>Net bir akış: ön görüşmeden teslime kadar her aşamada yanınızdayız.</p>
      </Fragment>
    </SectionHeading>
    <ol class="steps">
      {
        steps.map((s) => (
          <li class="steps__item">
            <span class="steps__n">{s.n}</span>
            <h3 class="steps__t">{s.t}</h3>
            <p class="steps__d">{s.d}</p>
          </li>
        ))
      }
    </ol>
  </Section>

  {/* 6 — SSS */}
  <Section id="sss" width="narrow">
    <SectionHeading eyebrow="Sahne 06 · SSS">Sık sorulan sorular</SectionHeading>
    <div class="faq">
      {
        faqRendered.map((f, i) => {
          const Answer = f.Content;
          return (
            <AccordionItem question={f.data.question} open={i === 0}>
              <Answer />
            </AccordionItem>
          );
        })
      }
    </div>
  </Section>

  {/* 7 — Son CTA bandı */}
  <Section tone="ink" space="tight">
    <div class="cta-band">
      <Eyebrow tone="paper">Hazır mısınız?</Eyebrow>
      <h2 class="cta-band__title">Markanızın sinematik yüzünü birlikte çekelim.</h2>
      <Button href={PRIMARY_CTA.href} size="lg" arrow>{PRIMARY_CTA.label}</Button>
    </div>
  </Section>
</BaseLayout>

<style>
  /* 1 — Hero */
  .hero {
    padding-block: clamp(1rem, 4vw, 2.5rem) var(--section-gap);
  }
  .hero__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .hero__text {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }
  .hero__title {
    margin: 0;
    max-width: 16ch;
  }
  .hero__subtitle {
    margin: 0;
    max-width: 46ch;
    font-size: 1.2rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 0.5rem;
  }
  .hero__visual {
    position: relative;
    justify-self: center;
    width: 100%;
    max-width: 30rem;
  }
  .hero__visual :global(picture) {
    display: block;
  }
  .hero__img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius-card);
    border: 1px solid var(--glass-border);
    box-shadow:
      0 8px 32px -8px color-mix(in srgb, var(--ink) 12%, transparent),
      0 0 0 0.5px color-mix(in srgb, #ffffff 15%, transparent) inset;
  }
  @media (min-width: 860px) {
    .hero__inner {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }

  /* 2 — section head row with side CTA */
  .head-row {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .head-row__cta {
    flex: none;
  }
  .grid-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .grid-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .grid-cards {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* 3 — references */
  .refs {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    align-items: center;
    text-align: center;
  }

  /* 4 — services grid */
  .grid-services {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  @media (min-width: 768px) {
    .grid-services {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* 5 — why rast */
  .why__photo {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 7;
    object-fit: cover;
    border-radius: var(--radius-card);
    margin: 2.5rem 0 0;
    border: 1px solid color-mix(in srgb, #ffffff 12%, transparent);
  }
  :global(picture):has(.why__photo) {
    display: block;
  }
  .why {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .why__item {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-top: 1.4rem;
    border-top: 2px solid color-mix(in srgb, var(--amber) 70%, transparent);
  }
  .why__k {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 500;
    color: var(--paper);
    line-height: 1;
  }
  .why__t {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--paper);
  }
  .why__d {
    margin: 0;
    color: color-mix(in srgb, var(--paper) 72%, transparent);
    line-height: var(--leading-body);
  }
  @media (min-width: 768px) {
    .why {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
    }
  }

  /* 3.5 — stats bar */
  .stats {
    list-style: none;
    margin: 0;
    padding: 1.4rem clamp(1rem, 4vw, 2rem);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.4rem 1rem;
    border-block: 1px solid var(--line);
  }
  .stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    text-align: center;
  }
  .stats__n {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    line-height: 1;
    color: var(--amber-text);
  }
  .stats__l {
    font-family: var(--font-utility);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  @media (min-width: 720px) {
    .stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* 5.5 — process steps */
  .steps {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.8rem;
    counter-reset: step;
  }
  .steps__item {
    position: relative;
    padding-top: 1.3rem;
    border-top: 2px solid color-mix(in srgb, var(--amber) 65%, transparent);
  }
  .steps__n {
    font-family: var(--font-utility);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--amber-text);
  }
  .steps__t {
    margin: 0.5rem 0 0.5rem;
    font-size: 1.25rem;
    font-weight: 600;
  }
  .steps__d {
    margin: 0;
    color: var(--ink-soft);
    line-height: var(--leading-body);
    max-width: 42ch;
  }
  @media (min-width: 768px) {
    .steps {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  /* 6 — faq */
  .faq {
    margin-top: 2.5rem;
    border-top: 1px solid var(--line);
  }

  /* 7 — final CTA band */
  .cta-band {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
  }
  .cta-band__title {
    margin: 0;
    max-width: 18ch;
    color: var(--paper);
  }
</style>
