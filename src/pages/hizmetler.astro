---
import { getCollection, render } from "astro:content";
import { Picture } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Eyebrow from "../components/Eyebrow.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import AreaIndex from "../components/AreaIndex.astro";
import { PRIMARY_CTA } from "../consts";
import { breadcrumb, BUSINESS_ID } from "../lib/schema";
import bannerPhoto from "../assets/photos/director-clapper.jpg";
import { SEO_SERVICES } from "../data/seo-services";
import { AREA_INDEX_LOCATION_SLUGS, SEO_LOCATIONS } from "../data/locations";

const services = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(
  services.map(async (s) => ({ id: s.id, data: s.data, Content: (await render(s)).Content })),
);

// Representative icon per service (falls back to a generic mark).
const SERVICE_ICON: Record<string, "video" | "strategy" | "edit"> = {
  "video-produksiyon": "video",
  "kreatif-strateji": "strategy",
  "post-produksiyon": "edit",
};

const seoServiceGroups = SEO_SERVICES.filter((service) =>
  ["video-cekimi", "drone-cekimi", "tanitim-filmi", "reklam-filmi", "sosyal-medya-icerigi"].includes(service.slug),
);
const seoCoreLocations = SEO_LOCATIONS.filter((location) =>
  AREA_INDEX_LOCATION_SLUGS.includes(location.slug),
);

const deliveryPlan = [
  {
    t: "Çekim öncesi net plan",
    d: "Amaç, hedef kitle, mecra, çekim akışı ve teslim formatları görüşme aşamasında belirlenir.",
  },
  {
    t: "Mecra bazlı teslim",
    d: "Web sitesi, Instagram, YouTube, reklam ve sunum kullanımı için farklı oran ve sürelerde çıktı hazırlanabilir.",
  },
  {
    t: "Revizyon ve yayın hazırlığı",
    d: "Kurgu, renk, ses, altyazı, kapak ve reklam varyasyonları kontrollü revizyon akışıyla tamamlanır.",
  },
];

const useCases = [
  "Kurumsal tanıtım filmi",
  "Dikey Reels / Shorts içerikleri",
  "Ürün ve mekan çekimi",
  "Meta reklam videosu",
  "Fuar ve satış sunumu",
  "Podcast ve uzman içerikleri",
];

// Breadcrumb + a Service node per offering (local SEO).
const pageJsonLd = [
  breadcrumb([
    { name: "Ana Sayfa", path: "/" },
    { name: "Hizmetler", path: "/hizmetler" },
  ]),
  ...services.map((s) => ({
    "@context": "https://schema.org",
    "@type": "Service",
    name: s.data.title,
    description: s.data.summary,
    serviceType: s.data.title,
    areaServed: { "@type": "City", name: "Sakarya" },
    provider: { "@id": BUSINESS_ID },
  })),
];
---

<BaseLayout
  title="Hizmetler"
  description="Sakarya video prodüksiyon hizmetleri: reklam ve tanıtım filmi, kreatif strateji, post-prodüksiyon ve kurgu — Rast Creative Studio."
  jsonLd={pageJsonLd}
>
  <Section>
    <SectionHeading eyebrow="Sahne 01 · Hizmetler" as="h1">
      Uçtan uca üç ana hizmet
      <Fragment slot="intro">
        <p>
          Fikirden teslime kadar tek elden: stratejiyi kurar, sinematik
          standartta çeker, post-prodüksiyonda son rötuşu yaparız.
        </p>
      </Fragment>
    </SectionHeading>

    <Picture
      src={bannerPhoto}
      formats={["avif", "webp"]}
      alt="Klaketle sahne başlatan ekip ve sinema kamerasıyla Sakarya'da video prodüksiyon çekimi"
      widths={[600, 900, 1200, 1600]}
      sizes="(min-width: 1100px) 1040px, 92vw"
      loading="eager"
      fetchpriority="high"
      class="svc-banner"
    />

    <ul class="services">
      {
        rendered.map((s, i) => (
          <li id={s.id} class="svc">
            <div class="svc__aside">
              <span class="svc__icon">
                <Icon name={SERVICE_ICON[s.id] ?? "play"} size={26} />
              </span>
              <span class="svc__num">{String(i + 1).padStart(2, "0")}</span>
            </div>
            <div class="svc__main">
              <h2 class="svc__title">{s.data.title}</h2>
              <div class="svc__prose">
                <s.Content />
              </div>
              {s.data.features.length > 0 && (
                <ul class="svc__features">
                  {s.data.features.map((f) => (
                    <li>
                      <Icon name="arrow-right" size={16} class="svc__ic" />
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>
              )}
              <a href="/iletisim" class="svc__cta">
                Bu hizmet için teklif al
                <Icon name="arrow-right" size={16} />
              </a>
            </div>
          </li>
        ))
      }
    </ul>
  </Section>

  <Section space="tight">
    <div class="service-proof">
      <div class="service-proof__head" data-reveal>
        <Eyebrow>Planlı Teslim</Eyebrow>
        <h2>Hizmeti sadece çekim günüyle sınırlı görmüyoruz.</h2>
        <p>
          Her hizmette önce içeriğin nerede kullanılacağını netleştiriyoruz. Böylece çekim,
          kurgu ve teslim kararları tek bir ana videoya değil, markanın gerçek kullanım
          alanlarına göre planlanıyor.
        </p>
      </div>
      <ul class="service-proof__grid" aria-label="Hizmet teslim güvence adımları">
        {
          deliveryPlan.map((item) => (
            <li data-reveal>
              <h3>{item.t}</h3>
              <p>{item.d}</p>
            </li>
          ))
        }
      </ul>
      <div class="use-cases" data-reveal>
        <h3>Örnek kullanım alanları</h3>
        <ul>
          {useCases.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </Section>

  <Section space="tight">
    <AreaIndex
      title="Sakarya ve çevresinde üretim"
      text="Serdivan merkezli ekiple Sakarya ve yakın illerde çekime çıkıyoruz. İlçenize ve ihtiyacınıza göre drone, tanıtım filmi, reklam filmi ve sosyal medya içerik sayfalarına buradan ulaşabilirsiniz."
      services={seoServiceGroups}
      locations={seoCoreLocations}
    />
  </Section>

  <Section tone="ink" space="tight">
    <div class="cta">
      <Eyebrow tone="paper">Projeniz mi var?</Eyebrow>
      <h2 class="cta__title">Hangi hizmete ihtiyacınız olduğundan emin değil misiniz?</h2>
      <p class="cta__text">Ücretsiz ön görüşmede birlikte netleştirelim.</p>
      <Button href={PRIMARY_CTA.href} size="lg" arrow>{PRIMARY_CTA.label}</Button>
    </div>
  </Section>

</BaseLayout>

<style>
  .svc-banner {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 7;
    object-fit: cover;
    border-radius: var(--radius-card);
    border: 1px solid var(--line);
    margin: 2.5rem 0 0;
  }
  :global(picture):has(.svc-banner) {
    display: block;
  }
  .services {
    list-style: none;
    margin: 3rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .svc {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding-block: clamp(2rem, 4vw, 3rem);
    border-top: 1px solid var(--line);
    scroll-margin-top: 7rem; /* clear the fixed nav on anchor jump */
  }
  .svc:last-child {
    border-bottom: 1px solid var(--line);
  }
  .svc__aside {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .svc__icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    flex: none;
    border-radius: var(--radius-card);
    color: var(--amber-text);
    background: color-mix(in srgb, var(--amber) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--amber) 25%, transparent);
  }
  .svc__num {
    font-family: var(--font-utility);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--amber-text);
  }
  @media (min-width: 820px) {
    .svc__aside {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.7rem;
    }
  }
  .svc__title {
    margin: 0 0 1rem;
  }
  .svc__prose {
    font-size: 1.1rem;
    line-height: var(--leading-body);
    color: var(--ink-soft);
    max-width: 60ch;
  }
  .svc__prose :global(p) {
    margin: 0;
  }
  .svc__features {
    list-style: none;
    margin: 1.4rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.6rem;
  }
  .svc__features li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.98rem;
  }
  .svc__ic {
    margin-top: 0.2rem;
    flex: none;
    color: var(--amber-text);
  }
  .svc__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.4rem;
    align-self: flex-start;
    min-height: var(--tap-min);
    padding: 0.55rem 1.1rem;
    border: 1px solid color-mix(in srgb, var(--amber) 40%, var(--line));
    border-radius: var(--radius-pill);
    font-family: var(--font-utility);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--amber-text);
    transition:
      background-color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }
  .svc__cta:hover {
    background: color-mix(in srgb, var(--amber) 10%, transparent);
    border-color: var(--amber);
    transform: translateY(-1px);
  }
  .svc__cta:focus {
    outline: none;
  }
  .svc__cta:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 2px;
  }
  .service-proof {
    display: grid;
    gap: 1.5rem;
  }
  .service-proof__head {
    display: grid;
    gap: 0.7rem;
    max-width: 46rem;
  }
  .service-proof__head h2 {
    margin: 0;
    max-width: 18ch;
  }
  .service-proof__head p {
    margin: 0;
    color: var(--ink-soft);
    line-height: var(--leading-body);
  }
  .service-proof__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .service-proof__grid li,
  .use-cases {
    padding: 1.1rem 0 0;
    border-top: 1px solid var(--line);
  }
  .service-proof__grid h3,
  .use-cases h3 {
    margin: 0;
    font-size: 1.05rem;
  }
  .service-proof__grid p {
    margin: 0.55rem 0 0;
    color: var(--ink-soft);
    line-height: 1.58;
  }
  .use-cases ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
  }
  .use-cases li {
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    color: var(--ink-soft);
    font-family: var(--font-utility);
    font-size: 0.82rem;
  }
  .cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }
  .cta__title {
    margin: 0;
    max-width: 24ch;
    color: var(--on-ink);
  }
  .cta__text {
    margin: 0;
    color: color-mix(in srgb, var(--on-ink) 75%, transparent);
  }
  @media (min-width: 820px) {
    .svc {
      grid-template-columns: 6rem 1fr;
      gap: 2rem;
    }
    .service-proof {
      grid-template-columns: minmax(18rem, 0.75fr) minmax(0, 1.25fr);
      align-items: start;
      gap: clamp(2rem, 5vw, 4rem);
    }
    .service-proof__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.35rem;
    }
    .use-cases {
      grid-column: 2;
    }
  }
</style>
