---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ProjectGallery from "../../components/ProjectGallery.astro";

const projects = (await getCollection("projects"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Projeler"
  description="Rast Creative Studio portfolyosu: reklam, marka hikâyesi, ürün, kurumsal ve medikal video prodüksiyon projeleri."
>
  <Section>
    <SectionHeading eyebrow="Sahne 01 · Portfolyo">
      Projeler
      <Fragment slot="intro">
        <p>
          Reklamdan medikale, hikâyeyi merkeze alan sinematik işlerimiz.
          Kategoriye göre filtreleyin.
        </p>
      </Fragment>
    </SectionHeading>
    <ProjectGallery projects={projects} activeSlug="" />
  </Section>
</BaseLayout>
