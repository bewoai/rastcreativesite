---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import BrandFolder from "../../components/BrandFolder.astro";
import ProjectsNote from "../../components/ProjectsNote.astro";
import VideoHero from "../../components/VideoHero.astro";
import Eyebrow from "../../components/Eyebrow.astro";
import projHeroPoster from "../../assets/photos/director-clapper.jpg";
import { breadcrumb } from "../../lib/schema";
import { groupByBrand, brandHref } from "../../lib/brands";
import { PROJECT_CATEGORIES } from "../../consts";

const projects = (await getCollection("projects"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

const brands = groupByBrand(projects);

// Only categories that actually have brands, in canonical order.
const sections = PROJECT_CATEGORIES.map((c) => ({
  ...c,
  brands: brands.filter((b) => b.category === c.label),
})).filter((s) => s.brands.length > 0);

const crumbs = breadcrumb([
  { name: "Ana Sayfa", path: "/" },
  { name: "Projeler", path: "/projeler" },
]);
---

<BaseLayout
  title="Projeler"
  description="Rast Creative Studio portfolyosu: Sakarya'da kurumsal, ürün, medikal ve sosyal medya video prodüksiyon işleri — markalara göre düzenli."
  jsonLd={crumbs}
>
  <VideoHero poster={projHeroPoster.src} height="min(48vh, 440px)" scrim={66} flush class="proj-hero">
    <div class="proj-hero__text">
      <Eyebrow tone="paper">Sahne 01 · Portfolyo</Eyebrow>
      <h1 class="proj-hero__title">Projeler</h1>
      <p class="proj-hero__intro">
        Markalar için ürettiğimiz işler — kategori ve markaya göre düzenli.
      </p>
    </div>
  </VideoHero>

  <Section>
    {/* Quick jump to a category section */}
    <nav class="catnav" aria-label="Kategoriler">
      {
        sections.map((s) => (
          <a href={`#${s.slug}`} class="catnav__chip">
            {s.label}
          </a>
        ))
      }
    </nav>

    {
      sections.map((s) => (
        <section id={s.slug} class="catsec">
          <h2 class="catsec__title">{s.label}</h2>
          <div class="folder-grid">
            {s.brands.map((b) => (
              <BrandFolder
                href={brandHref(b)}
                name={b.name}
                category={b.category}
                cover={b.cover}
                count={b.count}
                vertical={b.vertical}
              />
            ))}
          </div>
        </section>
      ))
    }

    <ProjectsNote />
  </Section>
</BaseLayout>

<style>
  .proj-hero__text {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    max-width: 40rem;
  }
  .proj-hero__title {
    margin: 0;
    color: var(--paper);
  }
  .proj-hero__intro {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.5;
    color: color-mix(in srgb, var(--paper) 82%, transparent);
    max-width: 48ch;
  }
  .catnav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 0.5rem;
  }
  .catnav__chip {
    display: inline-flex;
    align-items: center;
    min-height: var(--tap-min);
    padding: 0 1rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--line);
    font-family: var(--font-utility);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--ink);
    touch-action: manipulation;
    transition:
      background-color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
  }
  .catnav__chip:hover {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--paper);
  }

  .catsec {
    margin-top: 2.5rem;
    scroll-margin-top: 6rem;
  }
  .catsec__title {
    margin: 0 0 1.2rem;
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--line);
  }

  .folder-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    align-items: start;
  }
  @media (min-width: 640px) {
    .folder-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .folder-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
    }
  }
</style>
