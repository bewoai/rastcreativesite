---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import BlogCard from "../../components/BlogCard.astro";
import { breadcrumb } from "../../lib/schema";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString("tr-TR", { day: "numeric", month: "long", year: "numeric" });

const crumbs = breadcrumb([
  { name: "Ana Sayfa", path: "/" },
  { name: "Blog", path: "/blog" },
]);
---

<BaseLayout
  title="Blog"
  description="Sakarya'da video prodüksiyon üzerine notlar: tanıtım filmi süreci, maliyeti, sosyal medya ve drone çekimi — Rast Creative Studio."
  jsonLd={crumbs}
>
  <Section width="narrow">
    <SectionHeading eyebrow="Günlük" as="h1">
      Blog
      <Fragment slot="intro">
        <p>Set'ten, kurgudan ve markalarla çalışmaktan öğrendiklerimiz.</p>
      </Fragment>
    </SectionHeading>

    {
      posts.length === 0 ? (
        <p class="empty">Yakında ilk yazımız burada olacak.</p>
      ) : (
        <div class="post-grid">
          {posts.map((p) => (
            <BlogCard
              href={`/blog/${p.id}`}
              title={p.data.title}
              description={p.data.description}
              date={fmt(p.data.pubDate)}
              datetime={p.data.pubDate.toISOString()}
              cover={p.data.cover}
              coverAlt={p.data.coverAlt}
              titleTag="h2"
            />
          ))}
        </div>
      )
    }
  </Section>
</BaseLayout>

<style>
  .post-grid {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .post-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .empty {
    margin-top: 2.5rem;
    color: var(--ink-soft);
    font-style: italic;
  }
</style>
