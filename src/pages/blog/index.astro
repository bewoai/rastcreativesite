---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { breadcrumb } from "../../lib/schema";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString("tr-TR", { day: "numeric", month: "long", year: "numeric" });

const crumbs = breadcrumb([
  { name: "Ana Sayfa", path: "/" },
  { name: "Blog", path: "/blog" },
]);
---

<BaseLayout
  title="Blog"
  description="Sakarya'da video prodüksiyon üzerine notlar: tanıtım filmi süreci, maliyeti ve sette öğrendiklerimiz — Rast Creative Studio."
  jsonLd={crumbs}
>
  <Section width="narrow">
    <SectionHeading eyebrow="Günlük">
      Blog
      <Fragment slot="intro">
        <p>Set'ten, kurgudan ve markalarla çalışmaktan öğrendiklerimiz.</p>
      </Fragment>
    </SectionHeading>

    {
      posts.length === 0 ? (
        <p class="empty">Yakında ilk yazımız burada olacak.</p>
      ) : (
        <ul class="posts">
          {posts.map((p) => (
            <li>
              <a href={`/blog/${p.id}`} class="post">
                <time class="post__date" datetime={p.data.pubDate.toISOString()}>
                  {fmt(p.data.pubDate)}
                </time>
                <h2 class="post__title">{p.data.title}</h2>
                <p class="post__desc">{p.data.description}</p>
                <span class="post__more">Oku →</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </Section>
</BaseLayout>

<style>
  .posts {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }
  .post {
    display: block;
    padding: 1.5rem clamp(1.25rem, 4vw, 1.8rem);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-card);
    background: var(--glass-bg);
    transition:
      transform var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .post:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--amber) 40%, var(--glass-border));
    box-shadow:
      var(--bloom-amber),
      0 12px 32px -10px color-mix(in srgb, var(--ink) 12%, transparent);
  }
  .post:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 3px;
  }
  .post__date {
    font-family: var(--font-utility);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
  }
  .post__title {
    margin: 0.5rem 0 0.5rem;
    font-size: clamp(1.25rem, 3vw, 1.55rem);
    line-height: 1.25;
    color: var(--ink);
  }
  .post__desc {
    margin: 0;
    color: var(--ink-soft);
    line-height: var(--leading-body);
    max-width: 62ch;
  }
  .post__more {
    display: inline-block;
    margin-top: 0.9rem;
    font-family: var(--font-utility);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--amber-text);
  }
  .empty {
    margin-top: 2.5rem;
    color: var(--ink-soft);
    font-style: italic;
  }
</style>
