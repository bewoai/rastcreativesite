---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Eyebrow from "../components/Eyebrow.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import { PRIMARY_CTA, SITE } from "../consts";
import { BUSINESS_ID, breadcrumb } from "../lib/schema";
import { groupByBrand } from "../lib/brands";
import equipPhoto from "../assets/photos/studio-lighting.jpg";
import muhammedPhoto from "../assets/photos/muhammed-al-sheikhly.png";
import beratPhoto from "../assets/photos/berat-degirmenci.png";

const crumbs = breadcrumb([
  { name: "Ana Sayfa", path: "/" },
  { name: "Hakkımızda", path: "/hakkimizda" },
]);

const pageTitle = "Hakkımızda | Sakarya Video Prodüksiyon Ekibi";
const pageDescription =
  "Rast Creative Studio, Sakarya merkezli video prodüksiyon ekibi. Tanıtım filmi, sosyal medya videosu, podcast prodüksiyonu, kurgu ve dijital reklam süreçlerini birlikte planlarız.";

const projects = (await getCollection("projects")).filter((p) => !p.data.draft);
const brandCount = groupByBrand(projects).length;

const approach = [
  {
    t: "Önce işi anlarız",
    d: "Çekime geçmeden önce markanın derdini, kullanılacak mecrayı ve izleyicinin neyi görmesi gerektiğini netleştiririz.",
  },
  {
    t: "Sahada sade kalırız",
    d: "Set günü karmaşayı azaltır, çekim akışını önceden planlar ve kararları görüntünün ihtiyacına göre veririz.",
  },
  {
    t: "Teslimi kullanıma hazır yaparız",
    d: "Videoyu sadece güzel görünsün diye değil; web, sosyal medya, reklam ve sunum kullanımlarına hazır olacak şekilde teslim ederiz.",
  },
];

const workflow = [
  {
    n: "01",
    t: "İhtiyacı netleştiririz",
    d: "Projenin amacı, hedef kitlesi, yayınlanacağı mecra ve teslim formatları ilk görüşmede belirlenir.",
  },
  {
    n: "02",
    t: "Çekimi planlarız",
    d: "Mekan, ekipman, çekim akışı ve zaman çizelgesi önceden hazırlanır; sürprizleri sahaya bırakmayız.",
  },
  {
    n: "03",
    t: "Kurgu ve teslimi yönetiriz",
    d: "Renk, ses, altyazı ve reklam varyasyonları dahil gerekli çıktıları düzenli revizyon akışıyla teslim ederiz.",
  },
];

const trustPoints = [
  "Projeyi doğrudan şirketin kurucu ortaklarıyla konuşursunuz.",
  "Sakarya ve çevresinde yerinde çekim için hızlı saha organizasyonu kurarız.",
  "Kısa sosyal medya içeriğinden kurumsal tanıtım filmine kadar aynı prodüksiyon disiplinini koruruz.",
  "Teslim sonrası kullanım ihtiyacını da düşünür; reklam, web ve sosyal medya formatlarını baştan planlarız.",
];

const whyUs = [
  {
    t: "Kurucu ortaklarla doğrudan süreç",
    d: "Projenizi satıştan üretime devreden kalabalık bir zincir yerine, işi planlayan kurucu ortaklarla konuşursunuz.",
  },
  {
    t: "Yeni medya ve yapay zeka takibi",
    d: "Video üretimini sadece kamera ve kurgu olarak görmeyiz; yeni araçları, dikey formatları ve reklam ihtiyaçlarını sürece dahil ederiz.",
  },
  {
    t: "Teslim sonrası kullanımı düşünürüz",
    d: "Videonun web, sosyal medya, reklam ve sunum tarafında nasıl kullanılacağını daha çekimden önce planlarız.",
  },
];

const projectProof = [
  {
    k: "Süreç",
    t: "Başlamadan önce kapsam netleşir.",
    d: "Amaç, hedef kitle, çekim günü, sahne akışı ve revizyon noktaları ilk plan içinde yazılı hale gelir.",
  },
  {
    k: "Teslim",
    t: "Video tek dosya olarak kalmaz.",
    d: "İhtiyaca göre yatay ana film, dikey Reels/Shorts, kısa reklam varyasyonu, kapak ve altyazı dosyaları planlanır.",
  },
  {
    k: "Kullanım",
    t: "İçerik nerede yaşayacaksa ona göre üretilir.",
    d: "Web sitesi, Instagram, YouTube, Meta reklamları, satış sunumu veya fuar ekranı için ayrı kullanım senaryosu düşünülür.",
  },
];

const teamMembers = [
  {
    name: "Muhammed Al Sheikhly",
    role: "Kurucu Ortak / Video Director",
    photo: muhammedPhoto,
    linkedin: "https://www.linkedin.com/in/muhammed-al-sheikhly-2a6b01209/",
    focus: "Animasyon, storyboard ve görsel anlatı tarafında projeye katkı sağlar.",
    bio:
      "Dumlupınar Üniversitesi Güzel Sanatlar ve Stüdyo Sanatları eğitimiyle güçlü bir görsel anlatı temeline sahip. Adatıp Hastanesi'nde yaratıcı videografi ve kısa video üretim süreçlerine katkı sağlıyor; animasyon, After Effects, storyboard ve kurgu bilgisini hikaye odaklı video üretimine taşıyor.",
    highlights: ["Video yönetmenliği", "Animasyon", "After Effects", "Storyboard", "Kurgu"],
  },
  {
    name: "Berat Değirmenci",
    role: "Kurucu Ortak / Video Director",
    photo: beratPhoto,
    linkedin: "https://www.linkedin.com/in/beratdegirmenci/",
    focus: "Teknik süreçler, dijital reklam planlama ve prodüksiyon akışını düzenli tutar.",
    bio:
      "Adatıp Hastanesi'nde video operasyonları ve podcast prodüksiyonları üzerine çalışıyor. Yönetim Bilişim Sistemleri eğitimiyle süreç planlama, teknik altyapı ve dijital reklam tarafındaki bilgisini prodüksiyon akışlarına dahil ediyor; markalar için daha düzenli, ölçülebilir ve etkili görsel içerikler üretmeye odaklanıyor.",
    highlights: ["Video operasyonları", "Podcast prodüksiyonu", "Meta reklamları", "Teknik süreçler", "Kurgu"],
  },
];

const teamStats = [
  { value: "2", label: "Kurucu ortak" },
  { value: `${brandCount}+`, label: "Marka deneyimi" },
  { value: `${projects.length}`, label: "Yayında proje ve içerik" },
];

const pageJsonLd = [
  crumbs,
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "@id": `${SITE.url}/hakkimizda#webpage`,
    url: `${SITE.url}/hakkimizda`,
    name: pageTitle,
    description: pageDescription,
    inLanguage: SITE.lang,
    isPartOf: { "@id": `${SITE.url}#website` },
    about: { "@id": BUSINESS_ID },
    primaryImageOfPage: {
      "@type": "ImageObject",
      url: `${SITE.url}/og-default.png`,
    },
    mainEntity: {
      "@type": "Organization",
      "@id": `${SITE.url}#organization`,
      name: SITE.name,
      url: SITE.url,
      areaServed: "Sakarya",
      knowsAbout: [
        "Sakarya video prodüksiyon",
        "tanıtım filmi",
        "sosyal medya videosu",
        "podcast prodüksiyonu",
        "post prodüksiyon",
        "Meta reklamları",
      ],
      member: teamMembers.map((member) => ({
        "@type": "Person",
        name: member.name,
        jobTitle: member.role,
        url: member.linkedin,
        worksFor: { "@id": `${SITE.url}#organization` },
        knowsAbout: member.highlights,
      })),
    },
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  jsonLd={pageJsonLd}
>
  {/* Sahne 01 · Kurucu Ekip */}
  <Section width="wide" class="about-hero">
    <div class="team-hero">
      <div class="team-hero__intro" data-reveal>
        <Eyebrow>Şirketin Kurucuları</Eyebrow>
        <h1 class="team-hero__title">Rast Creative’in kurucu ortakları.</h1>
        <p class="team-hero__text">
          Rast Creative Studio, Muhammed Al Sheikhly ve Berat Değirmenci tarafından yönetilen
          genç bir video prodüksiyon ajansıdır. Her projede markanın ne anlatmak istediğini,
          videonun nerede kullanılacağını ve teslimden sonra nasıl sonuç üretmesi gerektiğini
          baştan planlarız.
        </p>
        <p class="team-hero__text team-hero__text--small">
          Tanıtım filmi, sosyal medya videosu, podcast prodüksiyonu, kurgu ve dijital reklam dili
          doğrudan kurucu ortakların kontrolünde ilerler. Bu yüzden proje boyunca muhatabınız
          değişmez; fikir, çekim ve teslim aynı masada netleşir.
        </p>
        <div class="hero-actions" aria-label="Hakkımızda hızlı bağlantılar">
          <Button href={PRIMARY_CTA.href} arrow>{PRIMARY_CTA.label}</Button>
          <Button href="/projeler" variant="secondary" arrow>İşleri İncele</Button>
        </div>
        <ul class="team-stats" aria-label="Rast Creative ekip özeti">
          {
            teamStats.map((stat) => (
              <li data-reveal>
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="team-grid" aria-label="Kurucu ekip üyeleri">
        {
          teamMembers.map((member) => (
            <article class="member-card" data-reveal>
              <div class="member-card__photo-container">
                <Picture
                  src={member.photo}
                  formats={["avif", "webp"]}
                  alt={`${member.name}, ${member.role}`}
                  widths={[320, 520, 720]}
                  sizes="(min-width: 768px) 380px, 92vw"
                  loading="lazy"
                  class="member-card__photo"
                />
              </div>
              <div class="member-card__body">
                <div>
                  <p class="member-card__role">{member.role}</p>
                  <h3 class="member-card__name">{member.name}</h3>
                  <p class="member-card__focus">{member.focus}</p>
                  <p class="member-card__bio">{member.bio}</p>
                </div>
                <div>
                  <ul class="member-card__tags" aria-label={`${member.name} çalışma alanları`}>
                    {member.highlights.map((highlight) => (
                      <li>{highlight}</li>
                    ))}
                  </ul>
                  {
                    member.linkedin && (
                      <a class="member-card__link" href={member.linkedin} target="_blank" rel="noreferrer" aria-label={`${member.name} LinkedIn profili`}>
                        <Icon name="linkedin" size={16} />
                        <span>Bağlantı Kur</span>
                      </a>
                    )
                  }
                </div>
              </div>
            </article>
          ))
        }
      </div>

    </div>
  </Section>

  {/* Sahne 02 · Vizyon ve Misyon */}
  <Section space="tight">
    <div class="vision-mission" aria-label="Rast Creative vizyon ve misyon">
      <article class="vision-mission__item" data-reveal>
        <Eyebrow>Vizyonumuz</Eyebrow>
        <h2>Yeni üretim çağını yakından takip eden genç ajans.</h2>
        <p>
          Yapay zeka destekli araçları, yeni medya formatlarını ve dijital reklam dinamiklerini
          yaratıcı sürecin parçası haline getirerek markalara güncel, hızlı ve güçlü bir görsel
          üretim alanı açmak.
        </p>
      </article>
      <article class="vision-mission__item" data-reveal>
        <Eyebrow>Misyonumuz</Eyebrow>
        <h2>Net, etkili ve kullanıma hazır içerikler üretmek.</h2>
        <p>
          Her projede markanın hikayesini doğru formatta planlıyor; video, kurgu, sosyal medya ve
          dijital reklam çıktılarının sahada gerçekten kullanılabilir olmasına odaklanıyoruz.
          Süreci sade, dili güçlü, teslimi uygulanabilir tutuyoruz.
        </p>
      </article>
    </div>
  </Section>

  {/* Sahne 03 · Neden Biz */}
  <Section space="tight">
    <div class="why">
      <div class="why__head" data-reveal>
        <Eyebrow>Neden Rast Creative?</Eyebrow>
        <h2>Genç, güncel ve doğrudan ulaşılabilir bir prodüksiyon partneri.</h2>
      </div>
      <ul class="why__grid" aria-label="Rast Creative tercih sebepleri">
        {
          whyUs.map((item) => (
            <li class="why__item" data-reveal>
              <h3>{item.t}</h3>
              <p>{item.d}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </Section>

  {/* Sahne 04 · Proje Güvencesi */}
  <Section space="tight">
    <div class="proof">
      <div class="proof__head" data-reveal>
        <Eyebrow>Proje Güvencesi</Eyebrow>
        <h2>Güven veren şey büyük cümleler değil, net teslim planıdır.</h2>
        <p>
          Her işi sadece “çekim yapalım” diye ele almayız. Projenin başlamadan önce
          nasıl ilerleyeceğini, sonunda hangi dosyaların çıkacağını ve bu içeriklerin
          nerede kullanılacağını birlikte netleştiririz.
        </p>
      </div>
      <ul class="proof__grid" aria-label="Rast Creative proje güvence maddeleri">
        {
          projectProof.map((item) => (
            <li class="proof__item" data-reveal>
              <span>{item.k}</span>
              <h3>{item.t}</h3>
              <p>{item.d}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </Section>

  {/* Sahne 05 · Çalışma Şeklimiz */}
  <Section space="tight" class="workflow-section">
    <div class="workflow-head" data-reveal>
      <Eyebrow>Çalışma Şeklimiz</Eyebrow>
      <h2>İyi bir video, set gününden önce netleşir.</h2>
      <p>
        Sürecin başında neyi, kimin için ve hangi formatta üreteceğimizi netleştiririz;
        böylece çekim günü daha sakin, teslim süreci daha öngörülebilir ilerler.
      </p>
    </div>
    <ol class="workflow" aria-label="Rast Creative çalışma süreci">
      {
        workflow.map((step) => (
          <li class="workflow__item" data-reveal>
            <span class="workflow__n">{step.n}</span>
            <h3>{step.t}</h3>
            <p>{step.d}</p>
          </li>
        ))
      }
    </ol>
  </Section>

  {/* Sahne 06 · Yaklaşımımız */}
  <Section tone="ink" space="tight">
    <Eyebrow tone="paper">Yaklaşımımız</Eyebrow>
    <ul class="approach">
      {
        approach.map((a) => (
          <li class="approach__item" data-reveal>
            <h2 class="approach__t">{a.t}</h2>
            <p class="approach__d">{a.d}</p>
          </li>
        ))
      }
    </ul>
  </Section>

  {/* Sahne 07 · Güven Sinyalleri */}
  <Section space="tight">
    <div class="trust">
      <div data-reveal>
        <Eyebrow>Nasıl Fark Yaratıyoruz?</Eyebrow>
        <h2 class="trust__title">Küçük ekip, net sorumluluk, temiz teslim.</h2>
      </div>
      <ul class="trust__list" aria-label="Rast Creative güven veren çalışma prensipleri">
        {trustPoints.map((point) => <li data-reveal>{point}</li>)}
      </ul>
    </div>
  </Section>

  {/* Sahne 08 · Ekipman */}
  <Section width="narrow">
    <div class="equip" data-reveal>
      <Eyebrow>Ekipman</Eyebrow>
      <h2 class="equip__title">Sinema Standardı Ekipman</h2>
      <p class="equip__text">
        Görüntü kalitesinden ödün vermiyoruz; ama ekipmanı gösteriş için değil,
        hikayeyi daha temiz anlatmak için kullanıyoruz. Reklamdan medikale her projede
        kamera, ışık, ses ve kurgu kararlarını markanın ihtiyacına göre kuruyoruz.
      </p>
      <Picture
        src={equipPhoto}
        formats={["avif", "webp"]}
        alt="Sinema standardı aydınlatma ve yönetmen monitörüyle profesyonel video prodüksiyon seti"
        widths={[600, 900, 1200]}
        sizes="(min-width: 768px) 680px, 92vw"
        loading="lazy"
        class="about-photo"
      />
    </div>
  </Section>

  {/* Sahne 09 · Tanışalım */}
  <Section tone="ink" space="tight">
    <div class="cta" data-reveal>
      <Eyebrow tone="paper">Tanışalım</Eyebrow>
      <h2 class="cta__title">Projenin neye dönüşeceğini birlikte netleştirelim.</h2>
      <p class="cta__text">
        İlk görüşmede kapsamı, çekim ihtiyacını ve teslim formatlarını konuşur;
        size uygulanabilir bir prodüksiyon planı çıkarırız.
      </p>
      <Button href={PRIMARY_CTA.href} size="lg" arrow>{PRIMARY_CTA.label}</Button>
    </div>
  </Section>
</BaseLayout>

<style>
  .approach {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .approach__item {
    padding-top: 1.3rem;
    border-top: 2px solid color-mix(in srgb, var(--amber) 70%, transparent);
  }
  .approach__t {
    margin: 0 0 0.5rem;
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--on-ink);
  }
  .approach__d {
    margin: 0;
    color: color-mix(in srgb, var(--on-ink) 75%, transparent);
    line-height: var(--leading-body);
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.35rem;
  }
  .vision-mission {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
  }
  .vision-mission__item {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    padding-top: 1.35rem;
    border-top: 1px solid var(--line);
  }
  .vision-mission__item h2 {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(1.55rem, 4vw, 2.35rem);
    line-height: 1.02;
  }
  .vision-mission__item p {
    margin: 0;
    color: var(--ink-soft);
    line-height: var(--leading-body);
  }
  .workflow-head {
    display: grid;
    gap: 0.75rem;
    max-width: 44rem;
  }
  .proof {
    display: grid;
    gap: 1.5rem;
  }
  .proof__head {
    display: grid;
    gap: 0.7rem;
    max-width: 46rem;
  }
  .proof__head h2 {
    margin: 0;
    max-width: 17ch;
  }
  .proof__head p {
    margin: 0;
    color: var(--ink-soft);
    line-height: var(--leading-body);
  }
  .proof__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .proof__item {
    padding: 1rem 0 0;
    border-top: 1px solid var(--line);
  }
  .proof__item span {
    display: inline-flex;
    margin-bottom: 0.7rem;
    color: var(--amber-text);
    font-family: var(--font-utility);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .proof__item h3 {
    margin: 0;
    font-size: 1.08rem;
  }
  .proof__item p {
    margin: 0.6rem 0 0;
    color: var(--ink-soft);
    line-height: 1.58;
  }
  .why {
    display: grid;
    gap: 1.7rem;
  }
  .why__head {
    display: grid;
    gap: 0.7rem;
    max-width: 48rem;
  }
  .why__head h2 {
    margin: 0;
    max-width: 18ch;
  }
  .why__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .why__item {
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }
  .why__item h3 {
    margin: 0;
    font-size: 1.05rem;
  }
  .why__item p {
    margin: 0.55rem 0 0;
    color: var(--ink-soft);
    line-height: 1.55;
  }
  .workflow-head h2,
  .trust__title {
    margin: 0;
  }
  .workflow-head p {
    margin: 0;
    color: var(--ink-soft);
    line-height: var(--leading-body);
  }
  .workflow {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    counter-reset: workflow;
  }
  .workflow__item {
    display: grid;
    gap: 0.55rem;
    padding: 1.1rem 0;
    border-top: 1px solid var(--line);
    position: relative;
  }
  .workflow__item::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--amber);
    transition: width 0.7s var(--ease-out);
  }
  .workflow__item:hover::before {
    width: 100%;
  }
  .workflow__n {
    color: var(--amber-text);
    font-family: var(--font-utility);
    font-size: 0.78rem;
    font-weight: 700;
  }
  .workflow__item h3 {
    margin: 0;
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 700;
  }
  .workflow__item p {
    margin: 0;
    color: var(--ink-soft);
    line-height: 1.6;
  }
  .trust {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .trust__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .trust__list li {
    padding: 1rem 0;
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    line-height: 1.55;
  }
  .trust__list li::before {
    content: "";
    display: inline-block;
    width: 0.55rem;
    height: 0.55rem;
    margin-right: 0.65rem;
    border-radius: 999px;
    background: var(--amber);
