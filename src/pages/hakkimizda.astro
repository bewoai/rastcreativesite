---
import { Picture } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Eyebrow from "../components/Eyebrow.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import { PRIMARY_CTA, SITE } from "../consts";
import { BUSINESS_ID, breadcrumb } from "../lib/schema";
import equipPhoto from "../assets/photos/studio-lighting.jpg";
import muhammedPhoto from "../assets/photos/muhammed-al-sheikhly.png";
import beratPhoto from "../assets/photos/berat-degirmenci.png";

const crumbs = breadcrumb([
  { name: "Ana Sayfa", path: "/" },
  { name: "Hakkımızda", path: "/hakkimizda" },
]);

const pageTitle = "Hakkımızda | Sakarya Video Prodüksiyon Ekibi";
const pageDescription =
  "Rast Creative Studio, Sakarya merkezli video prodüksiyon ekibi. Tanıtım filmi, sosyal medya videosu, podcast prodüksiyonu, kurgu ve dijital reklam süreçlerini birlikte planlarız.";

const approach = [
  {
    t: "Doğru kare",
    d: "İsabetli ve gösterişsiz. Her karede markanın özünü yakalamayı hedefleriz — gürültü değil, netlik.",
  },
  {
    t: "Yerinde, Sakarya'da",
    d: "Çekim ekibiyle sahadayız; ön görüşmeden teslime kadar süreci yüz yüze yönetiriz.",
  },
  {
    t: "Sinema standardı",
    d: "Profesyonel sinema kamera ve optik parkıyla, her bütçede sinematik bir görüntü dili kurarız.",
  },
];

const teamMembers = [
  {
    name: "Muhammed Al Sheikhly",
    role: "Kurucu Ortak / Video Director",
    photo: muhammedPhoto,
    linkedin: "https://www.linkedin.com/in/muhammed-al-sheikhly-2a6b01209/",
    focus: "Animasyon, storyboard ve görsel anlatı tarafında projeye katkı sağlar.",
    bio:
      "Dumlupınar Üniversitesi Güzel Sanatlar ve Stüdyo Sanatları eğitimiyle güçlü bir görsel anlatı temeline sahip. Adatıp Hastanesi'nde yaratıcı videografi ve kısa video üretim süreçlerine katkı sağlıyor; animasyon, After Effects, storyboard ve kurgu bilgisini hikaye odaklı video üretimine taşıyor.",
    highlights: ["Video yönetmenliği", "Animasyon", "After Effects", "Storyboard", "Kurgu"],
  },
  {
    name: "Berat Değirmenci",
    role: "Kurucu Ortak / Video Director",
    photo: beratPhoto,
    linkedin: "https://www.linkedin.com/in/beratdegirmenci/",
    focus: "Teknik süreçler, dijital reklam planlama ve prodüksiyon akışını düzenli tutar.",
    bio:
      "Adatıp Hastanesi'nde video operasyonları ve podcast prodüksiyonları üzerine çalışıyor. Yönetim Bilişim Sistemleri eğitimiyle süreç planlama, teknik altyapı ve dijital reklam tarafındaki bilgisini prodüksiyon akışlarına dahil ediyor; markalar için daha düzenli, ölçülebilir ve etkili görsel içerikler üretmeye odaklanıyor.",
    highlights: ["Video operasyonları", "Podcast prodüksiyonu", "Meta reklamları", "Teknik süreçler", "Kurgu"],
  },
];

const teamStats = [
  { value: "2", label: "Kurucu ortak" },
  { value: "Sakarya", label: "Merkezli saha ekibi" },
  { value: "Prodüksiyon + Reklam", label: "Tek planlama masası" },
];

const pageJsonLd = [
  crumbs,
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "@id": `${SITE.url}/hakkimizda#webpage`,
    url: `${SITE.url}/hakkimizda`,
    name: pageTitle,
    description: pageDescription,
    inLanguage: SITE.lang,
    isPartOf: { "@id": `${SITE.url}#website` },
    about: { "@id": BUSINESS_ID },
    primaryImageOfPage: {
      "@type": "ImageObject",
      url: `${SITE.url}/og-default.png`,
    },
    mainEntity: {
      "@type": "Organization",
      "@id": `${SITE.url}#organization`,
      name: SITE.name,
      url: SITE.url,
      areaServed: "Sakarya",
      knowsAbout: [
        "Sakarya video prodüksiyon",
        "tanıtım filmi",
        "sosyal medya videosu",
        "podcast prodüksiyonu",
        "post prodüksiyon",
        "Meta reklamları",
      ],
      member: teamMembers.map((member) => ({
        "@type": "Person",
        name: member.name,
        jobTitle: member.role,
        url: member.linkedin,
        worksFor: { "@id": `${SITE.url}#organization` },
        knowsAbout: member.highlights,
      })),
    },
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  jsonLd={pageJsonLd}
>
  {/* Sahne 01 · Kurucu Ekip */}
  <Section width="wide" class="about-hero">
    <div class="team-hero">
      <div class="team-hero__intro">
        <Eyebrow>Kurucu Ekip</Eyebrow>
        <h1 class="team-hero__title">Sakarya'da video prodüksiyon ekibi.</h1>
        <p class="team-hero__text">
          Rast Creative Studio'da tanıtım filmi, sosyal medya videosu, podcast prodüksiyonu, kurgu,
          reklam dili ve teslim süreci doğrudan kurucu ekip tarafından planlanır. Sakarya merkezli
          kompakt bir prodüksiyon yapısıyla çalışır; projeyi sahada takip eder, süreci açık ve düzenli tutarız.
        </p>
        <ul class="team-stats" aria-label="Rast Creative ekip özeti">
          {
            teamStats.map((stat) => (
              <li>
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="team-grid" aria-label="Kurucu ekip üyeleri">
        {
          teamMembers.map((member) => (
            <article class="member-card">
              <div class="member-card__photo-container">
                <Picture
                  src={member.photo}
                  formats={["avif", "webp"]}
                  alt={`${member.name}, ${member.role}`}
                  widths={[320, 520, 720]}
                  sizes="(min-width: 768px) 380px, 92vw"
                  loading="lazy"
                  class="member-card__photo"
                />
              </div>
              <div class="member-card__body">
                <div>
                  <p class="member-card__role">{member.role}</p>
                  <h3 class="member-card__name">{member.name}</h3>
                  <p class="member-card__focus">{member.focus}</p>
                  <p class="member-card__bio">{member.bio}</p>
                </div>
                <div>
                  <ul class="member-card__tags" aria-label={`${member.name} çalışma alanları`}>
                    {member.highlights.map((highlight) => (
                      <li>{highlight}</li>
                    ))}
                  </ul>
                  {
                    member.linkedin && (
                      <a class="member-card__link" href={member.linkedin} target="_blank" rel="noreferrer" aria-label={`${member.name} LinkedIn profili`}>
                        <Icon name="linkedin" size={16} />
                        <span>Bağlantı Kur</span>
                      </a>
                    )
                  }
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <div class="team-cta" aria-label="Ekip ile proje görüşmesi">
        <p>Projenizi doğrudan üretimi planlayan ekiple konuşabilirsiniz.</p>
        <Button href={PRIMARY_CTA.href} variant="secondary" arrow>{PRIMARY_CTA.label}</Button>
      </div>
    </div>
  </Section>

  {/* Sahne 03 · Yaklaşımımız */}
  <Section tone="ink" space="tight">
    <Eyebrow tone="paper">Yaklaşımımız</Eyebrow>
    <ul class="approach">
      {
        approach.map((a) => (
          <li class="approach__item">
            <h2 class="approach__t">{a.t}</h2>
            <p class="approach__d">{a.d}</p>
          </li>
        ))
      }
    </ul>
  </Section>

  {/* Sahne 04 · Ekipman */}
  <Section width="narrow">
    <div class="equip">
      <Eyebrow>Ekipman</Eyebrow>
      <h2 class="equip__title">Sinema Standardı Ekipman</h2>
      <p class="equip__text">
        Görüntü kalitesinden ödün vermiyoruz. Reklamdan medikale her projede,
        sinema dünyasının standartlarında profesyonel kamera gövdeleri ve optiklerle
        çekim yapıyor; renk ve detayı en üst standartta tutuyoruz.
      </p>
      <Picture
        src={equipPhoto}
        formats={["avif", "webp"]}
        alt="Sinema standardı aydınlatma ve yönetmen monitörüyle profesyonel video prodüksiyon seti"
        widths={[600, 900, 1200]}
        sizes="(min-width: 768px) 680px, 92vw"
        loading="lazy"
        class="about-photo"
      />
    </div>
  </Section>

  {/* Sahne 05 · Tanışalım */}
  <Section tone="ink" space="tight">
    <div class="cta">
      <Eyebrow tone="paper">Tanışalım</Eyebrow>
      <h2 class="cta__title">Sakarya'da bir kahve, bir ön görüşme.</h2>
      <Button href={PRIMARY_CTA.href} size="lg" arrow>{PRIMARY_CTA.label}</Button>
    </div>
  </Section>
</BaseLayout>

<style>
  .approach {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .approach__item {
    padding-top: 1.3rem;
    border-top: 2px solid color-mix(in srgb, var(--amber) 70%, transparent);
  }
  .approach__t {
    margin: 0 0 0.5rem;
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--on-ink);
  }
  .approach__d {
    margin: 0;
    color: color-mix(in srgb, var(--on-ink) 75%, transparent);
    line-height: var(--leading-body);
  }
  .team-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .team-hero__intro {
    max-width: 44rem;
  }
  .team-hero__title {
    margin: 0.85rem 0 0;
    max-width: 12ch;
    font-size: clamp(2.45rem, 7vw, 5rem);
    line-height: 0.96;
  }
  .team-hero__text {
    margin: 1.2rem 0 0;
    max-width: 58ch;
    color: var(--ink-soft);
    font-size: clamp(1.02rem, 1.4vw, 1.16rem);
    line-height: var(--leading-body);
  }
  .team-stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    list-style: none;
    margin: 1.8rem 0 0;
    padding: 0;
  }
  .team-stats li {
    display: grid;
    align-content: start;
    gap: 0.25rem;
    min-width: 0;
    padding: 0.85rem 0;
    border-top: 1px solid var(--line);
  }
  .team-stats strong {
    color: var(--ink);
    font-family: var(--font-utility);
    font-size: 0.95rem;
    line-height: 1.15;
    overflow-wrap: anywhere;
  }
  .team-stats span {
    color: var(--ink-soft);
    font-size: 0.92rem;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }
  .equip__title {
    margin: 0.6rem 0 0.8rem;
  }
  .equip__text {
    margin: 0;
    font-size: 1.1rem;
    color: var(--ink-soft);
    line-height: var(--leading-body);
    max-width: 60ch;
  }
  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .team-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.9rem;
    margin-top: 0;
    padding: 1.6rem 0 0;
    border-top: 1px solid var(--line);
  }
  .team-cta p {
    margin: 0;
    max-width: 34rem;
    color: var(--ink-soft);
    font-size: 0.98rem;
    line-height: 1.5;
  }
  .member-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background: color-mix(in srgb, var(--paper) 94%, white);
    box-shadow: 0 18px 54px -42px rgba(0, 0, 0, 0.28);
    position: relative;
    transition:
      border-color var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .member-card::before {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--amber);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur) var(--ease-out);
  }
  .member-card:hover {
    border-color: color-mix(in srgb, var(--amber) 34%, var(--line));
    box-shadow: 0 24px 62px -42px rgba(0, 0, 0, 0.38);
  }
  .member-card:hover::before {
    transform: scaleX(1);
  }
  .member-card__photo-container {
    width: 100%;
    aspect-ratio: 5 / 4;
    overflow: hidden;
    position: relative;
    background: var(--line);
  }
  .member-card__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .member-card__body {
    padding: clamp(1.15rem, 2vw, 1.55rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex-grow: 1;
    gap: 1.5rem;
  }
  .member-card__role {
    margin: 0 0 0.5rem;
    color: var(--amber);
    font-family: var(--font-utility);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .member-card__name {
    margin: 0;
    font-size: clamp(1.45rem, 3vw, 1.9rem);
    font-weight: 700;
    line-height: var(--leading-flat);
    color: var(--ink);
  }
  .member-card__focus {
    margin: 0.8rem 0 0;
    color: var(--ink);
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.45;
  }
  .member-card__bio {
    margin: 0.8rem 0 0;
    color: var(--ink-soft);
    line-height: 1.6;
    font-size: 0.93rem;
  }
  .member-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 0 0 0.25rem 0;
    padding: 0;
  }
  .member-card__tags li {
    padding: 0.35rem 0.65rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--ink-soft);
    font-family: var(--font-utility);
    font-size: 0.75rem;
    background: color-mix(in srgb, var(--paper) 40%, transparent);
    transition: all var(--dur-fast) var(--ease-out);
  }
  .member-card:hover .member-card__tags li {
    border-color: color-mix(in srgb, var(--ink) 15%, var(--line));
    background: color-mix(in srgb, var(--ink) 3%, transparent);
  }
  .member-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.2rem;
    border: 1px solid var(--line);
    border-radius: 0.75rem;
    color: var(--ink);
    font-family: var(--font-utility);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
    transition: all var(--dur-fast) var(--ease-out);
    align-self: flex-start;
  }
  .member-card__link:hover {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .member-card__link:active {
    transform: translateY(0);
  }
  .about-photo {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: var(--radius-card);
    border: 1px solid var(--line);
    margin: 1.6rem 0 0;
  }
  .equip :global(picture) {
    display: block;
  }
  .cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }
  .cta__title {
    margin: 0;
    max-width: 20ch;
    color: var(--on-ink);
  }
  @media (min-width: 768px) {
    .team-hero {
      grid-template-columns: minmax(19rem, 0.85fr) minmax(0, 1.15fr);
      align-items: start;
    }
    .team-hero__intro {
      position: sticky;
      top: 6.5rem;
    }
    .approach {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
    }
    .team-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    .team-cta {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      margin-top: 0.5rem;
      padding-top: 1.6rem;
    }
  }
  @media (min-width: 1100px) {
    .team-hero {
      grid-template-columns: minmax(22rem, 0.78fr) minmax(0, 1.22fr);
    }
    .team-stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }
    .team-stats li {
      padding: 0.9rem 0;
    }
    .team-grid {
      gap: 1.25rem;
    }
    .member-card__photo-container {
      aspect-ratio: 4 / 3;
    }
  }
</style>
