---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import GlassNav from "../components/GlassNav.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";
import Eyebrow from "../components/Eyebrow.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProjectCard from "../components/ProjectCard.astro";
import VimeoFacade from "../components/VimeoFacade.astro";
import Icon from "../components/Icon.astro";
import Logo from "../components/Logo.astro";
import type { IconName } from "../consts";

// --- Live content collections (Faz 3) ---------------------------------
const byOrder = (a: { data: { order: number } }, b: { data: { order: number } }) =>
  a.data.order - b.data.order;

const projectEntries = (await getCollection("projects"))
  .filter((p) => !p.data.draft)
  .sort(byOrder);
const serviceEntries = (await getCollection("services")).sort(byOrder);
const faqEntries = (await getCollection("faq")).sort(byOrder);
// Pre-render FAQ answer bodies (markdown → component).
const faqRendered = await Promise.all(
  faqEntries.map(async (entry) => ({
    data: entry.data,
    Content: (await render(entry)).Content,
  })),
);

const icons: IconName[] = [
  "home", "projects", "services", "about", "contact", "instagram",
  "youtube", "tiktok", "linkedin", "arrow-right", "arrow-up-right", "play", "whatsapp",
];
---

<BaseLayout title="Bileşen Galerisi" noindex>
  <GlassNav />

  <div class="mx-auto w-full max-w-[var(--container-max)] px-[var(--container-pad)] py-12">
    <header class="mb-14 flex flex-col gap-3">
      <Eyebrow>Geçici · Faz 2–3</Eyebrow>
      <h1 class="max-w-[20ch]">Bileşen Galerisi</h1>
      <p class="max-w-[60ch] text-ink-soft">
        Tüm çekirdek bileşenler ve içerik koleksiyonları burada sergilenir; mobil
        (390px) ve masaüstünde gözden geçirmek için. Bu sayfa yayında
        <strong>indekslenmez</strong> ve Faz sonunda kaldırılabilir.
      </p>
    </header>

    <div class="flex flex-col gap-16">
      <!-- Buttons -->
      <section class="flex flex-col gap-5">
        <Eyebrow tone="soft">Butonlar</Eyebrow>
        <div class="flex flex-wrap items-center gap-3">
          <Button href="/iletisim">Ücretsiz Ön Görüşme</Button>
          <Button href="/iletisim" arrow size="lg">Ön Görüşme Al</Button>
          <Button href="/projeler" variant="secondary">Projeleri İzle</Button>
          <Button href="/projeler" variant="secondary" arrow>Tümünü Gör</Button>
        </div>
        <div class="max-w-[22rem]">
          <Button href="/iletisim" block arrow>Tam Genişlik (mobil CTA)</Button>
        </div>
      </section>

      <!-- Eyebrows -->
      <section class="flex flex-col gap-5">
        <Eyebrow tone="soft">Etiketler (timecode)</Eyebrow>
        <div class="flex flex-col gap-2">
          <Eyebrow>Sahne 01 · Portfolyo</Eyebrow>
          <Eyebrow tone="soft">Sahne 02 · Hizmetler</Eyebrow>
        </div>
        <div class="rounded-[var(--radius-card)] bg-ink p-6">
          <Eyebrow tone="paper">Sahne 03 · Koyu Zemin</Eyebrow>
        </div>
      </section>

      <!-- Section heading -->
      <section class="flex flex-col gap-8">
        <Eyebrow tone="soft">Bölüm Başlığı</Eyebrow>
        <SectionHeading eyebrow="Sahne 04 · Neden Rast">
          Doğru kareyi yakalayan ekip
          <Fragment slot="intro">
            <p>
              35 yaş üstü karar vericiler için net, somut güven sinyalleri:
              yerinde hizmet, sinema standardı ekipman, 2–4 hafta teslim.
            </p>
          </Fragment>
        </SectionHeading>
      </section>

      <!-- Projects (live from collection) -->
      <section class="flex flex-col gap-6">
        <Eyebrow tone="soft">Projeler · koleksiyondan ({projectEntries.length})</Eyebrow>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {
            projectEntries.map((p) => (
              <ProjectCard
                href={`/projeler/${p.id}`}
                title={p.data.title}
                category={p.data.category}
                poster={p.data.poster}
                posterAlt={p.data.posterAlt}
                client={p.data.client}
                year={p.data.year}
                timecode={p.data.duration}
              />
            ))
          }
        </div>
        <p class="text-sm text-ink-soft">
          Bu kartlar <code>src/content/projects/*.md</code> dosyalarından üretilir —
          dosya eklemek yeni kart oluşturur.
        </p>
      </section>

      <!-- Services (live from collection) -->
      <section class="flex flex-col gap-6">
        <Eyebrow tone="soft">Hizmetler · koleksiyondan ({serviceEntries.length})</Eyebrow>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
          {
            serviceEntries.map((s) => (
              <article class="flex flex-col gap-3 rounded-[var(--radius-card)] border border-line p-6">
                <h3 class="text-[1.15rem] font-semibold">{s.data.title}</h3>
                <p class="text-ink-soft">{s.data.summary}</p>
                <ul class="mt-1 flex flex-col gap-1.5">
                  {s.data.features.map((f) => (
                    <li class="flex items-start gap-2 text-sm">
                      <Icon name="arrow-right" size={16} class="mt-0.5 shrink-0 text-amber-deep" />
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <!-- FAQ (live from collection, rendered markdown answers) -->
      <section class="flex flex-col gap-6">
        <Eyebrow tone="soft">SSS · koleksiyondan ({faqRendered.length})</Eyebrow>
        <div class="flex flex-col divide-y divide-line border-y border-line">
          {
            faqRendered.map((f) => {
              const Answer = f.Content;
              return (
                <div class="flex flex-col gap-2 py-5">
                  <h3 class="text-[1.05rem] font-semibold">{f.data.question}</h3>
                  <div class="faq-answer max-w-[60ch] text-ink-soft">
                    <Answer />
                  </div>
                </div>
              );
            })
          }
        </div>
      </section>

      <!-- Vimeo facade -->
      <section class="flex flex-col gap-6">
        <Eyebrow tone="soft">Vimeo Facade (tıkla-oynat, önceden yüklenmez)</Eyebrow>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          <VimeoFacade
            vimeoId="76979871"
            title="Örnek Proje Videosu"
            poster="/placeholders/poster-2.svg"
          />
          <div class="flex items-center">
            <p class="max-w-[40ch] text-ink-soft">
              iframe yalnızca tıklayınca yüklenir; sayfa açılışında Vimeo'ya hiç
              istek gitmez. Otomatik oynatma yok, <code>dnt=1</code> (izleme yok).
            </p>
          </div>
        </div>
      </section>

      <!-- Icons -->
      <section class="flex flex-col gap-6">
        <Eyebrow tone="soft">İkonlar (özel çizgi seti, emoji yok)</Eyebrow>
        <ul class="grid grid-cols-3 gap-4 sm:grid-cols-5 lg:grid-cols-7">
          {
            icons.map((name) => (
              <li class="flex flex-col items-center gap-2 rounded-[var(--radius-sm)] border border-line p-3 text-ink">
                <Icon name={name} size={26} />
                <span class="font-utility text-[0.6rem] uppercase tracking-wide text-ink-soft">
                  {name}
                </span>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- Logo -->
      <section class="flex flex-col gap-6">
        <Eyebrow tone="soft">Logo</Eyebrow>
        <div class="flex flex-wrap items-center gap-8">
          <Logo />
          <Logo wordmark={false} />
        </div>
        <div class="rounded-[var(--radius-card)] bg-ink p-8">
          <Logo tone="paper" />
        </div>
      </section>
    </div>
  </div>

  <Footer />
</BaseLayout>

<style>
  .faq-answer :global(p) {
    margin: 0;
    line-height: var(--leading-body);
  }
  .faq-answer :global(strong) {
    color: var(--ink);
  }
</style>
