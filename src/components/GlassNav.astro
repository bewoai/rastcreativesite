---
import Logo from "./Logo.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { NAV, PRIMARY_CTA, waLink } from "../consts";

// Active-route detection (ignore trailing slash).
const path = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");

// Mobile tab-bar mirrors the full nav + Home for thumb-reach parity.
const tabs = [{ label: "Ana sayfa", href: "/", icon: "home" as const }, ...NAV];

// WhatsApp quick-action, surfaced in the condensed tab-bar (null → hidden).
const whatsappHref = waLink();
---

{/* Desktop: floating glass pill */}
<header class="nav" data-nav>
  <nav class="nav__pill" aria-label="Ana gezinme">
    <Logo class="nav__logo" />
    <ul class="nav__links">
      {
        NAV.map((item) => (
          <li>
            <a
              href={item.href}
              class="nav__link"
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
    <Button href={PRIMARY_CTA.href} class="nav__cta">{PRIMARY_CTA.label}</Button>
    <ThemeToggle class="nav__theme" />
  </nav>
</header>

{/* Mobile: compact brand/theme controls without a full-width bar */}
<header class="mobile-rail" aria-label="Marka ve tema">
  <div class="mobile-rail__inner">
    <Logo class="mobile-rail__logo" />
    <span class="mobile-rail__theme-hit">
      <ThemeToggle class="mobile-rail__theme" />
    </span>
  </div>
</header>

{/* Mobile: bottom glass tab-bar */}
<nav class="tabbar" aria-label="Ana gezinme" data-mobile-tabbar>
  <ul class="tabbar__inner">
    {
      tabs.map((item) => (
        <li>
          <a
            href={item.href}
            class="tab"
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            <Icon name={item.icon} size={22} class="tab__icon" />
            <span class="tab__label">{item.label}</span>
          </a>
        </li>
      ))
    }
  </ul>
  {
    whatsappHref && (
      <a
        class="tabbar__wa"
        href={whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="WhatsApp'tan yazın"
        aria-hidden="true"
        tabindex="-1"
        data-cta-location="mobile_tabbar"
        data-tabbar-wa
      >
        <Icon name="whatsapp" size={20} class="tabbar__wa-icon" />
        <span>WhatsApp</span>
      </a>
    )
  }
  <button
    class="tabbar__fab"
    type="button"
    aria-label="Menüyü aç"
    aria-expanded="false"
    aria-hidden="true"
    tabindex="-1"
    data-tabbar-fab
  >
    <Icon name="menu" size={22} class="tabbar__fab-icon" />
    <span>Menü</span>
  </button>
</nav>

<style>
  /* ---- Desktop pill (hidden on mobile) --------------------------------- */
  .nav {
    display: none;
  }
  .nav__pill {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: clamp(0.5rem, 1.5vw, 1.25rem);
    max-width: calc(100% - 2rem);
    padding: 0.4rem 0.5rem 0.4rem 1.1rem;
    /* Liquid glass: translucent so the blur reads, with a top-light sheen. */
    background: linear-gradient(
      180deg,
      color-mix(in srgb, #ffffff 60%, transparent),
      color-mix(in srgb, var(--paper) 40%, transparent)
    );
    border: 1px solid color-mix(in srgb, #ffffff 55%, transparent);
    border-radius: var(--radius-pill);
    -webkit-backdrop-filter: blur(26px) saturate(1.9) brightness(1.05);
    backdrop-filter: blur(26px) saturate(1.9) brightness(1.05);
    box-shadow:
      0 12px 34px -12px rgba(17, 17, 16, 0.28),
      0 2px 8px -4px rgba(17, 17, 16, 0.14),
      0 1px 0 0 color-mix(in srgb, #ffffff 80%, transparent) inset,
      0 -12px 20px -16px color-mix(in srgb, var(--ink) 22%, transparent) inset;
    transition:
      padding var(--dur) var(--ease-out),
      background var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out);
  }
  .nav__links {
    display: flex;
    gap: 0.15rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav__link {
    display: inline-flex;
    align-items: center;
    min-height: var(--tap-min);
    padding: 0 0.9rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-utility);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--ink);
    touch-action: manipulation;
    transition: background-color var(--dur-fast) var(--ease-out);
  }
  .nav__link:hover {
    background: color-mix(in srgb, var(--ink) 7%, transparent);
  }
  .nav__link:focus {
    outline: none;
  }
  .nav__link:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 2px;
  }
  .nav__link[aria-current="page"] {
    color: var(--amber-text);
  }
  .nav__cta {
    margin-left: 0.25rem;
  }
  :global(.nav__theme) {
    margin-left: -0.15rem;
  }

  .nav.is-scrolled .nav__pill {
    padding-top: 0.3rem;
    padding-bottom: 0.3rem;
    /* Slightly denser once over content, but keep the glass legible. */
    background: linear-gradient(
      180deg,
      color-mix(in srgb, #ffffff 72%, transparent),
      color-mix(in srgb, var(--paper) 58%, transparent)
    );
    box-shadow:
      0 14px 40px -16px rgba(17, 17, 16, 0.34),
      0 2px 8px -4px rgba(17, 17, 16, 0.16),
      0 1px 0 0 color-mix(in srgb, #ffffff 85%, transparent) inset,
      0 -12px 20px -16px color-mix(in srgb, var(--ink) 24%, transparent) inset;
  }

  :global(html[data-theme="dark"]) .nav__pill,
  :global(html[data-theme="dark"]) .tabbar__inner,
  :global(html[data-theme="dark"]) .tabbar__fab {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, #2a241e 78%, transparent),
      color-mix(in srgb, var(--paper) 70%, transparent)
    );
    border-color: color-mix(in srgb, var(--on-ink) 14%, transparent);
    box-shadow:
      0 12px 34px -14px rgba(0, 0, 0, 0.5),
      0 1px 0 0 color-mix(in srgb, var(--on-ink) 10%, transparent) inset;
  }

  :global(html[data-theme="dark"]) .nav.is-scrolled .nav__pill {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, #2a241e 86%, transparent),
      color-mix(in srgb, var(--paper) 78%, transparent)
    );
  }

  @media (min-width: 768px) {
    .nav {
      display: flex;
      justify-content: center;
      position: fixed;
      inset: 0 0 auto 0;
      z-index: 50;
      padding: clamp(0.6rem, 2vw, 1rem);
      pointer-events: none; /* let clicks pass through the transparent track */
    }
    .mobile-rail,
    .tabbar {
      display: none;
    }
  }

  /* ---- Mobile top controls --------------------------------------------- */
  .mobile-rail {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    padding: calc(0.6rem + env(safe-area-inset-top, 0px)) 0.85rem 0;
    pointer-events: none;
  }
  .mobile-rail__inner {
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  :global(.mobile-rail__logo) {
    pointer-events: auto;
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: var(--tap-min);
    padding: 0.38rem 0.82rem;
    border: 1px solid color-mix(in srgb, #ffffff 48%, transparent);
    border-radius: var(--radius-pill);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, #ffffff 74%, transparent),
      color-mix(in srgb, var(--paper) 56%, transparent)
    );
    -webkit-backdrop-filter: blur(18px) saturate(1.45);
    backdrop-filter: blur(18px) saturate(1.45);
    box-shadow:
      0 10px 28px -18px rgba(17, 17, 16, 0.34),
      0 1px 0 0 color-mix(in srgb, #ffffff 72%, transparent) inset;
  }
  :global(.mobile-rail__logo .logo__svg) {
    height: 1.34rem;
  }
  :global(.mobile-rail__logo)::before {
    content: "";
    position: absolute;
    inset: -0.25rem;
    border-radius: inherit;
  }
  .mobile-rail__theme-hit {
    pointer-events: auto;
    display: grid;
    place-items: center;
    min-width: var(--tap-min);
    min-height: var(--tap-min);
    padding: 0;
  }
  :global(.mobile-rail__theme) {
    --tt-h: 1.62rem;
    --tt-w: 3.24rem;
  }
  :global(html[data-theme="dark"] .mobile-rail__logo) {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, #2a241e 84%, transparent),
      color-mix(in srgb, var(--paper) 72%, transparent)
    );
    border-color: color-mix(in srgb, var(--on-ink) 14%, transparent);
    box-shadow:
      0 10px 28px -18px rgba(0, 0, 0, 0.55),
      0 1px 0 0 color-mix(in srgb, var(--on-ink) 9%, transparent) inset;
  }

  /* ---- Mobile bottom tab-bar ------------------------------------------- */
  .tabbar {
    position: fixed;
    inset: auto 0 0 0;
    z-index: 50;
    padding: 0.35rem 0.65rem calc(0.35rem + env(safe-area-inset-bottom, 0px));
    pointer-events: none;
  }
  .tabbar__inner {
    pointer-events: auto;
    display: flex;
    justify-content: space-between;
    gap: 0.15rem;
    list-style: none;
    margin: 0;
    padding: 0.25rem;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, #ffffff 64%, transparent),
      color-mix(in srgb, var(--paper) 50%, transparent)
    );
    border: 1px solid color-mix(in srgb, #ffffff 55%, transparent);
    border-radius: var(--radius-pill);
    -webkit-backdrop-filter: blur(24px) saturate(1.85) brightness(1.05);
    backdrop-filter: blur(24px) saturate(1.85) brightness(1.05);
    box-shadow:
      0 -10px 30px -16px rgba(17, 17, 16, 0.32),
      0 1px 0 0 color-mix(in srgb, #ffffff 75%, transparent) inset;
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
    transition:
      transform var(--dur) var(--ease-out),
      opacity var(--dur-fast) var(--ease-out),
      visibility var(--dur-fast) var(--ease-out);
  }
  .tabbar__inner li {
    flex: 1 1 0;
    min-width: 0;
  }
  .tab {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.18rem;
    min-height: var(--tap-min);
    padding: 0.28rem 0.12rem;
    border-radius: 0.95rem;
    color: var(--ink-soft);
    text-align: center;
    touch-action: manipulation;
  }
  .tab:focus {
    outline: none;
  }
  .tab:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: -2px;
  }
  .tab__label {
    font-family: var(--font-utility);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: uppercase;
    white-space: nowrap;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .tab[aria-current="page"] {
    color: var(--amber-text);
  }

  .tabbar__fab {
    pointer-events: none;
    position: absolute;
    right: 0.75rem;
    bottom: calc(0.55rem + env(safe-area-inset-bottom, 0px));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    min-width: 3.35rem;
    min-height: var(--tap-min);
    padding: 0 0.8rem;
    border: 1px solid color-mix(in srgb, #ffffff 55%, transparent);
    border-radius: var(--radius-pill);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, #ffffff 68%, transparent),
      color-mix(in srgb, var(--paper) 52%, transparent)
    );
    color: var(--ink);
    font: 600 0.72rem/1 var(--font-utility);
    box-shadow:
      0 -10px 30px -16px rgba(17, 17, 16, 0.32),
      0 1px 0 0 color-mix(in srgb, #ffffff 75%, transparent) inset;
    -webkit-backdrop-filter: blur(24px) saturate(1.85) brightness(1.05);
    backdrop-filter: blur(24px) saturate(1.85) brightness(1.05);
    opacity: 0;
    visibility: hidden;
    transform: translateY(0.8rem) scale(0.96);
    transition:
      transform var(--dur) var(--ease-out),
      opacity var(--dur-fast) var(--ease-out),
      visibility var(--dur-fast) var(--ease-out);
  }
  .tabbar__fab:focus {
    outline: none;
  }
  .tabbar__fab:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 2px;
  }
  .tabbar.is-condensed .tabbar__inner {
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transform: translateY(calc(100% + 0.9rem));
  }
  .tabbar.is-condensed .tabbar__fab {
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  /* WhatsApp quick-action: mirror of the Menü FAB on the left, revealed with it
     when the tab-bar condenses — so the two never collide and stay balanced. */
  .tabbar__wa {
    pointer-events: none;
    position: absolute;
    left: 0.75rem;
    bottom: calc(0.55rem + env(safe-area-inset-bottom, 0px));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: var(--tap-min);
    padding: 0 0.95rem;
    border-radius: var(--radius-pill);
    background: #25d366;
    color: #fff;
    font: 600 0.78rem/1 var(--font-utility);
    box-shadow:
      0 -10px 30px -16px rgba(17, 17, 16, 0.32),
      0 6px 18px -8px rgba(37, 211, 102, 0.6);
    opacity: 0;
    visibility: hidden;
    transform: translateY(0.8rem) scale(0.96);
    transition:
      transform var(--dur) var(--ease-out),
      opacity var(--dur-fast) var(--ease-out),
      visibility var(--dur-fast) var(--ease-out);
  }
  .tabbar__wa:focus {
    outline: none;
  }
  .tabbar__wa:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
  }
  .tabbar.is-condensed .tabbar__wa {
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  @media (max-width: 380px) {
    .tabbar {
      padding-inline: 0.45rem;
    }
    .tabbar__inner {
      gap: 0.08rem;
    }
    .tab {
      padding-inline: 0.08rem;
    }
    .tab__label {
      font-size: 0.58rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tabbar__inner,
    .tabbar__fab,
    .tabbar__wa {
      transition: none;
    }
  }
</style>

<script>
  // Scroll-aware chrome: desktop pill shrinks; mobile tabs condense while moving down.
  const nav = document.querySelector<HTMLElement>("[data-nav]");
  const tabbar = document.querySelector<HTMLElement>("[data-mobile-tabbar]");
  const tabbarFab = document.querySelector<HTMLButtonElement>("[data-tabbar-fab]");
  const tabbarWa = document.querySelector<HTMLAnchorElement>("[data-tabbar-wa]");
  const desktopQuery = matchMedia("(min-width: 768px)");
  const mobileQuery = matchMedia("(max-width: 767.98px)");

  let ticking = false;
  let lastScrollY = Math.max(0, window.scrollY);

  const setTabbarCondensed = (condensed: boolean) => {
    if (!tabbar || !tabbarFab) return;

    tabbar.classList.toggle("is-condensed", condensed);
    tabbarFab.setAttribute("aria-expanded", "false");
    tabbarFab.setAttribute("aria-hidden", condensed ? "false" : "true");
    tabbarFab.tabIndex = condensed ? 0 : -1;
    if (tabbarWa) {
      tabbarWa.setAttribute("aria-hidden", condensed ? "false" : "true");
      tabbarWa.tabIndex = condensed ? 0 : -1;
    }
  };

  const updateChrome = () => {
    const currentY = Math.max(0, window.scrollY);
    const delta = currentY - lastScrollY;

    if (nav) {
      nav.classList.toggle("is-scrolled", desktopQuery.matches && currentY > 8);
    }

    if (tabbar && tabbarFab) {
      if (!mobileQuery.matches) {
        setTabbarCondensed(false);
      } else {
        const documentHeight = document.documentElement.scrollHeight;
        const nearTop = currentY < 96;
        const nearBottom = window.innerHeight + currentY >= documentHeight - 120;

        if (nearTop || nearBottom || delta < -10) {
          setTabbarCondensed(false);
        } else if (delta > 10 && currentY > 140) {
          setTabbarCondensed(true);
        }
      }
    }

    lastScrollY = currentY;
    ticking = false;
  };

  const requestChromeUpdate = () => {
    if (!ticking) {
      ticking = true;
      requestAnimationFrame(updateChrome);
    }
  };

  updateChrome();
  window.addEventListener("scroll", requestChromeUpdate, { passive: true });
  window.addEventListener("resize", requestChromeUpdate);
  desktopQuery.addEventListener("change", requestChromeUpdate);
  mobileQuery.addEventListener("change", requestChromeUpdate);

  if (tabbarFab) {
    tabbarFab.addEventListener("click", () => {
      setTabbarCondensed(false);
      lastScrollY = Math.max(0, window.scrollY);
      ticking = false;
    });
  }
</script>

<style is:global>
  /* Reserve space for the fixed nav so content never hides behind it. */
  @media (max-width: 767.98px) {
    body {
      padding-top: calc(3.45rem + env(safe-area-inset-top, 0px));
      padding-bottom: calc(4.5rem + env(safe-area-inset-bottom, 0px));
    }
  }
  @media (min-width: 768px) {
    body {
      padding-top: 5.5rem;
    }
  }
</style>
