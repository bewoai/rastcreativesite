---
import { Image } from "astro:assets";
import Button from "./Button.astro";
import { PRIMARY_CTA } from "../consts";
import brandFilm from "../assets/photos/film-crew-red-camera.jpg";
import reelsCut from "../assets/photos/vertical-video-creator.jpg";
import dronePlan from "../assets/photos/aerial-drone-landscape.jpg";
---

<section class="story" aria-labelledby="production-story-title" data-production-story>
  <div class="story__sticky">
    <div class="story__narrative">
      <span class="story__eyebrow">Sahne 01.5 · Üretim Akışı</span>
      <h2 id="production-story-title">Tek çekim, baştan sona üretim akışı</h2>
      <p>
        Her projeyi tek bir üretim akışı olarak kurguluyoruz: hangi formatların
        gerekeceğini baştan planlıyor, çekimi buna göre hazırlıyoruz. Fikirden teslime
        kadar süreç tek elden ilerliyor.
      </p>

      <ol class="story__steps" aria-label="Üretim akışı">
        <li class="story__step story__step--one">
          <span>01</span>
          <strong>Planlama</strong>
          <em>Hedefi ve hangi formatların gerekeceğini (web, sosyal, reklam) baştan netleştiririz.</em>
        </li>
        <li class="story__step story__step--two">
          <span>02</span>
          <strong>Tek çekim</strong>
          <em>Ana film, dikey kesit ve drone planını aynı sette tek çekimde alırız.</em>
        </li>
        <li class="story__step story__step--three">
          <span>03</span>
          <strong>Kurgu &amp; teslim</strong>
          <em>Renk, ses ve kurguyla her formatı yayına hazır teslim ederiz.</em>
        </li>
      </ol>

      <div class="story__cta">
        <Button href={PRIMARY_CTA.href} size="lg" arrow data-cta-location="showreel">
          {PRIMARY_CTA.label}
        </Button>
      </div>
    </div>

    <div class="story__stage" aria-hidden="true">
      <div class="story__ambient story__ambient--one"></div>
      <div class="story__ambient story__ambient--two"></div>

      <div class="story__deck">
        <div class="story__screen">
          <div class="story__screenTop">
            <span>Rast Production Board</span>
            <span>00:14</span>
          </div>

          <div class="story__heroFrame">
            <Image
              src={brandFilm}
              alt=""
              widths={[360, 560, 760, 980]}
              sizes="(min-width: 980px) 41rem, 92vw"
              loading="lazy"
              class="story__image"
            />
            <div class="story__frameOverlay">
              <span>4K Brand Film</span>
              <strong>Tanıtım filmi</strong>
            </div>
            <span class="story__focusRing"></span>
          </div>

          <div class="story__timeline">
            <span class="story__track story__track--wide"></span>
            <span class="story__track story__track--amber"></span>
            <span class="story__track"></span>
            <span class="story__playhead"></span>
          </div>
        </div>

        <div class="story__phone">
          <Image
            src={reelsCut}
            alt=""
            widths={[180, 260, 340]}
            sizes="(min-width: 980px) 10rem, 8rem"
            loading="lazy"
            class="story__phoneImage"
          />
          <span>9:16</span>
          <strong>Reels Cut</strong>
        </div>

        <div class="story__drone">
          <Image
            src={dronePlan}
            alt=""
            widths={[220, 320, 440]}
            sizes="(min-width: 980px) 14rem, 11rem"
            loading="lazy"
            class="story__droneImage"
          />
          <span>Drone</span>
          <strong>Hava çekimi</strong>
        </div>

        <div class="story__post">
          <span>Kurgu & Renk</span>
          <strong>Yayına hazır</strong>
          <div class="story__meters">
            <i></i>
            <i></i>
            <i></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .story {
    --p: 0;
    --p1: 0;
    --p2: 0;
    --p3: 0;
    --pin-top: clamp(4.6rem, 8vh, 6.4rem);
    position: relative;
    min-height: 230dvh;
    margin-top: -1px;
    padding-inline: var(--container-pad);
    background:
      radial-gradient(circle at 82% 22%, color-mix(in srgb, var(--amber) 18%, transparent), transparent 26rem),
      linear-gradient(180deg, var(--ink-band), var(--ink) 52%, var(--paper) 100%);
    isolation: isolate;
  }

  .story__sticky {
    position: relative;
    top: auto;
    width: min(var(--container-max), 100%);
    min-height: calc(100dvh - var(--pin-top));
    margin-inline: auto;
    box-sizing: border-box;
    display: grid;
    grid-template-columns: minmax(19rem, 0.82fr) minmax(34rem, 1.18fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
    overflow: visible;
  }

  .story.is-pinned .story__sticky {
    position: fixed;
    inset-block-start: var(--pin-top);
    inset-inline-start: 50%;
    z-index: 3;
    width: min(var(--container-max), calc(100% - (var(--container-pad) * 2)));
    transform: translateX(-50%);
  }

  .story.is-after .story__sticky {
    position: absolute;
    inset-block-start: auto;
    inset-block-end: 0;
    inset-inline-start: 50%;
    width: min(var(--container-max), calc(100% - (var(--container-pad) * 2)));
    transform: translateX(-50%);
  }

  .story__narrative {
    position: relative;
    z-index: 3;
    max-width: 31rem;
    color: var(--on-ink);
  }

  /* Section eyebrow — same slate structure as the site Eyebrow component, but
     a brighter, theme-independent amber so it stays legible on the dark band. */
  .story__eyebrow {
    display: block;
    font-family: var(--font-utility);
    font-size: var(--text-eyebrow);
    font-weight: 600;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
    color: color-mix(in srgb, var(--amber) 60%, var(--on-ink));
  }

  /* Mini "slate" tags inside the deck cards (4K BRAND FİLM, 9:16, …). */
  .story__step span,
  .story__frameOverlay span,
  .story__phone span,
  .story__drone span,
  .story__post span {
    font-family: var(--font-utility);
    font-size: 0.74rem;
    font-style: normal;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--amber-text) 84%, var(--on-ink));
  }

  .story__narrative h2 {
    margin: 0.75rem 0 0;
    max-width: 12ch;
    color: var(--on-ink);
    font-size: clamp(2.35rem, 5vw, 5.2rem);
    line-height: 0.96;
    letter-spacing: 0;
  }

  .story__narrative p {
    margin: 1.1rem 0 0;
    max-width: 34rem;
    color: color-mix(in srgb, var(--on-ink) 76%, transparent);
    font-size: clamp(1rem, 1.45vw, 1.18rem);
    line-height: 1.55;
  }

  .story__steps {
    list-style: none;
    margin: clamp(1.35rem, 3vw, 2.1rem) 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .story__step {
    display: grid;
    grid-template-columns: 2.25rem 1fr;
    gap: 0.25rem 0.8rem;
    padding: 0.9rem 1rem;
    border: 1px solid color-mix(in srgb, var(--on-ink) 14%, transparent);
    border-radius: 0.65rem;
    background: color-mix(in srgb, var(--ink-band) 58%, transparent);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--on-ink) 10%, transparent);
    opacity: 0.36;
    transform: translateY(12px);
    will-change: transform, opacity;
  }

  .story__step strong {
    color: var(--on-ink);
    font-size: 0.98rem;
    line-height: 1.15;
  }

  .story__step em {
    grid-column: 2;
    color: color-mix(in srgb, var(--on-ink) 68%, transparent);
    font-style: normal;
    font-size: 0.86rem;
    line-height: 1.35;
  }

  .story__step--one {
    opacity: calc(0.36 + (var(--p1) * 0.64));
    transform: translateY(calc((1 - var(--p1)) * 12px));
  }

  .story__step--two {
    opacity: calc(0.36 + (var(--p2) * 0.64));
    transform: translateY(calc((1 - var(--p2)) * 12px));
  }

  .story__step--three {
    opacity: calc(0.36 + (var(--p3) * 0.64));
    transform: translateY(calc((1 - var(--p3)) * 12px));
  }

  .story__cta {
    margin-top: clamp(1.5rem, 3vw, 2.2rem);
  }

  .story__stage {
    position: relative;
    z-index: 2;
    width: min(47rem, 100%);
    justify-self: end;
    perspective: 1300px;
    pointer-events: none;
  }

  .story__ambient {
    position: absolute;
    border-radius: 999px;
    filter: blur(32px);
    opacity: 0.72;
    pointer-events: none;
  }

  .story__ambient--one {
    right: 0;
    top: 12%;
    width: min(35rem, 76vw);
    aspect-ratio: 1;
    background: radial-gradient(circle, color-mix(in srgb, var(--amber) 25%, transparent), transparent 62%);
  }

  .story__ambient--two {
    left: -12%;
    top: 0;
    width: min(28rem, 66vw);
    aspect-ratio: 1;
    background: radial-gradient(circle, color-mix(in srgb, #45d5d0 15%, transparent), transparent 62%);
  }

  .story__deck {
    position: relative;
    height: clamp(30rem, 45vw, 40rem);
    transform-style: preserve-3d;
    transform:
      translateY(calc((0.5 - var(--p)) * 34px))
      rotateX(calc(7deg - (var(--p) * 8deg)))
      rotateY(calc(-12deg + (var(--p) * 14deg)));
    will-change: transform;
  }

  .story__screen,
  .story__phone,
  .story__drone,
  .story__post {
    position: absolute;
    border: 1px solid color-mix(in srgb, var(--on-ink) 15%, transparent);
    background: color-mix(in srgb, var(--ink-band) 82%, transparent);
    -webkit-backdrop-filter: blur(16px) saturate(1.15);
    backdrop-filter: blur(16px) saturate(1.15);
    box-shadow:
      0 32px 90px color-mix(in srgb, #000000 42%, transparent),
      inset 0 1px 0 color-mix(in srgb, var(--on-ink) 12%, transparent);
  }

  .story__screen {
    inset: 5.2rem 7.9rem 4.8rem 0;
    border-radius: 1.15rem;
    overflow: hidden;
    transform: translateZ(42px) scale(calc(0.95 + (var(--p) * 0.055)));
    will-change: transform;
  }

  .story__screenTop {
    min-height: 2.6rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-inline: 1rem;
    color: color-mix(in srgb, var(--on-ink) 76%, transparent);
    font-family: var(--font-utility);
    font-size: 0.72rem;
    line-height: 1;
  }

  .story__heroFrame {
    position: relative;
    height: calc(100% - 5.8rem);
    overflow: hidden;
    isolation: isolate;
  }

  .story__image,
  .story__phoneImage,
  .story__droneImage {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .story__heroFrame::after,
  .story__phone::after,
  .story__drone::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, color-mix(in srgb, #000000 6%, transparent), color-mix(in srgb, #000000 48%, transparent)),
      radial-gradient(circle at 72% 28%, color-mix(in srgb, var(--amber) 24%, transparent), transparent 32%);
  }

  .story__frameOverlay {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    z-index: 2;
    display: grid;
    gap: 0.15rem;
  }

  .story__frameOverlay strong,
  .story__phone strong,
  .story__drone strong,
  .story__post strong {
    color: var(--on-ink);
    font-size: 1rem;
    line-height: 1.08;
  }

  .story__focusRing {
    position: absolute;
    right: 18%;
    top: 25%;
    z-index: 2;
    width: 6.4rem;
    aspect-ratio: 1;
    border: 1px solid color-mix(in srgb, var(--amber) 50%, transparent);
    border-radius: 999px;
    opacity: calc(0.24 + (var(--p1) * 0.52));
    transform: scale(calc(0.76 + (var(--p1) * 0.32)));
    will-change: transform, opacity;
  }

  .story__timeline {
    position: relative;
    height: 3.2rem;
    display: grid;
    grid-template-columns: 1.25fr 0.76fr 1fr;
    gap: 0.42rem;
    align-items: center;
    padding-inline: 1rem;
    background: color-mix(in srgb, #000000 22%, transparent);
  }

  .story__track {
    height: 0.48rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--on-ink) 18%, transparent);
  }

  .story__track--amber {
    background: color-mix(in srgb, var(--amber) 72%, transparent);
  }

  .story__playhead {
    position: absolute;
    left: calc(14% + (var(--p) * 58%));
    top: 0.62rem;
    bottom: 0.62rem;
    width: 2px;
    background: color-mix(in srgb, var(--on-ink) 86%, transparent);
  }

  .story__phone {
    right: 0;
    bottom: 3.1rem;
    width: 10rem;
    height: 18.4rem;
    border-radius: 1.25rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.18rem;
    padding: 0.9rem;
    transform:
      translateZ(calc(92px + (var(--p1) * 24px)))
      translateX(calc((1 - var(--p1)) * 42px))
      translateY(calc((1 - var(--p1)) * 18px))
      rotateY(-7deg);
    opacity: var(--p1);
    will-change: transform, opacity;
  }

  .story__phoneImage,
  .story__droneImage {
    position: absolute;
    inset: 0;
  }

  .story__phone span,
  .story__phone strong,
  .story__drone span,
  .story__drone strong {
    position: relative;
    z-index: 2;
  }

  .story__drone {
    right: 3.9rem;
    top: -1rem;
    width: 14.2rem;
    height: 6rem;
    border-radius: 1rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.12rem;
    padding: 0.85rem;
    transform:
      translateZ(calc(26px + (var(--p2) * 64px)))
      translateY(calc((1 - var(--p2)) * -30px))
      rotateX(-2deg);
    opacity: var(--p2);
    will-change: transform, opacity;
  }

  .story__post {
    left: 0.25rem;
    bottom: 1.15rem;
    width: 13.4rem;
    border-radius: 1rem;
    padding: 0.95rem 1rem;
    display: grid;
    gap: 0.25rem;
    transform:
      translateZ(calc(68px + (var(--p3) * 22px)))
      translateY(calc((1 - var(--p3)) * 24px))
      rotateY(5deg);
    opacity: var(--p3);
    will-change: transform, opacity;
  }

  .story__meters {
    display: grid;
    grid-template-columns: 1.2fr 0.75fr 1fr;
    gap: 0.28rem;
    margin-top: 0.45rem;
  }

  .story__meters i {
    height: 0.42rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--on-ink) 16%, transparent);
  }

  .story__meters i:nth-child(2) {
    background: color-mix(in srgb, var(--amber) 70%, transparent);
  }

  /* Laptop-height safety: when the pinned scene is viewed on shorter desktop
     screens, the left CTA must stay fully visible above the viewport edge. */
  @media (min-width: 980px) and (max-height: 900px) {
    .story__sticky {
      gap: clamp(1.5rem, 4vw, 3.5rem);
    }

    .story__narrative h2 {
      font-size: clamp(2.25rem, 4.35vw, 4.35rem);
      line-height: 0.94;
    }

    .story__narrative p {
      margin-top: 0.9rem;
      font-size: clamp(0.95rem, 1.2vw, 1.05rem);
      line-height: 1.45;
    }

    .story__steps {
      margin-top: 1rem;
      gap: 0.55rem;
    }

    .story__step {
      padding: 0.72rem 0.85rem;
    }

    .story__step strong {
      font-size: 0.92rem;
    }

    .story__step em {
      font-size: 0.78rem;
      line-height: 1.25;
    }

    .story__cta {
      margin-top: 1rem;
    }

    .story__deck {
      height: clamp(26rem, 39vw, 34rem);
    }

    .story__screen {
      inset: 4.4rem 7rem 4.1rem 0;
    }

    .story__phone {
      bottom: 2.65rem;
      width: 9.15rem;
      height: 16.8rem;
    }

    .story__drone {
      right: 3.4rem;
      width: 12.8rem;
      height: 5.55rem;
    }

    .story__post {
      bottom: 0.85rem;
      width: 12.4rem;
      padding: 0.8rem 0.9rem;
    }
  }

  /* ---------------------------------------------------------------------
     Mobile (<980px): the 3D fly-out collage clips and crowds on a narrow
     screen, so we drop the pin + parallax entirely and render a clean,
     fully-contained gallery: full-width board + a 3-up output row. The
     "one shoot → four outputs" story stays legible. (Desktop is untouched.)
     --------------------------------------------------------------------- */
  @media (max-width: 979.98px) {
    .story {
      --pin-top: 0px;
      min-height: auto;
      padding-block: clamp(2.75rem, 9vw, 4rem);
      background:
        radial-gradient(circle at 70% 12%, color-mix(in srgb, var(--amber) 14%, transparent), transparent 18rem),
        linear-gradient(180deg, var(--ink-band), var(--ink) 68%, var(--paper) 100%);
    }

    /* Neutralise the pin state machine — same specificity as the desktop
       is-pinned/is-after rules and declared later, so it wins cleanly. */
    .story.is-pinned .story__sticky,
    .story.is-after .story__sticky,
    .story__sticky {
      position: relative;
      inset: auto;
      top: auto;
      width: 100%;
      min-height: auto;
      transform: none;
      grid-template-columns: 1fr;
      align-content: start;
      gap: clamp(1.5rem, 6vw, 2.25rem);
      padding: 0;
    }

    .story__ambient {
      display: none;
    }

    /* Read order: message first, proof second. */
    .story__narrative {
      order: 1;
      max-width: 100%;
      opacity: 1;
    }

    .story__narrative h2 {
      max-width: 18ch;
      margin-top: 0.55rem;
      font-size: clamp(1.9rem, 7.5vw, 2.75rem);
      line-height: 1.04;
    }

    .story__narrative p {
      max-width: 48ch;
      margin-top: 0.8rem;
      font-size: 1rem;
      line-height: 1.55;
    }

    .story__steps {
      margin-top: 1.15rem;
      gap: 0.6rem;
    }

    .story__step {
      grid-template-columns: 1.9rem 1fr;
      padding: 0.85rem 0.9rem;
      border-radius: 0.6rem;
      opacity: 1;
      transform: none;
    }

    .story__step strong {
      font-size: 0.95rem;
    }

    .story__step em {
      font-size: 0.82rem;
      line-height: 1.3;
    }

    /* ---- Stage: flat & contained ---- */
    .story__stage {
      order: 2;
      justify-self: stretch;
      width: 100%;
      perspective: none;
    }

    .story__deck {
      height: auto;
      transform: none;
      transform-style: flat;
      will-change: auto;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.6rem;
    }

    .story__screen {
      position: static;
      inset: auto;
      grid-column: 1 / -1;
      width: 100%;
      transform: translateY(calc((var(--p) - 0.5) * -8px));
      border-radius: 0.9rem;
    }

    .story__screenTop {
      min-height: 2.5rem;
      padding-inline: 0.9rem;
      font-size: 0.7rem;
    }

    .story__heroFrame {
      height: auto;
      aspect-ratio: 16 / 9;
    }

    .story__timeline {
      height: 2.6rem;
      padding-inline: 0.9rem;
    }

    /* Playhead still sweeps with scroll → the section never feels frozen. */
    .story__playhead {
      left: calc(16% + (var(--p) * 58%));
    }

    .story__focusRing {
      display: none;
    }

    /* Scroll-reveal (site idiom): board + outputs fade in, clearly staggered, as
       they enter. Opacity-only so it never fights the scroll parallax (transform).
       Gated by .story--anim (added by JS on mobile + no-preference) → no opacity
       trap for no-JS / reduced-motion users. */
    .story--anim .story__screen,
    .story--anim .story__phone,
    .story--anim .story__drone,
    .story--anim .story__post {
      opacity: 0;
      transition: opacity 0.6s var(--ease-out);
    }

    .story--anim .story__phone {
      transition-delay: 0.1s;
    }

    .story--anim .story__drone {
      transition-delay: 0.2s;
    }

    .story--anim .story__post {
      transition-delay: 0.3s;
    }

    .story--anim .story__screen.is-in,
    .story--anim .story__phone.is-in,
    .story--anim .story__drone.is-in,
    .story--anim .story__post.is-in {
      opacity: 1;
    }

    /* The three secondary outputs become an even, contained row with a gentle
       scroll-linked vertical parallax — moves faster than the board (depth),
       vertical-only so the row stays aligned and never clips sideways. */
    .story__phone,
    .story__drone,
    .story__post {
      position: static;
      inset: auto;
      width: auto;
      min-width: 0;
      height: 6.6rem;
      transform: translateY(calc((var(--p) - 0.5) * -20px));
      opacity: 1;
      border-radius: 0.7rem;
      padding: 0.6rem;
    }

    .story__post {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      gap: 0.15rem;
    }

    .story__meters {
      display: none;
    }

    .story__frameOverlay {
      left: 0.9rem;
      bottom: 0.9rem;
    }

    .story__frameOverlay span,
    .story__phone span,
    .story__drone span,
    .story__post span {
      font-size: 0.56rem;
    }

    .story__frameOverlay strong,
    .story__phone strong,
    .story__drone strong,
    .story__post strong {
      font-size: 0.8rem;
      line-height: 1.1;
    }
  }

  @media (max-width: 420px) {
    .story__phone,
    .story__drone,
    .story__post {
      height: 5.6rem;
      padding: 0.5rem;
    }

    .story__frameOverlay strong,
    .story__phone strong,
    .story__drone strong,
    .story__post strong {
      font-size: 0.74rem;
    }
  }

  /* Reduced-motion: no pin, no 3D. Without the 3D offsets the absolute cards
     would pile onto the board, so we fall back to the SAME flat, contained
     gallery the mobile layout uses (board + 3-up output row) at any width. */
  @media (prefers-reduced-motion: reduce) {
    .story {
      --p: 1;
      --p1: 1;
      --p2: 1;
      --p3: 1;
      min-height: auto;
      padding-block: clamp(3rem, 8vw, 6rem);
    }

    .story.is-pinned .story__sticky,
    .story.is-after .story__sticky,
    .story__sticky {
      position: relative;
      inset: auto;
      top: auto;
      width: min(46rem, 100%);
      min-height: auto;
      transform: none;
      grid-template-columns: 1fr;
      align-content: start;
      gap: clamp(1.5rem, 5vw, 2.25rem);
    }

    .story__ambient {
      display: none;
    }

    .story__narrative {
      order: 1;
      max-width: 100%;
      opacity: 1;
    }

    .story__step {
      opacity: 1;
      transform: none;
      transition: none;
      will-change: auto;
    }

    .story__stage {
      order: 2;
      justify-self: stretch;
      width: 100%;
      perspective: none;
    }

    .story__deck {
      height: auto;
      transform: none;
      transform-style: flat;
      will-change: auto;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.6rem;
    }

    .story__screen {
      position: static;
      inset: auto;
      grid-column: 1 / -1;
      width: 100%;
      transform: none;
      will-change: auto;
      border-radius: 0.9rem;
    }

    .story__heroFrame {
      height: auto;
      aspect-ratio: 16 / 9;
    }

    .story__playhead {
      left: 34%;
    }

    .story__focusRing {
      display: none;
    }

    .story__phone,
    .story__drone,
    .story__post {
      position: static;
      inset: auto;
      width: auto;
      min-width: 0;
      height: 7rem;
      transform: none;
      opacity: 1;
      will-change: auto;
      border-radius: 0.7rem;
    }

    .story__post {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      gap: 0.15rem;
    }

    .story__meters {
      display: none;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-production-story]").forEach((story) => {
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const clamp = (value: number, min = 0, max = 1) => Math.min(max, Math.max(min, value));
    const segment = (value: number, start: number, end: number) => clamp((value - start) / (end - start));

    const setProgress = (progress: number) => {
      story.style.setProperty("--p", progress.toFixed(3));
      story.style.setProperty("--p1", segment(progress, 0.08, 0.34).toFixed(3));
      story.style.setProperty("--p2", segment(progress, 0.36, 0.66).toFixed(3));
      story.style.setProperty("--p3", segment(progress, 0.64, 0.9).toFixed(3));
    };

    if (reduceMotion) {
      setProgress(1);
      return;
    }

    // Mobile: the desktop 3D parallax is dropped (it clipped), so the stage was
    // static. Give it life with the site's scroll-reveal idiom — fade/rise the
    // board + outputs as they enter. (Playhead also sweeps via --p in CSS.)
    if (window.innerWidth < 980) {
      story.classList.add("story--anim");
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-in");
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.18, rootMargin: "0px 0px -8% 0px" },
      );
      story
        .querySelectorAll(".story__screen, .story__phone, .story__drone, .story__post")
        .forEach((el) => io.observe(el));
    }

    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
    const sticky = story.querySelector<HTMLElement>(".story__sticky");

    // Layout metrics are cached and only recomputed on resize. Reading
    // offsetHeight on every scroll frame forces a reflow → the "rubber" jank.
    let viewport = 1;
    let pinTop = 0;
    let stickyHeight = 0;
    let scrollRange = 1;

    const measure = () => {
      viewport = window.innerHeight || 1;
      pinTop = window.innerWidth < 980 ? 0 : Math.min(102, Math.max(74, viewport * 0.08));
      story.style.setProperty("--pin-top", `${pinTop}px`);
      stickyHeight = sticky ? sticky.offsetHeight : viewport;
      scrollRange = Math.max(1, story.offsetHeight - viewport);
    };

    let target = 0;
    let current = 0;
    let running = false;

    const readTarget = () => {
      const rect = story.getBoundingClientRect();
      if (sticky) {
        const isPinned = rect.top <= pinTop && rect.bottom > pinTop + stickyHeight;
        const isAfter = rect.bottom <= pinTop + stickyHeight;
        story.classList.toggle("is-pinned", isPinned);
        story.classList.toggle("is-after", isAfter);
      }
      target = clamp((pinTop - rect.top) / scrollRange);
    };

    // rAF loop eases `current` toward `target` (lerp) so fast scrolls glide
    // instead of snapping. Writes only composited props (transform/opacity).
    const render = () => {
      current = lerp(current, target, 0.18);
      if (Math.abs(target - current) < 0.0006) current = target;
      setProgress(current);
      if (current !== target) {
        window.requestAnimationFrame(render);
      } else {
        running = false;
      }
    };

    const kick = () => {
      if (running) return;
      running = true;
      window.requestAnimationFrame(render);
    };

    const onScroll = () => {
      readTarget();
      kick();
    };

    const onResize = () => {
      measure();
      readTarget();
      kick();
    };

    measure();
    readTarget();
    current = target;
    setProgress(current);

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onResize);
  });
</script>
