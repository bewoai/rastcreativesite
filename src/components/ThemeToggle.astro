---
import Icon from "./Icon.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<button
  class:list={["theme-toggle", className]}
  type="button"
  aria-label="Koyu temaya geç"
  aria-pressed="false"
  data-theme-toggle
>
  <span class="theme-toggle__track" aria-hidden="true">
    <span class="theme-toggle__icon theme-toggle__icon--sun">
      <Icon name="sun" size={13} />
    </span>
    <span class="theme-toggle__icon theme-toggle__icon--moon">
      <Icon name="moon" size={12} />
    </span>
    <span class="theme-toggle__thumb"></span>
  </span>
</button>

<style>
  .theme-toggle {
    /* Sizing tokens */
    --tt-h: 1.75rem;          /* track height */
    --tt-w: 3.25rem;          /* track width  */
    --tt-pad: 0.2rem;         /* inner padding */
    --tt-thumb: calc(var(--tt-h) - var(--tt-pad) * 2); /* perfect circle thumb */

    /* Layout */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--tt-w);
    min-width: var(--tt-w);
    height: var(--tt-h);
    min-height: var(--tt-h);
    padding: 0;

    /* Glass pill shell */
    border-radius: 99px;
    border: 1px solid color-mix(in srgb, var(--ink) 14%, transparent);
    background: color-mix(in srgb, var(--paper) 70%, transparent);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    backdrop-filter: blur(16px) saturate(1.4);
    box-shadow:
      0 1px 3px -1px rgba(0,0,0,0.14),
      0 1px 0 color-mix(in srgb,#fff 40%,transparent) inset;

    cursor: pointer;
    touch-action: manipulation;

    transition:
      border-color 200ms ease,
      background 200ms ease,
      box-shadow 200ms ease,
      transform 100ms ease;
  }

  .theme-toggle:hover {
    border-color: color-mix(in srgb, var(--amber) 50%, transparent);
    box-shadow:
      0 2px 8px -2px color-mix(in srgb, var(--amber) 20%, transparent),
      0 1px 0 color-mix(in srgb,#fff 40%,transparent) inset;
  }

  .theme-toggle:active {
    transform: scale(0.95);
  }

  .theme-toggle:focus {
    outline: none;
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 3px;
  }

  /* ── Track ── */
  .theme-toggle__track {
    position: relative;
    width: calc(var(--tt-w) - 2px); /* account for border */
    height: calc(var(--tt-h) - 2px);
    border-radius: 99px;
    overflow: visible;
  }

  /* ── Icons ── */
  .theme-toggle__icon {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: calc(var(--tt-w) / 2 - 1px);
    pointer-events: none;
    transition:
      opacity 200ms ease,
      color 200ms ease;
  }

  .theme-toggle__icon--sun {
    left: 0;
    color: color-mix(in srgb, var(--ink) 75%, transparent);
  }

  .theme-toggle__icon--moon {
    right: 0;
    color: color-mix(in srgb, var(--ink) 50%, transparent);
  }

  /* ── Thumb ── */
  .theme-toggle__thumb {
    position: absolute;
    top: var(--tt-pad);
    left: var(--tt-pad);
    z-index: 3;
    width: var(--tt-thumb);
    height: var(--tt-thumb);
    border-radius: 50%;
    background: var(--amber);
    box-shadow:
      0 2px 8px -2px color-mix(in srgb, var(--amber-deep) 60%, transparent),
      0 1px 0 color-mix(in srgb,#fff 28%,transparent) inset;
    transition: transform 280ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* ── Dark mode states ── */
  html[data-theme="dark"] .theme-toggle__thumb {
    transform: translateX(calc(var(--tt-w) / 2 - var(--tt-pad) - 1px));
    background: var(--amber);
  }

  html[data-theme="dark"] .theme-toggle {
    border-color: color-mix(in srgb, var(--on-ink) 16%, transparent);
    background: color-mix(in srgb, var(--ink-band) 68%, transparent);
    box-shadow:
      0 1px 3px -1px rgba(0,0,0,0.3),
      0 1px 0 color-mix(in srgb,#fff 8%,transparent) inset;
  }

  html[data-theme="dark"] .theme-toggle__icon--sun {
    color: color-mix(in srgb, var(--on-ink) 45%, transparent);
  }

  html[data-theme="dark"] .theme-toggle__icon--moon {
    color: var(--on-ink);
  }

  html[data-theme="dark"] .theme-toggle:hover {
    border-color: color-mix(in srgb, var(--amber) 55%, transparent);
  }
</style>

<script>
  if (!(window as any).__rcThemeToggleMounted) {
    (window as any).__rcThemeToggleMounted = true;

    const storageKey = "rc_theme";
    const toggles = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");

    const getTheme = () =>
      document.documentElement.dataset.theme === "dark" ? "dark" : "light";

    const syncToggles = () => {
      const isDark = getTheme() === "dark";
      for (const toggle of toggles) {
        toggle.setAttribute("aria-pressed", String(isDark));
        toggle.setAttribute("aria-label", isDark ? "Açık temaya geç" : "Koyu temaya geç");
      }
    };

    const setTheme = (theme: "light" | "dark") => {
      document.documentElement.dataset.theme = theme;
      try {
        localStorage.setItem(storageKey, theme);
      } catch (e) {}
      syncToggles();
    };

    syncToggles();

    for (const toggle of toggles) {
      toggle.addEventListener("click", () => {
        setTheme(getTheme() === "dark" ? "light" : "dark");
      });
    }
  }
</script>
