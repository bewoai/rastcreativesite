---
import Icon from "./Icon.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<button
  class:list={["theme-toggle", className]}
  type="button"
  aria-label="Koyu temaya geç"
  aria-pressed="false"
  data-theme-toggle
>
  <!-- Sun icon (left half) -->
  <span class="tt-icon tt-icon--sun" aria-hidden="true">
    <Icon name="sun" size={12} />
  </span>

  <!-- Sliding thumb -->
  <span class="tt-thumb" aria-hidden="true"></span>

  <!-- Moon icon (right half) -->
  <span class="tt-icon tt-icon--moon" aria-hidden="true">
    <Icon name="moon" size={11} />
  </span>
</button>

<style>
  /*
   * W = 2H ensures thumb is perfectly centered over each icon:
   *   Light:  thumb-center = H/2 = W/4  ✓
   *   Dark:   thumb-center = H/2 + H = 3H/2 = 3W/4  ✓
   */
  .theme-toggle {
    --tt-h: 1.75rem;          /* height */
    --tt-w: 3.5rem;           /* width = 2 × height */
    --tt-pad: 3px;            /* gap around thumb */

    /* Reset */
    appearance: none;
    -webkit-appearance: none;
    margin: 0;
    padding: 0;
    border: none;

    /* Pill shape — overflow:hidden clips the thumb cleanly */
    position: relative;
    display: inline-flex;
    align-items: center;
    width: var(--tt-w);
    height: var(--tt-h);
    flex-shrink: 0;
    border-radius: 99px;
    overflow: hidden;

    /* Glass background */
    background: color-mix(in srgb, var(--paper) 55%, transparent);
    outline: 1.5px solid color-mix(in srgb, var(--ink) 14%, transparent);
    outline-offset: -1.5px;
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    backdrop-filter: blur(16px) saturate(1.4);
    box-shadow:
      0 1px 4px -1px rgba(0,0,0,0.16),
      0 1px 0 color-mix(in srgb, #fff 35%, transparent) inset;

    cursor: pointer;
    touch-action: manipulation;
    transition:
      outline-color 200ms ease,
      background 200ms ease,
      box-shadow 200ms ease,
      transform 120ms ease;
  }

  .theme-toggle:hover {
    outline-color: color-mix(in srgb, var(--amber) 45%, transparent);
    box-shadow:
      0 2px 10px -3px color-mix(in srgb, var(--amber) 22%, transparent),
      0 1px 0 color-mix(in srgb, #fff 35%, transparent) inset;
  }

  .theme-toggle:active  { transform: scale(0.94); }
  .theme-toggle:focus   { outline: none; }
  .theme-toggle:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 3px;
    overflow: visible;
  }

  /* ── Icons: each sits in exactly one half ── */
  .tt-icon {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50%;
    height: 100%;
    flex-shrink: 0;
    pointer-events: none;
    transition: color 220ms ease;
  }

  .tt-icon--sun  { color: color-mix(in srgb, var(--ink) 70%, transparent); }
  .tt-icon--moon { color: color-mix(in srgb, var(--ink) 45%, transparent); }

  /* ── Thumb: diameter = H - 2×pad, slides by exactly H (= W/2) ── */
  .tt-thumb {
    position: absolute;
    top: var(--tt-pad);
    left: var(--tt-pad);
    width: calc(var(--tt-h) - 2 * var(--tt-pad));
    height: calc(var(--tt-h) - 2 * var(--tt-pad));
    z-index: 3;
    border-radius: 50%;
    background: var(--amber);
    box-shadow:
      0 2px 8px -2px color-mix(in srgb, var(--amber-deep) 60%, transparent),
      0 1px 0 color-mix(in srgb, #fff 30%, transparent) inset;
    transition: transform 270ms cubic-bezier(0.34, 1.4, 0.64, 1);
  }

  /* Dark: slide right by exactly H — centres thumb over moon icon */
  html[data-theme="dark"] .tt-thumb {
    transform: translateX(var(--tt-h));
  }

  /* ── Dark mode colours ── */
  html[data-theme="dark"] .theme-toggle {
    background: color-mix(in srgb, var(--ink-band) 65%, transparent);
    outline-color: color-mix(in srgb, var(--on-ink) 15%, transparent);
    box-shadow:
      0 1px 5px -1px rgba(0,0,0,0.32),
      0 1px 0 color-mix(in srgb, #fff 7%, transparent) inset;
  }

  html[data-theme="dark"] .tt-icon--sun  {
    color: color-mix(in srgb, var(--on-ink) 35%, transparent);
  }
  html[data-theme="dark"] .tt-icon--moon {
    color: var(--on-ink);
  }
</style>

<script>
  if (!(window as any).__rcThemeToggleMounted) {
    (window as any).__rcThemeToggleMounted = true;

    const storageKey = "rc_theme";
    const toggles = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");

    const getTheme = () =>
      document.documentElement.dataset.theme === "dark" ? "dark" : "light";

    const syncToggles = () => {
      const isDark = getTheme() === "dark";
      for (const t of toggles) {
        t.setAttribute("aria-pressed", String(isDark));
        t.setAttribute("aria-label", isDark ? "Açık temaya geç" : "Koyu temaya geç");
      }
    };

    const setTheme = (theme: "light" | "dark") => {
      document.documentElement.dataset.theme = theme;
      try { localStorage.setItem(storageKey, theme); } catch {}
      syncToggles();
    };

    syncToggles();

    for (const t of toggles) {
      t.addEventListener("click", () => {
        setTheme(getTheme() === "dark" ? "light" : "dark");
      });
    }
  }
</script>
