---
import Icon from "./Icon.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<button
  class:list={["theme-toggle", className]}
  type="button"
  aria-label="Koyu temaya geç"
  aria-pressed="false"
  data-theme-toggle
>
  <span class="theme-toggle__track" aria-hidden="true">
    <span class="theme-toggle__icon theme-toggle__icon--sun">
      <Icon name="sun" size={13} />
    </span>
    <span class="theme-toggle__icon theme-toggle__icon--moon">
      <Icon name="moon" size={12} />
    </span>
    <span class="theme-toggle__thumb"></span>
  </span>
</button>

<style>
  .theme-toggle {
    /* Sizing — all derived from these two values */
    --tt-w: 3.25rem;
    --tt-h: 1.75rem;
    --tt-pad: 3px;

    /* Reset browser button defaults */
    appearance: none;
    -webkit-appearance: none;
    margin: 0;
    padding: 0;
    line-height: 1;

    /* Fixed size */
    display: block;
    width: var(--tt-w);
    height: var(--tt-h);
    flex-shrink: 0;

    /* Glass pill */
    border-radius: 99px;
    border: 1.5px solid color-mix(in srgb, var(--ink) 14%, transparent);
    background: color-mix(in srgb, var(--paper) 70%, transparent);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    backdrop-filter: blur(16px) saturate(1.4);
    box-shadow:
      0 1px 3px -1px rgba(0,0,0,0.14),
      0 1px 0 color-mix(in srgb, #fff 40%, transparent) inset;

    cursor: pointer;
    touch-action: manipulation;
    transition:
      border-color 200ms ease,
      background 200ms ease,
      box-shadow 200ms ease,
      transform 100ms ease;
  }

  .theme-toggle:hover {
    border-color: color-mix(in srgb, var(--amber) 50%, transparent);
    box-shadow:
      0 2px 8px -2px color-mix(in srgb, var(--amber) 20%, transparent),
      0 1px 0 color-mix(in srgb, #fff 40%, transparent) inset;
  }

  .theme-toggle:active  { transform: scale(0.95); }
  .theme-toggle:focus   { outline: none; }
  .theme-toggle:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 3px;
  }

  /* ── Track: fills the full interior of the button ── */
  .theme-toggle__track {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 99px;
  }

  /* ── Icons: vertically centered with absolute positioning ── */
  .theme-toggle__icon {
    position: absolute;
    top: 0;
    bottom: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50%;
    pointer-events: none;
    transition: opacity 200ms ease, color 200ms ease;
  }

  .theme-toggle__icon--sun {
    left: 0;
    color: color-mix(in srgb, var(--ink) 75%, transparent);
  }

  .theme-toggle__icon--moon {
    right: 0;
    left: auto;
    color: color-mix(in srgb, var(--ink) 50%, transparent);
  }

  /* ── Thumb: perfect circle, padded from all edges ── */
  .theme-toggle__thumb {
    position: absolute;
    top: var(--tt-pad);
    bottom: var(--tt-pad);
    left: var(--tt-pad);
    /* Width auto-matches height for perfect circle */
    aspect-ratio: 1;
    z-index: 3;
    border-radius: 50%;
    background: var(--amber);
    box-shadow:
      0 2px 6px -1px color-mix(in srgb, var(--amber-deep) 55%, transparent),
      0 1px 0 color-mix(in srgb, #fff 28%, transparent) inset;
    transition: transform 280ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* ── Dark: slide thumb to right side ── */
  html[data-theme="dark"] .theme-toggle__thumb {
    /* Move right by: (total width) - (thumb size) - (right pad) - (left pad) */
    /* Since thumb uses left+top+bottom+aspect-ratio, offset = tt-w - tt-h + (2*pad) */
    transform: translateX(calc(var(--tt-w) - var(--tt-h) + var(--tt-pad)));
  }

  html[data-theme="dark"] .theme-toggle {
    border-color: color-mix(in srgb, var(--on-ink) 16%, transparent);
    background: color-mix(in srgb, var(--ink-band) 68%, transparent);
    box-shadow:
      0 1px 4px -1px rgba(0,0,0,0.3),
      0 1px 0 color-mix(in srgb, #fff 8%, transparent) inset;
  }

  html[data-theme="dark"] .theme-toggle__icon--sun {
    color: color-mix(in srgb, var(--on-ink) 40%, transparent);
  }

  html[data-theme="dark"] .theme-toggle__icon--moon {
    color: var(--on-ink);
  }

  html[data-theme="dark"] .theme-toggle:hover {
    border-color: color-mix(in srgb, var(--amber) 55%, transparent);
  }
</style>

<script>
  if (!(window as any).__rcThemeToggleMounted) {
    (window as any).__rcThemeToggleMounted = true;

    const storageKey = "rc_theme";
    const toggles = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");

    const getTheme = () =>
      document.documentElement.dataset.theme === "dark" ? "dark" : "light";

    const syncToggles = () => {
      const isDark = getTheme() === "dark";
      for (const toggle of toggles) {
        toggle.setAttribute("aria-pressed", String(isDark));
        toggle.setAttribute("aria-label", isDark ? "Açık temaya geç" : "Koyu temaya geç");
      }
    };

    const setTheme = (theme: "light" | "dark") => {
      document.documentElement.dataset.theme = theme;
      try { localStorage.setItem(storageKey, theme); } catch (e) {}
      syncToggles();
    };

    syncToggles();

    for (const toggle of toggles) {
      toggle.addEventListener("click", () => {
        setTheme(getTheme() === "dark" ? "light" : "dark");
      });
    }
  }
</script>
