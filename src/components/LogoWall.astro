---
/**
 * Client logo wall ("trusted by") as a seamless marquee. Chips keep the quiet
 * grayscale → colour-on-hover treatment (roadmap §2.3); the track auto-scrolls,
 * pauses on hover, fades at both edges, and falls back to a manual-scroll strip
 * when the visitor prefers reduced motion. The set is duplicated for a seamless
 * loop — the second copy is aria-hidden so screen readers read each brand once.
 */
import { Image } from "astro:assets";
import adatip from "../assets/logos/adatip.png";
import altoteks from "../assets/logos/altoteks.png";
import aytashome from "../assets/logos/aytashome.png";
import basak from "../assets/logos/basak.png";
import buyapi from "../assets/logos/buyapi.png";
import canex from "../assets/logos/canex.jpg";
import chint from "../assets/logos/chint.webp";
import estada from "../assets/logos/estada.png";
import isitan from "../assets/logos/isitan.webp";
import meteors from "../assets/logos/meteors.png";
import newlife from "../assets/logos/newlife.png";
import oyka from "../assets/logos/oyka.png";
import serdivan from "../assets/logos/serdivan.jpg";
import thermoway from "../assets/logos/thermoway.png";
import zeminkoleji from "../assets/logos/zeminkoleji.avif";
import federal from "../assets/logos/federal.svg";
import allufem from "../assets/logos/allufem-aluminium.webp";

const logos = [
  { src: federal, name: "Federal", dark: false },
  { src: allufem, name: "Allufem Aluminium", dark: true, big: true },
  { src: adatip, name: "Adatıp Hastanesi", dark: false },
  { src: serdivan, name: "Serdivan AVM", dark: false, big: true },
  { src: aytashome, name: "Aytaş Home", dark: false },
  { src: meteors, name: "Meteors Shipping", dark: false },
  { src: oyka, name: "Oyka Kağıt Ambalaj", dark: false },
  { src: thermoway, name: "ThermoWay", dark: false },
  { src: estada, name: "Estada Hair Transplant", dark: false },
  { src: isitan, name: "Isıtan Isı Kontrol Sistemleri", dark: false },
  { src: zeminkoleji, name: "Zemin Koleji", dark: false, big: true },
  { src: buyapi, name: "Buyapı", dark: false },
  { src: basak, name: "Başak Traktör", dark: false },
  { src: canex, name: "Canex", dark: false },
  { src: chint, name: "Chint Power", dark: false },
  { src: newlife, name: "New Life", dark: true, big: true },
  { src: altoteks, name: "Altoteks", dark: true },
];
---

<div class="marquee" role="group" aria-label="Çalıştığımız markalar" data-logo-wall>
  <ul class="marquee__track" data-logo-track>
    {
      logos.map((l) => (
        <li class:list={["logo-chip", { "logo-chip--dark": l.dark }]}>
          <Image
            src={l.src}
            alt={`${l.name} logosu`}
            height={l.big ? 64 : 44}
            densities={[1.5, 2]}
            quality={72}
            loading="lazy"
            draggable={false}
            class:list={["logo-chip__img", { "logo-chip__img--big": l.big }]}
          />
        </li>
      ))
    }
    {
      logos.map((l) => (
        <li class:list={["logo-chip", { "logo-chip--dark": l.dark }]} aria-hidden="true">
          <Image
            src={l.src}
            alt={`${l.name} logosu`}
            height={l.big ? 64 : 44}
            densities={[1.5, 2]}
            quality={72}
            loading="lazy"
            draggable={false}
            class:list={["logo-chip__img", { "logo-chip__img--big": l.big }]}
          />
        </li>
      ))
    }
  </ul>
</div>

<style>
  .marquee {
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    cursor: grab;
    overscroll-behavior-inline: contain;
    scrollbar-width: none;
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
    -webkit-touch-callout: none;
    /* Soft fade at both edges so chips slide in/out instead of cutting off. */
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
  }
  .marquee::-webkit-scrollbar {
    display: none;
  }
  .marquee.is-dragging {
    cursor: grabbing;
  }
  .marquee__track {
    list-style: none;
    margin: 1.6rem 0 0;
    padding: 0.5rem 0; /* room for the hover lift */
    display: flex;
    width: max-content;
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  .logo-chip {
    flex: 0 0 auto;
    width: clamp(8.5rem, 30vw, 10.5rem);
    margin-right: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.1rem;
    min-height: 5.6rem;
    background: #ffffff;
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    user-select: none;
    -webkit-user-select: none;
    -webkit-user-drag: none;
    transition:
      box-shadow var(--dur-fast, 0.2s) var(--ease-out, ease),
      border-color var(--dur-fast, 0.2s) var(--ease-out, ease);
  }
  .logo-chip--dark {
    background: var(--ink);
    border-color: color-mix(in srgb, #ffffff 12%, transparent);
  }
  .logo-chip__img {
    width: auto;
    height: auto;
    max-height: 3rem;
    max-width: 100%;
    object-fit: contain;
    pointer-events: none;
    user-select: none;
    -webkit-user-select: none;
    -webkit-user-drag: none;
    /* Quiet black & white by default; full colour on hover. */
    filter: grayscale(1);
    opacity: 0.82;
    transition:
      filter var(--dur-fast, 0.2s) var(--ease-out, ease),
      opacity var(--dur-fast, 0.2s) var(--ease-out, ease);
  }
  /* Marks with lots of internal whitespace or a small footprint read bigger. */
  .logo-chip__img--big {
    max-height: 3.9rem;
  }
  .logo-chip:hover {
    border-color: color-mix(in srgb, var(--amber) 35%, var(--line));
    box-shadow: 0 6px 20px -8px color-mix(in srgb, var(--ink) 18%, transparent);
  }
  .logo-chip:hover .logo-chip__img {
    filter: grayscale(0);
    opacity: 1;
  }

  /* Reduced motion: stop the auto-scroll, let the visitor swipe through. */
  @media (prefers-reduced-motion: reduce) {
    .logo-chip,
    .logo-chip__img {
      transition: none;
    }
  }
</style>

<script>
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  document.querySelectorAll<HTMLElement>("[data-logo-wall]").forEach((wall) => {
    const track = wall.querySelector<HTMLElement>("[data-logo-track]");
    if (!track) return;

    let frame = 0;
    let lastTime = 0;
    let isHovering = false;
    let isDragging = false;
    let startX = 0;
    let startScrollLeft = 0;
    let loopWidth = 0;
    let wallWidth = 0;

    const shouldAutoScroll = () => !prefersReducedMotion.matches && !isHovering && !isDragging;
    const measure = () => {
      loopWidth = track.scrollWidth / 2;
      wallWidth = wall.clientWidth;
    };

    const normalizeScroll = () => {
      if (loopWidth <= wallWidth) return;

      if (wall.scrollLeft >= loopWidth) {
        wall.scrollLeft -= loopWidth;
      } else if (wall.scrollLeft <= 0 && isDragging) {
        wall.scrollLeft += loopWidth;
        startScrollLeft += loopWidth;
      }
    };

    const tick = (time: number) => {
      if (!lastTime) lastTime = time;
      const elapsed = time - lastTime;
      lastTime = time;

      if (shouldAutoScroll()) {
        wall.scrollLeft += (loopWidth / 42000) * elapsed;
        normalizeScroll();
      }

      frame = window.requestAnimationFrame(tick);
    };

    const stopDragging = () => {
      if (!isDragging) return;
      isDragging = false;
      wall.classList.remove("is-dragging");
      normalizeScroll();
    };

    wall.addEventListener("pointerenter", () => {
      isHovering = true;
    });

    wall.addEventListener("pointerleave", () => {
      isHovering = false;
      stopDragging();
    });

    wall.addEventListener("pointerdown", (event) => {
      if (event.button !== 0) return;

      isDragging = true;
      startX = event.clientX;
      startScrollLeft = wall.scrollLeft;
      wall.classList.add("is-dragging");
      wall.setPointerCapture(event.pointerId);
      event.preventDefault();
    });

    wall.addEventListener("pointermove", (event) => {
      if (!isDragging) return;

      wall.scrollLeft = startScrollLeft - (event.clientX - startX);
      normalizeScroll();
    });

    wall.addEventListener("pointerup", stopDragging);
    wall.addEventListener("pointercancel", stopDragging);
    wall.addEventListener("dragstart", (event) => event.preventDefault());
    wall.addEventListener("contextmenu", (event) => event.preventDefault());

    measure();
    const resizeObserver = "ResizeObserver" in window ? new ResizeObserver(measure) : null;
    resizeObserver?.observe(wall);
    resizeObserver?.observe(track);
    window.addEventListener("load", measure, { once: true });
    window.addEventListener("resize", measure, { passive: true });

    frame = window.requestAnimationFrame(tick);

    window.addEventListener(
      "pagehide",
      () => {
        window.cancelAnimationFrame(frame);
        resizeObserver?.disconnect();
      },
      { once: true },
    );
  });
</script>
