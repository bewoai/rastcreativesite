---
/**
 * Clapperboard — true 3D scroll-driven background decoration.
 * Built with CSS 3D transforms (preserve-3d) for real depth.
 * Starts open, rotates in 3D space as user scrolls, closes at the
 * contact section where a CTA button appears on the board surface.
 */
import { PRIMARY_CTA } from "../consts";
---

<div class="clapper-scene" aria-hidden="true" data-clapper-scene>
  <div class="clapper" data-clapper>
    {/* ── Hinged top bar (arm) ─────────────────────────────── */}
    <div class="clapper__arm" data-clapper-arm>
      <div class="clapper__arm-face clapper__arm-front">
        <div class="arm-stripes">
          <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
        </div>
      </div>
      <div class="clapper__arm-face clapper__arm-top"></div>
      <div class="clapper__arm-face clapper__arm-bottom"></div>
    </div>

    {/* ── Board body ──────────────────────────────────────── */}
    <div class="clapper__body">
      <div class="clapper__body-face clapper__body-front">
        {/* Brand info on the board */}
        <div class="board-fields">
          <div class="board-row">
            <span class="board-label">PRODUCTION</span>
            <span class="board-value">Rast Creative Studio</span>
          </div>
          <div class="board-row">
            <span class="board-label">DIRECTOR</span>
            <span class="board-value">Kreatif Ekip</span>
          </div>
          <div class="board-row">
            <span class="board-label">PROJECT</span>
            <span class="board-value">Markanızın Hikâyesi</span>
          </div>
          <div class="board-row board-row--half">
            <div>
              <span class="board-label">SCENE</span>
              <span class="board-value">01</span>
            </div>
            <div>
              <span class="board-label">TAKE</span>
              <span class="board-value">01</span>
            </div>
            <div>
              <span class="board-label">DATE</span>
              <span class="board-value">2026</span>
            </div>
          </div>
        </div>

        {/* CTA appears when clapperboard is closed */}
        <div class="board-cta" data-clapper-cta>
          <a href={PRIMARY_CTA.href} class="board-cta__btn" aria-hidden="true" tabindex="-1">
            {PRIMARY_CTA.label}
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
      <div class="clapper__body-face clapper__body-top"></div>
      <div class="clapper__body-face clapper__body-right"></div>
      <div class="clapper__body-face clapper__body-left"></div>
      <div class="clapper__body-face clapper__body-bottom"></div>
    </div>
  </div>
</div>

<style>
  /* ── Scene: full-viewport container with perspective ────────────── */
  .clapper-scene {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    perspective: 1200px;
    perspective-origin: 50% 45%;
    overflow: hidden;
  }

  /* ── Main 3D object ─────────────────────────────────────────────── */
  .clapper {
    position: absolute;
    top: 50%;
    left: 50%;
    width: clamp(260px, 42vw, 440px);
    transform-style: preserve-3d;
    /* Initial: centered, slight tilt, open */
    transform:
      translate(-50%, -50%)
      rotateX(-12deg)
      rotateY(18deg)
      rotateZ(2deg);
  }

  /* ── Arm (hinged top bar) ───────────────────────────────────────── */
  .clapper__arm {
    position: relative;
    width: 100%;
    height: clamp(36px, 5.5vw, 52px);
    transform-style: preserve-3d;
    transform-origin: 0% 100%;
    /* Start open */
    transform: rotateX(-50deg);
  }

  .clapper__arm-face {
    position: absolute;
    backface-visibility: hidden;
  }

  .clapper__arm-front {
    width: 100%;
    height: 100%;
    background: #0a0a0a;
    border-radius: 6px 6px 0 0;
    overflow: hidden;
  }

  /* Diagonal stripes */
  .arm-stripes {
    display: flex;
    width: 100%;
    height: 100%;
  }
  .arm-stripes span {
    flex: 1;
    background: repeating-linear-gradient(
      -65deg,
      #0a0a0a 0px,
      #0a0a0a 12px,
      #f5f4f0 12px,
      #f5f4f0 24px
    );
  }

  /* Top edge — gives thickness */
  .clapper__arm-top {
    width: 100%;
    height: 8px;
    background: #1a1a1a;
    transform-origin: bottom;
    transform: rotateX(90deg) translateZ(0px);
    top: -8px;
    border-radius: 6px 6px 0 0;
  }

  /* Bottom edge — gives thickness */
  .clapper__arm-bottom {
    width: 100%;
    height: 8px;
    background: #050505;
    transform-origin: top;
    transform: rotateX(-90deg);
    bottom: -8px;
  }

  /* ── Board body ─────────────────────────────────────────────────── */
  .clapper__body {
    position: relative;
    width: 100%;
    aspect-ratio: 1.45 / 1;
    transform-style: preserve-3d;
  }

  .clapper__body-face {
    position: absolute;
    backface-visibility: hidden;
  }

  .clapper__body-front {
    width: 100%;
    height: 100%;
    background: linear-gradient(170deg, #141414 0%, #0a0a0a 100%);
    border-radius: 0 0 8px 8px;
    padding: clamp(14px, 3vw, 24px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
  }

  /* Top thickness */
  .clapper__body-top {
    width: 100%;
    height: 10px;
    background: #1a1a1a;
    transform-origin: bottom;
    transform: rotateX(90deg);
    top: 0;
  }

  /* Right side */
  .clapper__body-right {
    width: 10px;
    height: 100%;
    background: #0d0d0d;
    transform-origin: left;
    transform: rotateY(90deg);
    right: -10px;
    top: 0;
    border-radius: 0 4px 4px 0;
  }

  /* Left side */
  .clapper__body-left {
    width: 10px;
    height: 100%;
    background: #181818;
    transform-origin: right;
    transform: rotateY(-90deg);
    left: -10px;
    top: 0;
    border-radius: 4px 0 0 4px;
  }

  /* Bottom edge */
  .clapper__body-bottom {
    width: 100%;
    height: 10px;
    background: #080808;
    transform-origin: top;
    transform: rotateX(-90deg);
    bottom: -10px;
    border-radius: 0 0 8px 8px;
  }

  /* ── Board text fields ──────────────────────────────────────────── */
  .board-fields {
    display: flex;
    flex-direction: column;
    gap: clamp(6px, 1.5vw, 12px);
  }

  .board-row {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-bottom: clamp(6px, 1.2vw, 10px);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .board-row--half {
    flex-direction: row;
    gap: clamp(12px, 3vw, 24px);
    border-bottom: none;
  }
  .board-row--half > div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .board-label {
    font-family: var(--font-utility, monospace);
    font-size: clamp(0.5rem, 1.1vw, 0.7rem);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  .board-value {
    font-family: var(--font-utility, monospace);
    font-size: clamp(0.7rem, 1.6vw, 1rem);
    font-weight: 500;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.02em;
  }

  /* ── CTA Button (hidden until closed) ───────────────────────────── */
  .board-cta {
    display: flex;
    justify-content: center;
    margin-top: auto;
    opacity: 0;
    transform: translateY(8px) scale(0.95);
    transition:
      opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }

  .board-cta.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .board-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    background: linear-gradient(135deg, var(--amber, #E25303), var(--amber-deep, #B84203));
    color: #fff;
    border-radius: 999px;
    font-family: var(--font-utility, system-ui);
    font-size: clamp(0.8rem, 1.4vw, 0.95rem);
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    pointer-events: auto;
    box-shadow:
      0 0 24px -4px rgba(226, 83, 3, 0.5),
      0 4px 12px -2px rgba(0,0,0,0.3);
    transition:
      box-shadow 0.3s ease,
      transform 0.2s ease;
  }
  .board-cta__btn:hover {
    box-shadow:
      0 0 36px -4px rgba(226, 83, 3, 0.65),
      0 6px 20px -4px rgba(0,0,0,0.35);
    transform: scale(1.04);
  }

  @media (prefers-reduced-motion: reduce) {
    .clapper-scene {
      display: none;
    }
  }
</style>

<script>
  const scene = document.querySelector<HTMLElement>('[data-clapper-scene]');
  const clapper = document.querySelector<HTMLElement>('[data-clapper]');
  const arm = document.querySelector<HTMLElement>('[data-clapper-arm]');
  const cta = document.querySelector<HTMLElement>('[data-clapper-cta]');

  if (scene && clapper && arm) {
    let ticking = false;

    // Smooth ease-in-out cubic
    const easeInOut = (t: number): number =>
      t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;

    const update = () => {
      const scrollY = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const raw = Math.min(1, Math.max(0, scrollY / Math.max(docHeight, 1)));
      const p = easeInOut(raw);

      // ── 3D Rotation: cinematic orbit around the clapperboard ──
      // X-axis: starts tilted back (-12°), tilts forward to face viewer
      const rx = -12 + p * 24;
      // Y-axis: gentle orbital sweep (18° → -15° → back)
      const ry = 18 - p * 33;
      // Z-axis: subtle wobble
      const rz = 2 + Math.sin(p * Math.PI * 2) * 4;

      // ── Scale: slightly grows as it comes toward viewer ──
      const scale = 1 + p * 0.08;

      clapper.style.transform = `
        translate(-50%, -50%)
        rotateX(${rx}deg)
        rotateY(${ry}deg)
        rotateZ(${rz}deg)
        scale3d(${scale}, ${scale}, ${scale})
      `;

      // ── Arm: open (rotated up -50°) → closed (0°) ──
      const armAngle = -50 * (1 - p);
      arm.style.transform = `rotateX(${armAngle}deg)`;

      // ── Opacity: subtle at start, slightly more visible mid-scroll ──
      const opacity = 0.13 + Math.sin(p * Math.PI) * 0.07;
      scene.style.opacity = String(opacity);

      // ── CTA: show when nearly closed (>90%) ──
      if (cta) {
        const isClosed = p > 0.88;
        cta.classList.toggle('is-visible', isClosed);
        // Make clapperboard more visible when CTA is showing
        if (isClosed) {
          scene.style.opacity = String(0.28);
        }
      }

      ticking = false;
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };

    update();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
