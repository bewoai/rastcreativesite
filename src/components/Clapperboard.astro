---
/**
 * Clapperboard — scroll-driven 3D background decoration.
 * Starts top-left (open), moves to bottom-left while doing a full 3D
 * 360° rotation as the user scrolls. Ease-in-out timing.
 */
---

<div class="clapper" aria-hidden="true" data-clapper>
  {/* Top bar (the hinged arm that swings closed) */}
  <svg class="clapper__top" viewBox="0 0 600 80" preserveAspectRatio="none">
    <rect width="600" height="80" fill="#111110" rx="8"/>
    {/* Diagonal stripes */}
    <g>
      <rect x="40" y="0" width="40" height="80" fill="#FAF9F6" opacity="0.92" transform="skewX(-15)"/>
      <rect x="120" y="0" width="40" height="80" fill="#FAF9F6" opacity="0.92" transform="skewX(-15)"/>
      <rect x="200" y="0" width="40" height="80" fill="#FAF9F6" opacity="0.92" transform="skewX(-15)"/>
      <rect x="280" y="0" width="40" height="80" fill="#FAF9F6" opacity="0.92" transform="skewX(-15)"/>
      <rect x="360" y="0" width="40" height="80" fill="#FAF9F6" opacity="0.92" transform="skewX(-15)"/>
      <rect x="440" y="0" width="40" height="80" fill="#FAF9F6" opacity="0.92" transform="skewX(-15)"/>
      <rect x="520" y="0" width="40" height="80" fill="#FAF9F6" opacity="0.92" transform="skewX(-15)"/>
    </g>
    {/* Hinge circle */}
    <circle cx="28" cy="40" r="12" fill="#E25303"/>
  </svg>

  {/* Bottom board */}
  <svg class="clapper__board" viewBox="0 0 600 400" preserveAspectRatio="none">
    <rect width="600" height="400" fill="#111110" rx="8"/>
    {/* Field lines */}
    <g stroke="#FAF9F6" stroke-width="1.5" opacity="0.2">
      <line x1="40" y1="70" x2="560" y2="70"/>
      <line x1="40" y1="140" x2="560" y2="140"/>
      <line x1="40" y1="210" x2="560" y2="210"/>
      <line x1="40" y1="280" x2="560" y2="280"/>
      <line x1="300" y1="30" x2="300" y2="350"/>
    </g>
    {/* Labels */}
    <text x="50" y="55" fill="#FAF9F6" opacity="0.3" font-family="monospace" font-size="16" font-weight="700" letter-spacing="0.15em">PRODUCTION</text>
    <text x="50" y="125" fill="#FAF9F6" opacity="0.3" font-family="monospace" font-size="16" font-weight="700" letter-spacing="0.15em">DIRECTOR</text>
    <text x="50" y="195" fill="#FAF9F6" opacity="0.3" font-family="monospace" font-size="16" font-weight="700" letter-spacing="0.15em">CAMERA</text>
    <text x="50" y="265" fill="#FAF9F6" opacity="0.3" font-family="monospace" font-size="16" font-weight="700" letter-spacing="0.15em">DATE</text>
    <text x="320" y="55" fill="#FAF9F6" opacity="0.3" font-family="monospace" font-size="16" font-weight="700" letter-spacing="0.15em">SCENE</text>
    <text x="320" y="125" fill="#FAF9F6" opacity="0.3" font-family="monospace" font-size="16" font-weight="700" letter-spacing="0.15em">TAKE</text>
    {/* Rast Creative watermark — very subtle */}
    <text x="300" y="360" fill="#FAF9F6" opacity="0.08" font-family="monospace" font-size="28" font-weight="700" letter-spacing="0.2em" text-anchor="middle">RAST CREATIVE</text>
  </svg>
</div>

<style>
  .clapper {
    position: fixed;
    z-index: -1;
    pointer-events: none;
    width: clamp(220px, 38vw, 400px);

    /* Starting position: top-left area */
    top: 8%;
    left: 6%;

    /* 3D perspective for the rotation */
    perspective: 900px;
    transform-style: preserve-3d;

    opacity: 0.18;
    filter: drop-shadow(0 12px 40px rgba(0,0,0,0.25));
  }

  .clapper__board,
  .clapper__top {
    width: 100%;
    height: auto;
    display: block;
    transform-style: preserve-3d;
  }

  .clapper__top {
    /* Hinge at the left edge, bottom of the arm */
    transform-origin: 4.7% 100%;
  }

  @media (prefers-reduced-motion: reduce) {
    .clapper {
      display: none;
    }
  }

  /* Scale down on small screens */
  @media (max-width: 640px) {
    .clapper {
      width: 180px;
      opacity: 0.12;
      top: 5%;
      left: 3%;
    }
  }
</style>

<script>
  const clapper = document.querySelector<HTMLElement>('[data-clapper]');
  if (clapper) {
    const topBar = clapper.querySelector<SVGElement>('.clapper__top');
    let ticking = false;

    // Ease-in-out function (cubic)
    const easeInOut = (t: number): number => {
      return t < 0.5
        ? 4 * t * t * t
        : 1 - Math.pow(-2 * t + 2, 3) / 2;
    };

    const update = () => {
      const scrollY = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const rawProgress = Math.min(1, Math.max(0, scrollY / Math.max(docHeight, 1)));

      // Apply ease-in-out
      const p = easeInOut(rawProgress);

      // Position: top-left → bottom-left (translate down and slightly inward)
      const translateY = p * 65; // vh units equivalent in percentage
      const translateX = p * 3;  // slight rightward drift

      // 3D rotation: full 360° Y-axis spin + subtle X tilt
      const rotateY = p * 360;
      const rotateX = Math.sin(p * Math.PI) * 15; // peaks at middle, returns to 0
      const rotateZ = p * -8; // subtle clockwise lean

      // Clapper arm: open (-42deg) → closed (0deg)
      const armAngle = -42 + (p * 42);

      // Opacity: start subtle, peak in middle, fade at end
      const opacity = 0.14 + Math.sin(p * Math.PI) * 0.08;

      // Apply transforms
      clapper.style.transform = `
        translate(${translateX}vw, ${translateY}vh)
        rotateY(${rotateY}deg)
        rotateX(${rotateX}deg)
        rotateZ(${rotateZ}deg)
      `;
      clapper.style.opacity = String(opacity);

      if (topBar) {
        topBar.style.transform = `rotate(${armAngle}deg)`;
      }

      ticking = false;
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };

    update();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
