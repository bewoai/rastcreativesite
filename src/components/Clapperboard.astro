---
/**
 * Clapperboard — 3D scroll-driven element.
 *
 * ▸ Arm starts OPEN, gradually CLOSES as user scrolls.
 * ▸ Opacity starts very low (~0.06), increases smoothly as you scroll,
 *   reaches full opacity (1.0) at the final CTA section.
 * ▸ Seamlessly transitions from background decoration → foreground
 *   element docked to the right side of the CTA section.
 * ▸ CTA button on the board is clickable when in foreground.
 */
import { PRIMARY_CTA } from "../consts";
---

<div class="clapper-scene" data-clapper-scene>
  <div class="clapper" data-clapper>
    {/* ── Arm (hinged top bar) ── */}
    <div class="clapper__arm" data-clapper-arm>
      <div class="arm__front">
        <div class="arm__stripes"></div>
      </div>
      <div class="arm__edge"></div>
    </div>

    {/* ── Board body ── */}
    <div class="clapper__body">
      <div class="body__front">
        <div class="board-fields">
          <div class="board-row">
            <span class="board-label">PRODUCTION</span>
            <span class="board-value">Rast Creative Studio</span>
          </div>
          <div class="board-row">
            <span class="board-label">DIRECTOR</span>
            <span class="board-value">Kreatif Ekip</span>
          </div>
          <div class="board-row">
            <span class="board-label">PROJECT</span>
            <span class="board-value">Markanızın Hikâyesi</span>
          </div>
          <div class="board-row board-row--cols">
            <div><span class="board-label">SCENE</span><span class="board-value">01</span></div>
            <div><span class="board-label">TAKE</span><span class="board-value">01</span></div>
            <div><span class="board-label">DATE</span><span class="board-value">2026</span></div>
          </div>
        </div>
        <div class="board-cta" data-clapper-cta>
          <a href={PRIMARY_CTA.href} class="board-cta__btn">
            {PRIMARY_CTA.label}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
      <div class="body__top"></div>
      <div class="body__right"></div>
      <div class="body__left"></div>
      <div class="body__bottom"></div>
    </div>
  </div>
</div>

<style>
  .clapper-scene {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    perspective: 1100px;
    perspective-origin: 50% 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.06;
    /* Smooth ALL transitions */
    transition: opacity 0.15s linear;
  }

  .clapper-scene.is-docked {
    z-index: 55;
  }

  .clapper {
    width: clamp(240px, 36vw, 400px);
    transform-style: preserve-3d;
    filter: drop-shadow(0 16px 48px rgba(0,0,0,0.3));
    transition: filter 0.4s ease;
  }

  /* ── ARM ── */
  .clapper__arm {
    position: relative;
    width: 100%;
    height: clamp(34px, 5vw, 48px);
    transform-style: preserve-3d;
    transform-origin: 50% 100%;
    transform: rotateX(-55deg);
  }

  .arm__front {
    position: absolute;
    width: 100%; height: 100%;
    background: #0a0a0a;
    border-radius: 7px 7px 0 0;
    overflow: hidden;
  }
  .arm__stripes {
    width: 100%; height: 100%;
    background: repeating-linear-gradient(
      -55deg,
      #0a0a0a 0px, #0a0a0a 13px,
      #f0efeb 13px, #f0efeb 26px
    );
  }
  .arm__edge {
    position: absolute;
    width: 100%; height: 10px;
    background: linear-gradient(180deg, #252525, #141414);
    transform-origin: 50% 100%;
    transform: rotateX(90deg);
    top: -10px;
    border-radius: 7px 7px 0 0;
  }

  /* ── BODY ── */
  .clapper__body {
    position: relative;
    width: 100%;
    aspect-ratio: 1.42 / 1;
    transform-style: preserve-3d;
  }

  .body__front {
    position: absolute;
    width: 100%; height: 100%;
    background: linear-gradient(175deg, #151515, #0a0a0a);
    border-radius: 0 0 7px 7px;
    padding: clamp(14px, 3vw, 24px);
    display: flex;
    flex-direction: column;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
  }
  .body__top {
    position: absolute;
    width: 100%; height: 10px;
    background: #1c1c1c;
    transform-origin: 50% 100%;
    transform: rotateX(90deg);
    top: 0;
  }
  .body__right {
    position: absolute;
    width: 10px; height: 100%;
    background: #0f0f0f;
    transform-origin: 0% 50%;
    transform: rotateY(90deg);
    top: 0; right: -10px;
    border-radius: 0 5px 5px 0;
  }
  .body__left {
    position: absolute;
    width: 10px; height: 100%;
    background: #1a1a1a;
    transform-origin: 100% 50%;
    transform: rotateY(-90deg);
    top: 0; left: -10px;
    border-radius: 5px 0 0 5px;
  }
  .body__bottom {
    position: absolute;
    width: 100%; height: 10px;
    background: #080808;
    transform-origin: 50% 0%;
    transform: rotateX(-90deg);
    bottom: -10px;
    border-radius: 0 0 7px 7px;
  }

  /* ── Board text ── */
  .board-fields {
    display: flex;
    flex-direction: column;
    gap: clamp(6px, 1.5vw, 12px);
    flex: 1;
  }
  .board-row {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-bottom: clamp(6px, 1.2vw, 10px);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .board-row--cols {
    flex-direction: row;
    gap: clamp(14px, 3.5vw, 28px);
    border-bottom: none;
    padding-bottom: 0;
  }
  .board-row--cols > div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .board-label {
    font-family: var(--font-utility, monospace);
    font-size: clamp(0.48rem, 1vw, 0.65rem);
    font-weight: 700;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.28);
  }
  .board-value {
    font-family: var(--font-utility, monospace);
    font-size: clamp(0.68rem, 1.4vw, 0.92rem);
    font-weight: 500;
    color: rgba(255,255,255,0.68);
  }

  /* ── CTA button ── */
  .board-cta {
    display: flex;
    justify-content: center;
    margin-top: auto;
    padding-top: clamp(10px, 2vw, 16px);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    pointer-events: none;
  }
  .board-cta.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .board-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    background: linear-gradient(135deg, var(--amber, #E25303), var(--amber-deep, #B84203));
    color: #fff;
    border-radius: 999px;
    font-family: var(--font-utility, system-ui);
    font-size: clamp(0.78rem, 1.3vw, 0.95rem);
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    box-shadow: 0 0 24px -4px rgba(226,83,3,0.5), 0 4px 14px -4px rgba(0,0,0,0.35);
    transition: box-shadow 0.3s ease, transform 0.2s ease;
  }
  .board-cta__btn:hover {
    box-shadow: 0 0 40px -4px rgba(226,83,3,0.65), 0 8px 20px -4px rgba(0,0,0,0.4);
    transform: scale(1.04);
  }
  .board-cta__btn:active { transform: scale(0.97); }

  @media (prefers-reduced-motion: reduce) {
    .clapper-scene { display: none; }
  }
</style>

<script>
  const scene = document.querySelector<HTMLElement>('[data-clapper-scene]');
  const clapper = document.querySelector<HTMLElement>('[data-clapper]');
  const arm = document.querySelector<HTMLElement>('[data-clapper-arm]');
  const cta = document.querySelector<HTMLElement>('[data-clapper-cta]');
  const ctaVisual = document.querySelector<HTMLElement>('.cta-band__visual');

  if (scene && clapper && arm) {
    let ticking = false;

    const ease = (t: number): number =>
      t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;

    // Smooth interpolation helper
    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

    const update = () => {
      const scrollY = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const raw = Math.min(1, Math.max(0, scrollY / Math.max(docHeight, 1)));
      const p = ease(raw);

      // ── ARM: open (-55°) → closed (0°) ──
      const armAngle = lerp(-55, 0, p);
      arm.style.transform = `rotateX(${armAngle}deg)`;

      // ── OPACITY: gradual increase 0.06 → 1.0 ──
      // Non-linear: slow start, accelerates toward the end
      const opacityCurve = Math.pow(p, 1.8);
      const opacity = lerp(0.06, 1.0, opacityCurve);

      // ── Determine dock state ──
      // Start docking transition when visual area is in viewport
      let dockProgress = 0;
      if (ctaVisual) {
        const rect = ctaVisual.getBoundingClientRect();
        const vh = window.innerHeight;
        // dockProgress: 0 (not yet visible) → 1 (fully centered)
        const start = vh * 0.85; // starts entering
        const end = vh * 0.3;   // fully in view
        dockProgress = Math.min(1, Math.max(0, (start - rect.top) / (start - end)));
        dockProgress = ease(dockProgress); // smooth the dock transition too
      }

      const isDocked = dockProgress > 0.05;

      if (isDocked && ctaVisual) {
        // ── DOCKED: smoothly move toward the CTA visual area ──
        scene.classList.add('is-docked');

        const rect = ctaVisual.getBoundingClientRect();
        const targetX = rect.left + rect.width / 2;
        const targetY = rect.top + rect.height / 2;

        // Interpolate from center of viewport to target position
        const cx = window.innerWidth / 2;
        const cy = window.innerHeight / 2;
        const finalX = lerp(cx, targetX, dockProgress);
        const finalY = lerp(cy, targetY, dockProgress);

        // 3D rotation: ease toward flat front-facing
        const rx = lerp(-6 + p * 12, 5, dockProgress);
        const ry = lerp(10 - p * 6, 0, dockProgress);
        const rz = lerp(Math.sin(p * Math.PI) * 3, 0, dockProgress);
        const s = lerp(1 + p * 0.03, 1.0, dockProgress);

        clapper.style.position = 'fixed';
        clapper.style.left = `${finalX}px`;
        clapper.style.top = `${finalY}px`;
        clapper.style.translate = '-50% -50%';
        clapper.style.transform = `
          rotateX(${rx}deg) rotateY(${ry}deg) rotateZ(${rz}deg)
          scale3d(${s},${s},${s})
        `;

        scene.style.opacity = String(Math.min(1, lerp(opacity, 1.0, dockProgress)));
        scene.style.pointerEvents = dockProgress > 0.7 ? 'auto' : 'none';

        // Show CTA button when well docked
        if (cta) {
          const showBtn = dockProgress > 0.65 && p > 0.85;
          cta.classList.toggle('is-visible', showBtn);
          const link = cta.querySelector('a');
          if (link) {
            link.tabIndex = showBtn ? 0 : -1;
            link.setAttribute('aria-hidden', showBtn ? 'false' : 'true');
          }
        }
      } else {
        // ── FLOATING: background decoration ──
        scene.classList.remove('is-docked');
        scene.style.pointerEvents = 'none';

        // Gentle 3D perspective shift — hero of the animation is the ARM
        const rx = -6 + p * 12;
        const ry = 10 - p * 6;
        const rz = Math.sin(p * Math.PI) * 3;
        const s = 1 + p * 0.03;

        clapper.style.position = 'relative';
        clapper.style.left = 'auto';
        clapper.style.top = 'auto';
        clapper.style.translate = 'none';
        clapper.style.transform = `
          rotateX(${rx}deg) rotateY(${ry}deg) rotateZ(${rz}deg)
          scale3d(${s},${s},${s})
        `;

        scene.style.opacity = String(opacity);

        if (cta) {
          cta.classList.remove('is-visible');
          const link = cta.querySelector('a');
          if (link) { link.tabIndex = -1; link.setAttribute('aria-hidden', 'true'); }
        }
      }

      ticking = false;
    };

    const onScroll = () => {
      if (!ticking) { ticking = true; requestAnimationFrame(update); }
    };

    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', update, { passive: true });
  }
</script>
