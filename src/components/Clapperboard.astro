---
/**
 * Clapperboard — scroll-driven background decoration.
 * Starts OPEN at the top, CLOSES as the user scrolls down,
 * fully closed when the contact section comes into view.
 * Pure CSS + minimal JS (IntersectionObserver for scroll progress).
 */
---

<div class="clapper" aria-hidden="true" data-clapper>
  {/* Top bar (the hinged arm that swings closed) */}
  <svg class="clapper__top" viewBox="0 0 600 80" fill="none" preserveAspectRatio="none">
    <defs>
      <linearGradient id="clapper-bar-grad" x1="0" y1="0" x2="600" y2="0" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="var(--ink)" stop-opacity="0.07"/>
        <stop offset="50%" stop-color="var(--ink)" stop-opacity="0.10"/>
        <stop offset="100%" stop-color="var(--ink)" stop-opacity="0.06"/>
      </linearGradient>
    </defs>
    {/* Diagonal stripes on the clapper arm */}
    <rect width="600" height="80" fill="url(#clapper-bar-grad)" rx="6"/>
    <g stroke="var(--amber)" stroke-width="3" opacity="0.18">
      <line x1="60" y1="0" x2="20" y2="80"/>
      <line x1="140" y1="0" x2="100" y2="80"/>
      <line x1="220" y1="0" x2="180" y2="80"/>
      <line x1="300" y1="0" x2="260" y2="80"/>
      <line x1="380" y1="0" x2="340" y2="80"/>
      <line x1="460" y1="0" x2="420" y2="80"/>
      <line x1="540" y1="0" x2="500" y2="80"/>
    </g>
    {/* Hinge circle */}
    <circle cx="28" cy="40" r="10" fill="var(--amber)" opacity="0.15"/>
  </svg>

  {/* Bottom board */}
  <svg class="clapper__board" viewBox="0 0 600 420" fill="none" preserveAspectRatio="none">
    <defs>
      <linearGradient id="clapper-board-grad" x1="0" y1="0" x2="0" y2="420" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="var(--ink)" stop-opacity="0.06"/>
        <stop offset="100%" stop-color="var(--ink)" stop-opacity="0.03"/>
      </linearGradient>
    </defs>
    <rect width="600" height="420" fill="url(#clapper-board-grad)" rx="6"/>
    {/* Field lines */}
    <g stroke="var(--line)" stroke-width="1" opacity="0.5">
      <line x1="40" y1="70" x2="560" y2="70"/>
      <line x1="40" y1="140" x2="560" y2="140"/>
      <line x1="40" y1="210" x2="560" y2="210"/>
      <line x1="40" y1="280" x2="560" y2="280"/>
    </g>
    {/* Labels — very subtle */}
    <text x="50" y="55" fill="var(--ink-soft)" opacity="0.18" font-family="var(--font-utility)" font-size="14" font-weight="500" letter-spacing="0.1em">PRODUCTION</text>
    <text x="50" y="125" fill="var(--ink-soft)" opacity="0.18" font-family="var(--font-utility)" font-size="14" font-weight="500" letter-spacing="0.1em">DIRECTOR</text>
    <text x="50" y="195" fill="var(--ink-soft)" opacity="0.18" font-family="var(--font-utility)" font-size="14" font-weight="500" letter-spacing="0.1em">CAMERA</text>
    <text x="50" y="265" fill="var(--ink-soft)" opacity="0.18" font-family="var(--font-utility)" font-size="14" font-weight="500" letter-spacing="0.1em">DATE</text>
    <text x="400" y="55" fill="var(--ink-soft)" opacity="0.18" font-family="var(--font-utility)" font-size="14" font-weight="500" letter-spacing="0.1em">SCENE</text>
    <text x="400" y="125" fill="var(--ink-soft)" opacity="0.18" font-family="var(--font-utility)" font-size="14" font-weight="500" letter-spacing="0.1em">TAKE</text>
  </svg>
</div>

<style>
  .clapper {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(280px, 50vw, 520px);
    z-index: -1;
    pointer-events: none;
    opacity: 0.45;
    filter: blur(0.5px);
    transition: opacity 0.1s linear;
  }

  .clapper__board {
    width: 100%;
    height: auto;
    display: block;
  }

  .clapper__top {
    width: 100%;
    height: auto;
    display: block;
    /* Hinge at the left edge, bottom of the arm */
    transform-origin: 4.7% 100%;
    /* Start fully open — the arm is swung up */
    transform: rotate(calc(var(--clapper-progress, 0) * -45deg + 0deg));
    /* Initial state: open = rotated -45deg upward */
    transition: none; /* driven by JS scroll */
  }

  /* When fully closed, hide subtle to not interfere */
  .clapper.is-closed {
    opacity: 0.2;
  }

  @media (prefers-reduced-motion: reduce) {
    .clapper {
      display: none;
    }
  }

  /* Hide on very small screens where it would be too cramped */
  @media (max-width: 480px) {
    .clapper {
      width: 220px;
      opacity: 0.3;
    }
  }
</style>

<script>
  // Drive the clapperboard arm rotation based on scroll progress.
  // 0 = top of page (open, arm up), 1 = contact section (closed, arm down).
  const clapper = document.querySelector<HTMLElement>('[data-clapper]');
  if (clapper) {
    const top = clapper.querySelector<SVGElement>('.clapper__top');
    if (top) {
      let ticking = false;

      const update = () => {
        const scrollY = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        // Map scroll position to 0–1 (clamped)
        const progress = Math.min(1, Math.max(0, scrollY / Math.max(docHeight, 1)));

        // Arm rotation: -45deg (open) → 0deg (closed)
        const angle = -45 + (progress * 45);
        top.style.transform = `rotate(${angle}deg)`;

        // Fade out a bit when fully closed
        clapper.classList.toggle('is-closed', progress > 0.92);

        ticking = false;
      };

      const onScroll = () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      };

      update();
      window.addEventListener('scroll', onScroll, { passive: true });
    }
  }
</script>
