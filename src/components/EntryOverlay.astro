</div>

<script>
  const overlay = document.querySelector<HTMLElement>("[data-entry-overlay]");

  if (overlay) {
    const root = document.documentElement;
    const storageKey = "rc_entry_played";
    const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const mobile = matchMedia("(max-width: 767.98px)").matches;

    let played = false;
    try {
      played = sessionStorage.getItem(storageKey) === "1";
    } catch {
      played = false;
    }

    const markPlayed = () => {
      try {
        sessionStorage.setItem(storageKey, "1");
      } catch {
        // Animation remains time-based when sessionStorage is unavailable.
      }
    };

    if (reduceMotion || played) {
      root.classList.remove("entry-pending");
      overlay.remove();
    } else {
      root.classList.add("entry-pending");

      let done = false;
      let revealTimer = 0;
      let removeTimer = 0;
      const listenerOptions = { passive: true } as const;

      const cleanup = () => {
        window.removeEventListener("pointerdown", skip, listenerOptions);
        window.removeEventListener("keydown", skip);
        window.removeEventListener("touchstart", skip, listenerOptions);
      };

      const finish = (skipping = false) => {
        if (done) return;
        done = true;
        markPlayed();
        cleanup();
        window.clearTimeout(revealTimer);
        window.clearTimeout(removeTimer);

        if (skipping) overlay.classList.add("is-skipping");
        overlay.classList.add("is-revealing");

        removeTimer = window.setTimeout(() => {
          overlay.classList.add("is-done");
          root.classList.remove("entry-pending");
          overlay.remove();
        }, skipping ? 200 : 700);
      };

      function skip() {
        finish(true);
      }

      window.addEventListener("pointerdown", skip, listenerOptions);
      window.addEventListener("keydown", skip);
      window.addEventListener("touchstart", skip, listenerOptions);

      requestAnimationFrame(() => {
        overlay.classList.add("is-ready");
        revealTimer = window.setTimeout(() => finish(false), mobile ? 2350 : 2600);
      });
    }
  }
</script>
