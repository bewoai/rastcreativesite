---
/**
 * TestimonialCard — a single customer quote card (roadmap Faz 3: social proof).
 *
 * Styling follows the site's design tokens (tokens.css): --line border, --amber
 * accent, --font-display for the decorative quote mark, and data-reveal for
 * scroll-triggered reveal animation. Card scales up subtly on hover (desktop).
 */
interface Props {
  /** The customer's quote — plain text, no markdown. */
  quote: string;
  /** Full name of the person. */
  name: string;
  /** Role / position. */
  role?: string;
  /** Company / brand name. */
  company: string;
}

const { quote, name, role, company } = Astro.props;
---

<blockquote class="tcard" data-reveal>
  <span class="tcard__mark" aria-hidden="true">"</span>
  <p class="tcard__quote">{quote}</p>
  <footer class="tcard__footer">
    <cite class="tcard__cite">
      <strong class="tcard__name">{name}</strong>
      {role && <span class="tcard__role">{role}</span>}
      <span class="tcard__company">{company}</span>
    </cite>
  </footer>
</blockquote>

<style>
  .tcard {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    padding: clamp(1.5rem, 3vw, 2rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background: var(--paper);
    transition: transform var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }

  @media (hover: hover) {
    .tcard:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 36px -12px color-mix(in srgb, var(--ink) 10%, transparent);
    }
  }

  .tcard__mark {
    position: absolute;
    top: -0.15rem;
    left: 0.85rem;
    font-family: var(--font-display);
    font-size: 4.5rem;
    line-height: 1;
    color: color-mix(in srgb, var(--amber) 28%, transparent);
    pointer-events: none;
    user-select: none;
  }

  .tcard__quote {
    margin: 0;
    padding-top: 1.5rem;
    font-size: clamp(0.98rem, 1.2vw, 1.08rem);
    line-height: 1.6;
    color: var(--ink);
    font-style: italic;
  }

  .tcard__footer {
    margin-top: auto;
    padding-top: 0.85rem;
    border-top: 1px solid var(--line);
  }

  .tcard__cite {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-style: normal;
  }

  .tcard__name {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink);
  }

  .tcard__role {
    font-size: 0.82rem;
    color: var(--ink-soft);
  }

  .tcard__company {
    font-family: var(--font-utility);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--amber-text);
  }
</style>
