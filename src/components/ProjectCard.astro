---
import Eyebrow from "./Eyebrow.astro";

interface Props {
  href: string;
  title: string;
  category: string;
  poster: string;
  posterAlt?: string;
  client?: string;
  year?: string | number;
  /** Amber timecode revealed on hover (e.g. "01:24"). */
  timecode?: string;
  /** 9:16 reel/short instead of the default 16:9. */
  vertical?: boolean;
  class?: string;
}

const {
  href,
  title,
  category,
  poster,
  posterAlt,
  client,
  year,
  timecode,
  vertical = false,
  class: className,
} = Astro.props;
const meta = [client].filter(Boolean).join(" · ");
---

<a href={href} class:list={["card", className]} data-reveal>
  <div
    class:list={["card__media", { "card__media--vertical": vertical }]}
    style={vertical ? `--poster-url: url("${poster}")` : undefined}
  >
    <img
      class="card__poster"
      src={poster}
      alt={posterAlt ?? `${title} — proje görseli`}
      loading="lazy"
      decoding="async"
      width="1600"
      height="900"
    />
  </div>
  <div class="card__body">
    <Eyebrow tone="amber">{category}</Eyebrow>
    <h3 class="card__title">{title}</h3>
    {meta && <p class="card__meta">{meta}</p>}
  </div>
</a>

<style>
  /* Glass card: translucent surface + blur + bloom glow on hover. */
  .card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-card);
    background: var(--glass-bg);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    overflow: hidden;
    touch-action: manipulation;
    box-shadow: 0 4px 20px -8px color-mix(in srgb, var(--ink) 8%, transparent);
    transition:
      transform var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--amber) 40%, var(--glass-border));
    box-shadow:
      var(--bloom-amber),
      0 12px 32px -8px color-mix(in srgb, var(--ink) 12%, transparent);
  }
  .card:focus-visible {
    box-shadow: none;
    outline: 2px solid var(--amber);
    outline-offset: 3px;
  }

  .card__media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: color-mix(in srgb, var(--ink) 92%, #ffffff);
  }
  .card__media--vertical {
    aspect-ratio: 16 / 9 !important;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    isolation: isolate;
  }
  .card__media--vertical::before,
  .card__media--vertical::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .card__media--vertical::before {
    background-image: var(--poster-url);
    background-size: cover;
    background-position: center;
    filter: blur(16px) saturate(0.9);
    opacity: 0.52;
    transform: scale(1.18);
  }
  .card__media--vertical::after {
    background:
      linear-gradient(90deg, rgba(17, 15, 14, 0.5), transparent 28%, transparent 72%, rgba(17, 15, 14, 0.5)),
      rgba(17, 15, 14, 0.28);
  }
  .card__poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--dur) var(--ease-out);
  }
  .card__media--vertical .card__poster {
    position: relative;
    z-index: 1;
    width: auto;
    height: 100%;
    max-width: 38%;
    object-fit: cover;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.16);
  }
  .card:hover .card__poster {
    transform: scale(1.04);
  }

  .card__timecode {
    position: absolute;
    z-index: 2;
    top: 0.7rem;
    right: 0.7rem;
    font-family: var(--font-utility);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--amber);
    background: color-mix(in srgb, var(--ink) 70%, transparent);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    padding: 0.28rem 0.55rem;
    border-radius: var(--radius-pill);
    opacity: 0;
    transform: translateY(-4px);
    transition:
      opacity var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
  }
  .card:hover .card__timecode,
  .card:focus-visible .card__timecode {
    opacity: 1;
    transform: translateY(0);
  }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1rem 1.1rem 1.2rem;
  }
  .card__title {
    margin: 0;
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--ink);
  }
  .card__meta {
    margin: 0;
    font-size: 0.85rem;
    color: var(--ink-soft);
  }
</style>
