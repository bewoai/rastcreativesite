---
import type { CollectionEntry } from "astro:content";
import ProjectCard from "./ProjectCard.astro";
import { PROJECT_CATEGORIES } from "../consts";

interface Props {
  projects: CollectionEntry<"projects">[];
  /** Active category slug; "" means "Tümü" (all). */
  activeSlug?: string;
}

const { projects, activeSlug = "" } = Astro.props;
---

<div class="gallery">
  <nav class="filters" aria-label="Kategori filtresi">
    <a href="/projeler" class="chip" aria-current={activeSlug === "" ? "page" : undefined}>
      Tümü
    </a>
    {
      PROJECT_CATEGORIES.map((c) => (
        <a
          href={`/projeler/kategori/${c.slug}`}
          class="chip"
          aria-current={activeSlug === c.slug ? "page" : undefined}
        >
          {c.label}
        </a>
      ))
    }
  </nav>

  {
    projects.length > 0 ? (
      <div class="grid-cards">
        {projects.map((p) => (
          <ProjectCard
            href={`/projeler/${p.id}`}
            title={p.data.title}
            category={p.data.category}
            poster={p.data.poster}
            posterAlt={p.data.posterAlt}
            client={p.data.client}
            year={p.data.year}
            timecode={p.data.duration}
          />
        ))}
      </div>
    ) : (
      <p class="empty">Bu kategoride henüz proje eklenmedi.</p>
    )
  }
</div>

<style>
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    min-height: var(--tap-min);
    padding: 0 1.1rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--line);
    font-family: var(--font-utility);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--ink);
    touch-action: manipulation;
    transition:
      background-color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
  }
  .chip:hover {
    border-color: var(--ink);
  }
  .chip[aria-current="page"] {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--paper);
  }
  .grid-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .empty {
    color: var(--ink-soft);
  }
  @media (min-width: 640px) {
    .grid-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .grid-cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
