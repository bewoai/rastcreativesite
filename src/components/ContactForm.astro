---
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import { WEB3FORMS_ACCESS_KEY, SITE } from "../consts";
---

<form class="cform" action="https://api.web3forms.com/submit" method="POST" data-cform>
  <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
  <input type="hidden" name="subject" value="Yeni ön görüşme talebi — rastcreative.com" />
  <input type="hidden" name="from_name" value={SITE.name} />
  {/* honeypot — bots fill this; humans never see it */}
  <input type="checkbox" name="botcheck" class="cform__hp" tabindex="-1" autocomplete="off" />

  <div class="cform__row">
    <div class="field">
      <label for="cf-name">Ad Soyad <span class="req" aria-hidden="true">*</span></label>
      <input id="cf-name" name="name" type="text" autocomplete="name" required />
    </div>
    <div class="field">
      <label for="cf-company">Firma</label>
      <input id="cf-company" name="company" type="text" autocomplete="organization" />
    </div>
  </div>

  <div class="cform__row">
    <div class="field">
      <label for="cf-phone">Telefon <span class="req" aria-hidden="true">*</span></label>
      <input
        id="cf-phone"
        name="phone"
        type="tel"
        inputmode="tel"
        autocomplete="tel"
        required
        aria-describedby="cf-phone-hint"
      />
      <span id="cf-phone-hint" class="hint">Size en hızlı telefonla dönüş yaparız.</span>
    </div>
    <div class="field">
      <label for="cf-email">E-posta <span class="req" aria-hidden="true">*</span></label>
      <input
        id="cf-email"
        name="email"
        type="email"
        inputmode="email"
        autocomplete="email"
        required
        aria-describedby="cf-email-hint"
      />
      <span id="cf-email-hint" class="hint">Teklif ve detayları e-posta ile paylaşırız.</span>
    </div>
  </div>

  <div class="field">
    <label for="cf-project">Proje türü <span class="req" aria-hidden="true">*</span></label>
    <select id="cf-project" name="project_type" required>
      <option value="" disabled selected>Seçin…</option>
      <option value="Kurumsal / Tanıtım Filmi">Kurumsal / Tanıtım Filmi</option>
      <option value="Reklam Filmi">Reklam Filmi</option>
      <option value="Drone Çekimi">Drone Çekimi</option>
      <option value="Sosyal Medya / Reels">Sosyal Medya / Reels</option>
      <option value="Ürün & Mekan Çekimi">Ürün & Mekan Çekimi</option>
      <option value="Marka Hikayesi">Marka Hikayesi</option>
      <option value="Medikal">Medikal</option>
      <option value="Düğün & Organizasyon">Düğün & Organizasyon</option>
      <option value="Diğer">Diğer</option>
    </select>
  </div>

  <div class="field">
    <label for="cf-message">Mesajınız <span class="req" aria-hidden="true">*</span></label>
    <textarea id="cf-message" name="message" rows="5" required></textarea>
  </div>

  <label class="consent">
    <input type="checkbox" name="kvkk" value="onaylandi" required />
    <span>
      <a href="/kvkk" target="_blank" rel="noopener">KVKK Aydınlatma Metni</a>'ni
      okudum; kişisel verilerimin iletişim amacıyla işlenmesine ve belirtilen
      kapsamda aktarılmasına açık rıza veriyorum.
      <span class="req" aria-hidden="true">*</span>
    </span>
  </label>

  <div class="cform__status" data-status role="status" aria-live="polite"></div>

  <div class="cform__actions">
    <Button type="submit" size="lg" class="cform__submit">E-posta ile Gönder</Button>
    <button type="button" class="cform__wa" data-wa-send>
      <Icon name="whatsapp" size={20} /> WhatsApp'tan Gönder
    </button>
  </div>
</form>

<style>
  .cform {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .cform__hp {
    position: absolute !important;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
  .cform__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  label {
    font-family: var(--font-utility);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--ink);
  }
  .req {
    color: var(--amber-text);
  }
  .hint {
    font-size: 0.82rem;
    color: var(--ink-soft);
  }
  input[type="text"],
  input[type="tel"],
  input[type="email"],
  select,
  textarea {
    font: inherit;
    font-size: 1rem;
    min-height: var(--tap-min);
    padding: 0.75rem 1rem;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    transition:
      border-color var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out);
  }
  textarea {
    min-height: 8rem;
    resize: vertical;
    line-height: var(--leading-body);
  }
  input:focus-visible,
  select:focus-visible,
  textarea:focus-visible {
    outline: none;
    border-color: var(--amber);
    box-shadow: var(--focus-ring);
  }
  input:user-invalid,
  select:user-invalid,
  textarea:user-invalid {
    border-color: #b42318;
  }
  .consent {
    position: relative;
    display: grid;
    grid-template-columns: var(--tap-min) 1fr;
    align-items: start;
    gap: 0.6rem;
    min-height: var(--tap-min);
    padding-block: 0.35rem;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.92rem;
    color: var(--ink-soft);
    line-height: 1.5;
    cursor: pointer;
  }
  .consent::before {
    content: "";
    width: 1.25rem;
    height: 1.25rem;
    margin-top: 0.2rem;
    border: 1.5px solid var(--line-strong);
    border-radius: 4px;
    background: var(--paper);
  }
  .consent:has(input:checked)::before {
    background: var(--amber);
    border-color: var(--amber);
    box-shadow: inset 0 0 0 4px var(--paper);
  }
  .consent:has(input:focus-visible)::before {
    outline: 2px solid var(--amber);
    outline-offset: 3px;
  }
  .consent input {
    position: absolute;
    inset: 0 auto auto 0;
    width: var(--tap-min);
    height: var(--tap-min);
    margin: 0;
    opacity: 0;
    accent-color: var(--amber);
    cursor: pointer;
  }
  .consent a {
    display: inline-flex;
    align-items: center;
    min-height: var(--tap-min);
    color: var(--amber-text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .cform__status {
    font-size: 0.95rem;
  }
  .cform__status.is-pending {
    color: var(--ink-soft);
  }
  .cform__status.is-ok {
    color: #1a7f37;
    font-weight: 600;
  }
  .cform__status.is-err {
    color: #b42318;
    font-weight: 600;
  }
  .cform__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: stretch;
  }
  .cform__wa {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 56px;
    padding: 0.95rem 1.6rem;
    border: 0;
    border-radius: var(--radius-pill);
    background: #25d366;
    color: #fff;
    font-family: var(--font-utility);
    font-size: 1.05rem;
    font-weight: 500;
    cursor: pointer;
    touch-action: manipulation;
    transition:
      transform var(--dur-fast) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .cform__wa:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 26px -8px rgba(37, 211, 102, 0.5);
  }
  .cform__wa:active {
    transform: scale(0.98);
  }
  .cform__wa:focus-visible {
    outline: 3px solid var(--ink);
    outline-offset: 3px;
  }
  @media (min-width: 560px) {
    .cform__row {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<script>
  import { waLink } from "../consts";

  type RcTrack = (
    eventName: string,
    eventParams?: Record<string, unknown>,
    callback?: () => void,
  ) => void;

  const trackEvent = (
    eventName: string,
    eventParams?: Record<string, unknown>,
    callback?: () => void,
  ) => {
    const rcTrack = (window as Window & { rcTrack?: RcTrack }).rcTrack;
    if (typeof rcTrack === "function") {
      rcTrack(eventName, eventParams, callback);
      return;
    }
    callback?.();
  };

  const form = document.querySelector<HTMLFormElement>("[data-cform]");
  if (form) {
    const status = form.querySelector<HTMLElement>("[data-status]");
    const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const setStatus = (text: string, state: "pending" | "ok" | "err") => {
      if (status) {
        status.textContent = text;
        status.className = `cform__status is-${state}`;
      }
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      if (submit) submit.disabled = true;
      setStatus("Gönderiliyor…", "pending");
      try {
        const res = await fetch(form.action, {
          method: "POST",
          headers: { Accept: "application/json" },
          body: new FormData(form),
        });
        const json = await res.json().catch(() => ({}));
        if (res.ok && json.success) {
          form.reset();
          setStatus("Teşekkürler! Mesajınız ulaştı, en kısa sürede dönüş yapacağız.", "ok");
          trackEvent(
            "lead_form_submit_success",
            {
              event_category: "lead",
              event_label: "contact_form",
              form_id: "contact_form",
            },
            () => {
              window.location.href = "/tesekkurler";
            },
          );
        } else {
          setStatus(
            json.message ?? "Gönderilemedi. Lütfen tekrar deneyin ya da alttaki WhatsApp seçeneğini kullanın.",
            "err",
          );
        }
      } catch {
        setStatus("Bağlantı hatası. Lütfen tekrar deneyin ya da alttaki WhatsApp seçeneğini kullanın.", "err");
      } finally {
        if (submit) submit.disabled = false;
      }
    });

    // "WhatsApp'tan Gönder" — build a structured message from the same fields
    // and open WhatsApp with it prefilled (the visitor taps send in their app).
    const waBtn = form.querySelector<HTMLButtonElement>("[data-wa-send]");
    waBtn?.addEventListener("click", () => {
      const get = (sel: string) =>
        form.querySelector<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(sel);
      for (const sel of ["#cf-name", "#cf-phone", "#cf-email", "#cf-project", "#cf-message", 'input[name="kvkk"]']) {
        const el = get(sel);
        if (el && !el.checkValidity()) {
          el.reportValidity();
          return;
        }
      }
      const val = (sel: string) => get(sel)?.value.trim() ?? "";
      const lines = ["Yeni teklif talebi — rastcreative.com", "", `Ad: ${val("#cf-name")}`];
      if (val("#cf-company")) lines.push(`Firma: ${val("#cf-company")}`);
      lines.push(`Telefon: ${val("#cf-phone")}`);
      if (val("#cf-email")) lines.push(`E-posta: ${val("#cf-email")}`);
      lines.push(`Proje türü: ${val("#cf-project")}`);
      lines.push(`Mesaj: ${val("#cf-message")}`);
      const url = waLink(lines.join("\n"));
      if (!url) return;
      setStatus("WhatsApp açılıyor — mesajı göndermek için WhatsApp'ta 'Gönder'e basın.", "ok");
      trackEvent("contact_whatsapp_click", {
        event_category: "contact",
        event_label: "whatsapp_form",
      });
      window.open(url, "_blank", "noopener");
    });
  }
</script>
