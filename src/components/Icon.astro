---
import type { IconName } from "../consts";

interface Props {
  name: IconName;
  size?: number;
  class?: string;
  /** If given, the icon is meaningful (role=img + title); else decorative. */
  label?: string;
}

const { name, size = 24, class: className, label } = Astro.props;

// Inner SVG per icon. Root sets fill:none + stroke:currentColor; glyphs that
// need a solid fill override locally. Custom line set — no emoji / stock icons.
const ICONS: Record<IconName, string> = {
  home: `<path d="M4 11.5 12 5l8 6.5"/><path d="M6.5 10.2V19h11v-8.8"/>`,
  projects: `<rect x="3.5" y="5.5" width="17" height="13" rx="2.5"/><path d="M10.6 9.7 15.2 12l-4.6 2.3z" fill="currentColor" stroke="none"/>`,
  services: `<path d="M12 4.4 20 8.4 12 12.4 4 8.4z"/><path d="M4 12.4 12 16.4 20 12.4"/>`,
  about: `<circle cx="12" cy="8.4" r="3.3"/><path d="M5.8 19a6.2 6.2 0 0 1 12.4 0"/>`,
  contact: `<path d="M4.5 6.5A2 2 0 0 1 6.5 4.5h11a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H10l-4 3.5V14.5H6.5a2 2 0 0 1-2-2z"/>`,
  instagram: `<rect x="3.6" y="3.6" width="16.8" height="16.8" rx="5"/><circle cx="12" cy="12" r="3.7"/><circle cx="16.7" cy="7.3" r="1.15" fill="currentColor" stroke="none"/>`,
  youtube: `<rect x="3" y="6" width="18" height="12" rx="3.4"/><path d="M10.5 9.2 15.4 12l-4.9 2.8z" fill="currentColor" stroke="none"/>`,
  tiktok: `<path d="M13.8 4.5c.4 2.2 1.8 3.6 4 3.9v2.4c-1.4 0-2.8-.45-3.95-1.25v5a4.85 4.85 0 1 1-4.85-4.85c.3 0 .6.03.9.08v2.5a2.35 2.35 0 1 0 1.6 2.22V4.5z" fill="currentColor" stroke="none"/>`,
  linkedin: `<rect x="3.5" y="3.5" width="17" height="17" rx="3"/><path d="M7.2 10.2v6.3M7.2 7.4v.01M11 16.5v-6.3m0 2.1c.5-1.3 1.6-2.1 3-2.1 1.7 0 2.4 1.1 2.4 3.1v3.2"/>`,
  "arrow-right": `<path d="M4.5 12h14"/><path d="M12.5 6 19 12l-6.5 6"/>`,
  "arrow-up-right": `<path d="M7 17 17 7"/><path d="M8.5 7H17v8.5"/>`,
  play: `<path d="M8 6.2v11.6L18 12z" fill="currentColor" stroke="none"/>`,
  whatsapp: `<path d="M5.4 18.6 4.4 14a7.6 7.6 0 1 1 3.05 3z"/><path d="M9 9.4c0 3 2.5 5.5 5.5 5.5.55 0 1-.4 1-.65 0-.5-1.4-1.15-1.8-1.05-.3.08-.5.5-.72.5-.5 0-2.28-1.6-2.28-2.2 0-.22.42-.4.42-.7.1-.42-.6-1.8-1.1-1.8-.22 0-.62.4-.62 1z" fill="currentColor" stroke="none"/>`,
  video: `<rect x="3" y="7" width="11" height="10" rx="2"/><path d="M14 11l6-3v8l-6-3z"/>`,
  strategy: `<path d="M12 3a6 6 0 0 0-3.6 10.8c.55.4.85 1 .85 1.7v.5h5.5v-.5c0-.7.3-1.3.85-1.7A6 6 0 0 0 12 3z"/><path d="M9.5 19h5"/><path d="M10.5 21.5h3"/>`,
  edit: `<rect x="3.5" y="5.5" width="17" height="13" rx="2"/><path d="M3.5 9.5h17M3.5 14.5h17M8.5 5.5v13M15.5 5.5v13"/>`,
};
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  role={label ? "img" : undefined}
  aria-hidden={label ? undefined : "true"}
  aria-label={label}
  set:html={(label ? `<title>${label}</title>` : "") + ICONS[name]}
/>
