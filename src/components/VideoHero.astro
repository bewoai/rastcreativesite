---
/**
 * Full-bleed background showreel for hero/header areas.
 *
 * Performance & a11y:
 *  - The `poster` image is the LCP — it shows instantly; the video is
 *    `preload="none"` and only starts after `window.load`, so it never blocks
 *    first paint.
 *  - Muted + loop + playsinline → autoplays on mobile and desktop.
 *  - prefers-reduced-motion OR Save-Data → the loop never plays; the poster
 *    stays. (roadmap §0.1: one short, silent, optimised hero loop.)
 *
 * Pass encoded loop paths once the studio supplies them. Until they exist the
 * poster carries the hero on its own.
 */
interface Props {
  /** Built URL of the poster image (desktop / default). Omit for a bg-only hero. */
  poster?: string;
  /** Optional art-directed poster for narrow screens (portrait crop). */
  posterMobile?: string;
  /** Intrinsic poster dimensions; keeps the LCP image fully declared. */
  posterWidth?: number;
  posterHeight?: number;
  /** Public paths to the encoded loop; both recommended. */
  webm?: string;
  mp4?: string;
  /** Section min-height (CSS length). */
  height?: string;
  /** Scrim strength 0–100 (higher = darker, more readable text). */
  scrim?: number;
  /** Pull up under the floating nav so the video reaches the top edge. */
  flush?: boolean;
  /** Fade the bottom edge into `--ink-band` for a seamless join with the
   *  dark section below (use only when the next section starts on --ink-band). */
  fadeBottom?: boolean;
  class?: string;
}

const defaultHeight = "min(84vh, 760px)";
const defaultScrim = 62;

const {
  poster,
  posterMobile,
  posterWidth,
  posterHeight,
  webm,
  mp4,
  height = defaultHeight,
  scrim = defaultScrim,
  flush = false,
  fadeBottom = false,
  class: className,
} = Astro.props;

const hasVideo = Boolean(webm || mp4);

// Always emit the custom properties — the scrim gradient and min-height read
// `var(--vhero-scrim)` / `var(--vhero-h)`, so omitting them (the old "defaults"
// path) left the variables undefined → invalid color-mix → no scrim at all.
const styleVars = `--vhero-h:${height}; --vhero-scrim:${scrim}%`;
---

<section
  class:list={["vhero", { "vhero--flush": flush, "vhero--fade": fadeBottom }, className]}
  style={styleVars}
>
  {/* Art-directed poster: portrait crop on phones, landscape on desktop. It is
      the LCP, so the <img> is eager + high priority (no separate preload). */}
  {poster && (
    <picture class="vhero__media">
      {posterMobile && <source media="(max-width: 767.98px)" srcset={posterMobile} />}
      <img
        src={poster}
        alt=""
        loading="eager"
        decoding="async"
        fetchpriority="high"
        width={posterWidth}
        height={posterHeight}
      />
    </picture>
  )}
  {
    hasVideo && (
      <video
        class="vhero__media vhero__video"
        muted
        loop
        playsinline
        preload="none"
        aria-hidden="true"
        tabindex="-1"
        data-showreel
      >
        {webm && <source src={webm} type="video/webm" />}
        {mp4 && <source src={mp4} type="video/mp4" />}
      </video>
    )
  }
  <div class="vhero__scrim" aria-hidden="true"></div>
  
  <!-- Viewfinder UI overlay (Production cues) -->
  <div class="vhero__viewport-ui" aria-hidden="true">
    <span class="vhero__corner vhero__corner--bl"></span>
    <span class="vhero__corner vhero__corner--br"></span>
    <div class="vhero__metadata">
      <span class="vhero__rec"><span class="vhero__rec-dot"></span>REC</span>
      <span class="vhero__timecode" id="intro-timecode">TC 00:00:00:00</span>
    </div>
  </div>

  <div class="vhero__inner">
    <slot />
  </div>
</section>

<style>
  .vhero {
    position: relative;
    min-height: var(--vhero-h);
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
    background: var(--ink-band); /* fallback before the poster paints */
  }
  .vhero__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -3;
  }
  .vhero__scrim {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
    pointer-events: none;
  }
  .vhero__media {
    object-fit: cover;
    display: block;
  }
  .vhero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Seamless fade of the hero's bottom edge into the dark section below
     (--ink-band, theme-aware) — removes the hard horizontal seam. Sits below
     interactive content; never intercepts pointer events. */
  .vhero--fade::after {
    content: "";
    position: absolute;
    inset-inline: 0;
    bottom: -1px;
    height: clamp(10rem, 28vh, 20rem);
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(
        180deg,
        transparent 0%,
        color-mix(in srgb, var(--ink-band) 18%, transparent) 28%,
        color-mix(in srgb, var(--ink-band) 72%, transparent) 64%,
        var(--ink-band) 100%
      );
  }
  .vhero__scrim {
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--ink-band) calc(var(--vhero-scrim) - 18%), transparent),
        color-mix(in srgb, var(--ink-band) var(--vhero-scrim), transparent)
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--ink-band) calc(var(--vhero-scrim) - 8%), transparent),
        transparent 62%
      );
  }
  .vhero__inner {
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
    padding-block: clamp(2.5rem, 7vw, 4.5rem);
  }

  /* Flush: cancel the body's nav padding so the video reaches the top edge,
     and add it back as inner top padding so content clears the nav pill. */
  .vhero--flush {
    margin-top: calc(-1 * (3.15rem + env(safe-area-inset-top, 0px)));
  }
  .vhero--flush .vhero__inner {
    padding-top: calc(3.15rem + env(safe-area-inset-top, 0px) + clamp(2.5rem, 7vw, 4.5rem));
  }
  @media (min-width: 768px) {
    .vhero--flush {
      margin-top: -5.5rem;
    }
    .vhero--flush .vhero__inner {
      padding-top: calc(5.5rem + clamp(2.5rem, 7vw, 4.5rem));
    }
  }
  @media (max-width: 767.98px) {
    .vhero {
      min-height: min(82dvh, 40rem);
      align-items: center;
    }
    .vhero__inner {
      padding-top: clamp(2rem, 10vw, 3.75rem);
      padding-bottom: calc(5.5rem + env(safe-area-inset-bottom, 0px));
    }
    .vhero--flush {
      margin-top: calc(-1 * (3.45rem + env(safe-area-inset-top, 0px)));
    }
    .vhero--flush .vhero__inner {
      padding-top: calc(3.45rem + env(safe-area-inset-top, 0px) + clamp(1.35rem, 6vw, 2.35rem));
    }
    .vhero__scrim {
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--ink-band) calc(var(--vhero-scrim) - 10%), transparent),
          color-mix(in srgb, var(--ink-band) calc(var(--vhero-scrim) + 8%), transparent)
        ),
        linear-gradient(
          90deg,
          color-mix(in srgb, var(--ink-band) calc(var(--vhero-scrim) + 6%), transparent),
          color-mix(in srgb, var(--ink-band) 18%, transparent)
        );
    }
  }

  /* Viewfinder UI overlay */
  .vhero__viewport-ui {
    position: absolute;
    inset: var(--container-pad);
    pointer-events: none;
    z-index: 1; /* above background layers, below content */
  }

  .vhero__corner {
    position: absolute;
    width: 14px;
    height: 14px;
    border: 1px solid rgba(255, 255, 255, 0.18); /* 18% white - very subtle corner markers */
    pointer-events: none;
  }

  .vhero__corner--bl { bottom: -1px; left: -1px; border-right: 0; border-top: 0; }
  .vhero__corner--br { bottom: -1px; right: -1px; border-left: 0; border-top: 0; }

  .vhero__metadata {
    position: absolute;
    bottom: 1.25rem;
    right: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-family: var(--font-utility);
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.95); /* 95% white */
    letter-spacing: 0.08em;
  }

  .vhero__rec {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 700;
  }

  .vhero__rec-dot {
    width: 7px;
    height: 7px;
    background-color: #ef4444;
    border-radius: 50%;
    animation: rec-pulse 1s steps(2, start) infinite;
  }

  @keyframes rec-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .vhero__rec-dot {
      animation: none;
    }
  }

  /* Adjust for mobile viewport spacing */
  @media (max-width: 768px) {
    .vhero__viewport-ui {
      inset: 1rem;
    }
  }
</style>

<script>
  // Start the muted loop only after load — never for reduced-motion / data-saver.
  document.querySelectorAll<HTMLVideoElement>("[data-showreel]").forEach((v) => {
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const saveData = (navigator as Navigator & { connection?: { saveData?: boolean } })
      .connection?.saveData;
    if (reduce || saveData || !v.querySelector("source")) return;
    const start = () => {
      v.play().catch(() => {});
    };
    if (document.readyState === "complete") start();
    else window.addEventListener("load", start, { once: true });
  });

  // Update timecode dynamically at 25 fps
  const tcElement = document.getElementById('intro-timecode');
  if (tcElement) {
    let frames = 0;
    let seconds = 0;
    let minutes = 4; // Start at 00:04:12:00
    let hours = 0;

    const pad = (n: number) => String(n).padStart(2, '0');

    window.setInterval(() => {
      frames += 1;
      if (frames >= 25) {
        frames = 0;
        seconds += 1;
        if (seconds >= 60) {
          seconds = 0;
          minutes += 1;
          if (minutes >= 60) {
            minutes = 0;
            hours += 1;
          }
        }
      }
      tcElement.textContent = `TC ${pad(hours)}:${pad(minutes)}:${pad(seconds)}:${pad(frames)}`;
    }, 40); // 25 fps
  }
</script>
