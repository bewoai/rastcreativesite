---
interface Props {
  /** ink = on light surfaces (default), paper = on the dark footer band. */
  tone?: "ink" | "paper";
  /** Show the "Rast Creative" wordmark next to the mark. */
  wordmark?: boolean;
  href?: string;
  class?: string;
}

const { tone = "ink", wordmark = true, href = "/", class: className } = Astro.props;
const fill = tone === "paper" ? "var(--paper)" : "var(--ink)";
---

<a
  href={href}
  class:list={["logo", className]}
  style={`--logo-fill:${fill}`}
  aria-label="Rast Creative Studio — ana sayfa"
>
  {/* Real Rast Creative Studio mark — upper icon portion of the logo */}
  <svg class="logo__mark" viewBox="240 400 600 210" fill="var(--logo-fill)" aria-hidden="true">
    <circle cx="589.63" cy="568.91" r="26.43"/>
    <path d="M530.22,546.19c4.89,2.17,9.42,3.26,14.71,4.26.39,1.6.62,3.45.61,5.27l-.14,38.81c-1.85.55-3.65.62-5.44.4l-6.84-.86c-15.96-2-30.38-9.19-41.9-20.3-1.32-1.27-2.96-.91-4.19.14-19.44,16.67-44.82,23.79-70.19,20.19-17.39-2.47-32.9-9.74-45.83-21.68-12.44-11.49-21.27-26.22-24.98-42.87-1.72-7.72-3.22-15.25-2.78-23.2.41-7.39,1.58-14.42,3.49-21.56,5.66-21.06,19.09-38.9,37.83-50.06,11.91-7.09,25.09-11.27,39.03-11.96l34.93-.49,32.57.02,25.11.2v45.67s-89.14.07-89.14.07c-15.24.01-29.19,10.46-34.95,24.36-6.16,14.86-3.32,32.3,7.46,44.29,4.97,5.53,11.52,8.77,18.4,11.01,13.62,4.42,25.77.84,37.38-7.09,9.6-7.88,15.07-19.51,15.1-32.09l.04-19.31h45.73s.1,34.39.1,34.39c.03,9.77,5.03,18.03,13.88,22.38Z"/>
    <path d="M298.94,590.93l-45.62.04.1-91.06c.02-21.15,7.03-43.9,22.32-58.65,15.35-15.2,35.9-23.2,57.5-22.02l-.02,44.9c-1.45.38-2.66.59-4.02.61-18.5.26-30.21,15.7-30.21,33.82l-.03,92.37Z"/>
    <path d="M675.57,520.23c23.39,14.7,40.77,32.9,44.76,61.18l.09,9.37-12.44.11-22.31.1-10.29-.46c-.06-14.32-13.21-27.46-25.14-33.88l-24.8-13.35c-11.14-5.35-21.78-10.87-32.06-17.7-17.59-11.69-29.55-26.63-29.9-48.55-.19-12.05,3.33-23.34,10.85-32.69,13.41-16.68,34.24-24.51,55.37-25.22l13.67.08c16.89.1,33.05,6.39,45.81,17.57,12.77,11.19,19.66,27.13,20.46,44.03.04.76.1,2.9-1,2.9l-43.42.02c-2.93-10.84-6.29-16.6-16.92-20.58s-22.72-3.49-32.84,2.25c-4.45,2.53-7.29,7.41-6.13,12.49,1,4.37,4.08,7.58,7.55,10.26,5.34,4.12,11.1,7.25,17.18,10.28l20.78,10.38,20.74,11.41Z"/>
    <path d="M834.51,547.65l.06,43.15c-21.51,1.95-46.3-8.8-60.45-24.87-12.81-14.55-18.34-32.32-19.44-51.66v-46.05s-21.27-.01-21.27-.01l-.02-45.66,21.27-.1.04-45.83,45.8-.02v45.85s34.01.06,34.01.06l-.02,45.69-33.96.04-.03,44.16c.25,18.97,11.75,32.25,30.83,33.11,1.17.05,3.18.45,3.18,2.14Z"/>
  </svg>
  {wordmark && <span class="logo__word">Rast Creative</span>}
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--logo-fill);
    line-height: 1;
  }
  .logo__mark {
    width: 2.2rem;
    height: auto;
    flex: none;
  }
  .logo__word {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.1rem;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
</style>
