---
/**
 * Blog post card — used on /blog and in the homepage "Son yazılar" section.
 * Cover comes from the collection's image() field, so astro:assets optimises it.
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  href: string;
  title: string;
  description?: string;
  /** Pre-formatted, human-readable date (e.g. "6 Haziran 2026"). */
  date: string;
  /** ISO date for the <time datetime> attribute. */
  datetime: string;
  cover?: ImageMetadata;
  coverAlt?: string;
  /** Heading level for the card title so the surrounding page keeps a valid
   * H1 → H2 → H3 order. Homepage lists cards under an H2 (default h3); the
   * /blog index lists them directly under the page H1, so it passes "h2". */
  titleTag?: "h2" | "h3";
}

const { href, title, description, date, datetime, cover, coverAlt, titleTag = "h3" } = Astro.props;
const TitleTag = titleTag;
---

<a href={href} class="bcard" data-reveal>
  {
    cover && (
      <div class="bcard__media">
        <Image
          src={cover}
          alt={coverAlt ?? title}
          widths={[400, 700, 1000]}
          sizes="(min-width: 1000px) 340px, (min-width: 640px) 45vw, 92vw"
          loading="lazy"
          class="bcard__img"
        />
      </div>
    )
  }
  <div class="bcard__body">
    <time class="bcard__date" datetime={datetime}>{date}</time>
    <TitleTag class="bcard__title">{title}</TitleTag>
    {description && <p class="bcard__desc">{description}</p>}
    <span class="bcard__more">Oku →</span>
  </div>
</a>

<style>
  .bcard {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-card);
    background: var(--glass-bg);
    overflow: hidden;
    touch-action: manipulation;
    box-shadow: 0 4px 20px -8px color-mix(in srgb, var(--ink) 8%, transparent);
    transition:
      transform var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .bcard:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--amber) 40%, var(--glass-border));
    box-shadow:
      var(--bloom-amber),
      0 12px 32px -8px color-mix(in srgb, var(--ink) 12%, transparent);
  }
  .bcard:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 3px;
  }
  .bcard__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: color-mix(in srgb, var(--ink) 92%, #ffffff);
  }
  .bcard__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--dur) var(--ease-out);
  }
  .bcard:hover .bcard__img {
    transform: scale(1.04);
  }
  .bcard__body {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1.1rem 1.2rem 1.3rem;
  }
  .bcard__date {
    font-family: var(--font-utility);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
  }
  .bcard__title {
    margin: 0;
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--ink);
  }
  .bcard__desc {
    margin: 0;
    font-size: 0.92rem;
    color: var(--ink-soft);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .bcard__more {
    margin-top: 0.3rem;
    font-family: var(--font-utility);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--amber-text);
  }
</style>
