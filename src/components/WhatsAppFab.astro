---
/**
 * Floating contact dock — the 35+ audience's primary channel is WhatsApp
 * (roadmap §2), with small Instagram / YouTube buttons stacked above it.
 * Bottom-right, sits above the mobile tab-bar. Renders nothing until a real
 * WhatsApp number exists in consts; socials come from SOCIAL.
 */
import Icon from "./Icon.astro";
import { CONTACT, waLink, SOCIAL } from "../consts";

const href = waLink();
const socials = SOCIAL.filter((s) => s.icon === "instagram" || s.icon === "youtube");
---

{
  href && (
    <div class="dock">
      {socials.length > 0 && (
        <div class="dock__socials">
          {socials.map((s) => (
            <a
              class:list={["sfab", `sfab--${s.icon}`]}
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${s.label} sayfamız`}
            >
              <Icon name={s.icon} size={20} />
            </a>
          ))}
        </div>
      )}
      <a
        class="wafab"
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="WhatsApp'tan yazın"
        data-wafab
      >
        <span class="wafab__ring" aria-hidden="true" />
        <Icon name="whatsapp" size={28} class="wafab__icon" />
        <span class="wafab__label">WhatsApp</span>
      </a>
    </div>
    <div class="mobile-actions" aria-label="Hızlı iletişim">
      <a
        class="mobile-actions__btn mobile-actions__btn--call"
        href={`tel:${CONTACT.phoneIntl}`}
        aria-label={`Telefonla arayın: ${CONTACT.phone}`}
        data-callbar
      >
        <Icon name="contact" size={20} />
        <span>Ara</span>
      </a>
      <a
        class="mobile-actions__btn mobile-actions__btn--wa"
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="WhatsApp'tan yazın"
        data-wabar
      >
        <Icon name="whatsapp" size={22} />
        <span>WhatsApp</span>
      </a>
    </div>
    <script>
      const wafab = document.querySelector<HTMLAnchorElement>("[data-wafab]");
      if (wafab) {
        wafab.addEventListener("click", () => {
          if (typeof gtag === "function") {
            gtag("event", "contact", {
              event_category: "whatsapp",
              event_label: "whatsapp_fab",
            });
          }
        });
      }
      document.querySelector<HTMLAnchorElement>("[data-wabar]")?.addEventListener("click", () => {
        if (typeof gtag === "function") {
          gtag("event", "contact", {
            event_category: "whatsapp",
            event_label: "whatsapp_mobile_bar",
          });
        }
      });
      document.querySelector<HTMLAnchorElement>("[data-callbar]")?.addEventListener("click", () => {
        if (typeof gtag === "function") {
          gtag("event", "contact", {
            event_category: "phone",
            event_label: "phone_mobile_bar",
          });
        }
      });
    </script>
  )
}

<style>
  /* Fixed corner that holds the social mini-buttons above the WhatsApp pill. */
  .dock {
    position: fixed;
    right: clamp(0.9rem, 3vw, 1.5rem);
    bottom: clamp(0.9rem, 3vw, 1.5rem);
    z-index: 51;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.6rem;
  }
  .dock__socials {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: flex-end;
  }

  /* ── Social mini-button: quiet by default, brand colour on hover ───────── */
  .sfab {
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 50%;
    background: var(--paper);
    border: 1px solid var(--line);
    color: var(--ink-soft);
    box-shadow: 0 6px 16px -8px rgba(17, 17, 16, 0.4);
    text-decoration: none;
    touch-action: manipulation;
    transition:
      transform var(--dur) var(--ease-out),
      color var(--dur) var(--ease-out),
      background-color var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .sfab:hover {
    transform: translateY(-2px);
    color: #fff;
    border-color: transparent;
  }
  .sfab:active {
    transform: scale(0.95);
  }
  .sfab:focus-visible {
    outline: 3px solid var(--amber);
    outline-offset: 2px;
  }
  .sfab--instagram:hover {
    background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    box-shadow: 0 8px 20px -6px rgba(220, 39, 67, 0.5);
  }
  .sfab--youtube:hover {
    background: #ff0000;
    box-shadow: 0 8px 20px -6px rgba(255, 0, 0, 0.5);
  }

  /* ── WhatsApp pill (primary CTA) ───────────────────────────────────────── */
  .wafab {
    position: relative;
    isolation: isolate;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    height: 3.5rem;
    padding: 0 1.15rem;
    border-radius: var(--radius-pill);
    background: #25d366;
    color: #fff;
    box-shadow:
      0 10px 28px -8px rgba(37, 211, 102, 0.55),
      0 4px 12px -4px rgba(17, 17, 16, 0.3);
    text-decoration: none;
    touch-action: manipulation;
    transition:
      transform var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .wafab__icon {
    flex: none;
  }
  .wafab__label {
    font-family: var(--font-utility);
    font-size: 0.95rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .wafab:hover {
    transform: translateY(-2px);
    box-shadow:
      0 14px 34px -8px rgba(37, 211, 102, 0.65),
      0 6px 16px -4px rgba(17, 17, 16, 0.35);
  }
  .wafab:active {
    transform: scale(0.97);
  }
  .wafab:focus-visible {
    outline: 3px solid var(--ink);
    outline-offset: 3px;
  }

  .mobile-actions {
    display: none;
  }

  /* Subtle attention pulse (once-settled, gentle). */
  .wafab__ring {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.5);
    animation: wafab-pulse 2.6s ease-out infinite;
    z-index: -1;
  }
  @keyframes wafab-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.45);
    }
    70%,
    100% {
      box-shadow: 0 0 0 16px rgba(37, 211, 102, 0);
    }
  }

  /* On mobile, use one calm thumb-reachable action bar instead of floating
     bubbles competing with the tab bar and hero CTA. */
  @media (max-width: 767.98px) {
    .dock {
      display: none;
    }
    .mobile-actions {
      position: fixed;
      left: 0.75rem;
      right: 0.75rem;
      bottom: calc(4.75rem + env(safe-area-inset-bottom, 0px));
      z-index: 51;
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 0.55rem;
      padding: 0.45rem;
      border: 1px solid color-mix(in srgb, #ffffff 55%, transparent);
      border-radius: 1.35rem;
      background: linear-gradient(
        180deg,
        color-mix(in srgb, #ffffff 78%, transparent),
        color-mix(in srgb, var(--paper) 68%, transparent)
      );
      -webkit-backdrop-filter: blur(24px) saturate(1.7);
      backdrop-filter: blur(24px) saturate(1.7);
      box-shadow:
        0 -8px 28px -16px rgba(17, 17, 16, 0.35),
        0 1px 0 0 color-mix(in srgb, #ffffff 80%, transparent) inset;
    }
    :global(html[data-theme="dark"]) .mobile-actions {
      background: linear-gradient(
        180deg,
        color-mix(in srgb, #2a241e 84%, transparent),
        color-mix(in srgb, var(--paper) 76%, transparent)
      );
      border-color: color-mix(in srgb, var(--on-ink) 14%, transparent);
    }
    .mobile-actions__btn {
      min-height: 3rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.45rem;
      border-radius: 1rem;
      font-family: var(--font-utility);
      font-size: 0.92rem;
      font-weight: 700;
      letter-spacing: 0;
      touch-action: manipulation;
      transition:
        transform var(--dur-fast) var(--ease-out),
        background-color var(--dur-fast) var(--ease-out);
    }
    .mobile-actions__btn:active {
      transform: scale(0.97);
    }
    .mobile-actions__btn:focus-visible {
      outline: 2px solid var(--amber);
      outline-offset: 2px;
    }
    .mobile-actions__btn--call {
      color: var(--ink);
      background: color-mix(in srgb, var(--ink) 7%, transparent);
    }
    .mobile-actions__btn--wa {
      color: #ffffff;
      background: #25d366;
      box-shadow: 0 8px 20px -10px rgba(37, 211, 102, 0.8);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dock,
    .sfab,
    .wafab,
    .wafab__ring {
      transition: none;
      animation: none;
    }
  }
</style>
