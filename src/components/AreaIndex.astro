---
import Eyebrow from "./Eyebrow.astro";
import Icon from "./Icon.astro";
import type { SeoService } from "../data/seo-services";
import type { SeoLocation } from "../data/locations";

interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  services: readonly SeoService[];
  locations: readonly SeoLocation[];
}

const {
  eyebrow = "Hizmet bölgeleri",
  title,
  text,
  services,
  locations,
} = Astro.props;

const previewLocationNames = (items: readonly SeoLocation[]) =>
  items
    .slice(0, 4)
    .map((location) => location.name)
    .join(", ");
---

<div class="area-index" data-reveal>
  <div class="area-index__head">
    <Eyebrow tone="soft">{eyebrow}</Eyebrow>
    <h2>{title}</h2>
    <p>{text}</p>
  </div>

  <div class="area-links" aria-label="Bölgesel hizmet sayfaları">
    {
      services.map((service) => (
        <details class="area-card">
          <summary>
            <span class="area-card__icon" aria-hidden="true">
              <Icon name="arrow-right" size={14} class="area-card__chevron" />
            </span>
            <span class="area-card__summary">
              <span class="area-card__title">{service.name}</span>
              <span class="area-card__preview">
                {previewLocationNames(locations)}
                {locations.length > 4 && (
                  <em>+{locations.length - 4} bölge</em>
                )}
              </span>
            </span>
          </summary>

          <div class="area-card__body">
            <p>{service.tagline}</p>
            <a class="area-card__hub" href={`/${service.slug}`}>
              {service.name} ana sayfası
              <Icon name="arrow-up-right" size={13} />
            </a>
            <ul>
              {locations.map((location) => (
                <li>
                  <a
                    href={`/${service.slug}/${location.slug}`}
                    title={`${service.name} — ${location.name}`}
                  >
                    {location.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </details>
      ))
    }
  </div>
</div>

<style>
  /* ── Container ──────────────────────────────────────────────── */
  .area-index {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 2rem);
  }

  /* ── Left column: heading ───────────────────────────────────── */
  .area-index__head {
    display: grid;
    gap: 0.75rem;
    align-content: start;
  }
  .area-index__head h2 {
    margin: 0;
    max-width: 16ch;
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .area-index__head p {
    margin: 0;
    max-width: 46ch;
    color: var(--ink-soft);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  /* ── Right column: cards grid ───────────────────────────────── */
  .area-links {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }

  /* ── Individual card ────────────────────────────────────────── */
  .area-card {
    border: 1px solid var(--line);
    border-radius: 0.75rem;
    background: var(--paper);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease;
    overflow: hidden;
  }
  .area-card:hover {
    border-color: color-mix(in srgb, var(--amber) 28%, var(--line));
    box-shadow: 0 4px 20px color-mix(in srgb, var(--ink) 6%, transparent);
  }
  .area-card[open] {
    border-color: color-mix(in srgb, var(--amber) 22%, var(--line));
  }

  /* ── Summary row ────────────────────────────────────────────── */
  .area-card summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    padding: 0.85rem 1rem;
    user-select: none;
  }
  .area-card summary::-webkit-details-marker {
    display: none;
  }
  .area-card summary:focus {
    outline: none;
  }
  .area-card summary:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: -2px;
    border-radius: 0.65rem;
  }

  /* Arrow icon */
  .area-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: none;
    width: 1.6rem;
    height: 1.6rem;
    margin-top: 0.08rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--amber) 10%, transparent);
    color: var(--amber-text);
    transition: background 180ms ease;
  }
  .area-card:hover .area-card__icon {
    background: color-mix(in srgb, var(--amber) 16%, transparent);
  }
  .area-card__chevron {
    transition: transform 220ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .area-card[open] .area-card__chevron {
    transform: rotate(90deg);
  }

  /* Text stack */
  .area-card__summary {
    min-width: 0;
    flex: 1;
    display: grid;
    gap: 0.2rem;
  }
  .area-card__title {
    color: var(--ink);
    font-family: var(--font-utility);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .area-card__preview {
    overflow: hidden;
    color: var(--ink-soft);
    font-family: var(--font-utility);
    font-size: 0.72rem;
    line-height: 1.3;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .area-card__preview em {
    font-style: normal;
    color: var(--amber-text);
    font-weight: 600;
    margin-left: 0.15em;
  }

  /* ── Expanded body ──────────────────────────────────────────── */
  .area-card__body {
    padding: 0 1rem 1rem;
    border-top: 1px solid var(--line);
    margin-top: 0;
  }
  .area-card__body p {
    margin: 0.65rem 0 0.75rem;
    color: var(--ink-soft);
    font-size: 0.82rem;
    line-height: 1.5;
  }
  .area-card__hub {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    margin-bottom: 0.85rem;
    color: var(--amber-text);
    font-family: var(--font-utility);
    font-size: 0.76rem;
    font-weight: 700;
    text-decoration: none;
    transition: gap 150ms ease;
  }
  .area-card__hub:hover {
    gap: 0.45rem;
    color: var(--amber-text);
  }
  .area-card__hub:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* Location pill list */
  .area-card__body ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .area-card__body li a {
    display: inline-flex;
    align-items: center;
    height: 1.75rem;
    padding: 0 0.6rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: color-mix(in srgb, var(--paper) 60%, transparent);
    color: var(--ink);
    font-family: var(--font-utility);
    font-size: 0.72rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition:
      background 150ms ease,
      border-color 150ms ease,
      color 150ms ease,
      transform 150ms ease;
  }
  .area-card__body li a:hover {
    border-color: color-mix(in srgb, var(--amber) 50%, var(--line));
    background: color-mix(in srgb, var(--amber) 8%, var(--paper));
    color: var(--amber-text);
    transform: translateY(-1px);
  }
  .area-card__body li a:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 2px;
  }

  /* ── Responsive ─────────────────────────────────────────────── */
  @media (min-width: 700px) {
    .area-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 900px) {
    .area-index {
      grid-template-columns: minmax(14rem, 0.45fr) minmax(0, 1.55fr);
      align-items: start;
      gap: clamp(2rem, 4vw, 3rem);
    }
  }
</style>
